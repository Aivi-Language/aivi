@no_prelude
module integrationTests.stdlib.aivi.reactive.tests

use aivi
use aivi.reactive
use aivi.testing

@test "signal stores and updates current value"
signal_set_update = do Effect {
  count = signal 1

  assertEq (get count) 1
  assertEq (peek count) 1

  assertEq (set count 4) Unit
  assertEq (get count) 4

  assertEq (update count (_ + 3)) Unit
  assertEq (get count) 7
}

@test "signal patch operator updates scalar signals"
signal_patch_operator_updates_scalar = do Effect {
  count = signal 1

  assertEq (count <| (_ + 3)) Unit
  assertEq (get count) 4
}

@test "signal pipe derives a new signal from the current value"
signal_pipe_derives_from_source = do Effect {
  count   = signal 2
  doubled = count |> (_ * 2)

  assertEq (get doubled) 4
  assertEq (set count 5) Unit
  assertEq (get doubled) 10
}

@test "signal patch operator accepts replacement values"
signal_patch_operator_sets_scalar = do Effect {
  count = signal 1

  assertEq (count <| 9) Unit
  assertEq (get count) 9
}

@test "derive creates a derived signal from one source"
derive_updates_from_source = do Effect {
  count   = signal 2
  doubled = derive count (_ * 2)

  assertEq (get doubled) 4
  assertEq (set count 5) Unit
  assertEq (get doubled) 10
}

@test "record signals accept patch updates"
patch_updates_record_signal = do Effect {
  state = signal { count: 2 }

  assertEq (update state (patch { count: _ + 3 })) Unit
  assertEq (get state) { count: 5 }
}

@test "record signals accept signal updater operator sugar"
signal_patch_operator_updates_record_signal = do Effect {
  state = signal { count: 2, enabled: False }

  assertEq (state <| (current => current <| { count: _ + 3, enabled: True })) Unit
  assertEq (get state) { count: 5, enabled: True }
}

@test "record signals accept direct patch operator sugar"
signal_patch_operator_applies_record_patch = do Effect {
  state = signal { count: 2, enabled: False }

  assertEq (state <| { count: _ + 3, enabled: True }) Unit
  assertEq (get state) { count: 5, enabled: True }
}

@test "combineAll derives from a record of signals"
combineAll_updates_from_inputs = do Effect {
  firstName = signal "Ada"
  lastName  = signal "Lovelace"
  fullName  = combineAll { first: firstName, last: lastName } (vals =>
    "{vals.first} {vals.last}"
  )

  assertEq (get fullName) "Ada Lovelace"

  assertEq (set firstName "Grace") Unit
  assertEq (get fullName) "Grace Lovelace"

  assertEq (set lastName "Hopper") Unit
  assertEq (get fullName) "Grace Hopper"
}

@test "watch observes signal changes"
watch_observes_changes = do Effect {
  count         = signal 0
  seen          = signal 0
  _subscription = watch count (value => set seen value)

  assertEq (set count 3) Unit
  assertEq (get seen) 3
}

@test "dispose stops further watcher notifications"
dispose_stops_notifications = do Effect {
  count         = signal 0
  notifications = signal 0
  subscription  = watch count (_ => update notifications (_ + 1))

  assertEq (set count 1) Unit
  assertEq (get notifications) 1

  assertEq (dispose subscription) Unit
  assertEq (set count 2) Unit
  assertEq (get notifications) 1
}

@test "batch can group multiple writes"
batch_groups_writes = do Effect {
  first  = signal 1
  second = signal 2
  sum    = combineAll { a: first, b: second } (vals => vals.a + vals.b)

  assertEq (batch (_ => (set first 3, set second 4))) (Unit, Unit)
  assertEq (get sum) 7
}

@test "chained signal pipe derives through multiple transforms"
chained_pipe_derives_through_transforms = do Effect {
  count  = signal 3
  result = count |> (_ * 2) |> (_ + 10)

  assertEq (get result) 16
  assertEq (set count 5) Unit
  assertEq (get result) 20
}

@test "derived signal from another derived signal"
derived_from_derived = do Effect {
  base    = signal 2
  doubled = derive base (_ * 2)
  quad    = derive doubled (_ * 2)

  assertEq (get quad) 8
  assertEq (set base 3) Unit
  assertEq (get doubled) 6
  assertEq (get quad) 12
}

@test "peek does not create dependency for derived signals"
peek_no_dependency = do Effect {
  source    = signal 1
  unrelated = signal 0
  calls     = signal 0
  _sub      = watch source (_ => {
      _ = peek unrelated
      update calls (_ + 1)
  })

  assertEq (set source 2) Unit
  assertEq (get calls) 1

  assertEq (set unrelated 99) Unit
  assertEq (get calls) 1
}

@test "multiple watchers on the same signal"
multiple_watchers_same_signal = do Effect {
  source = signal 0
  seen1  = signal 0
  seen2  = signal 0
  _sub1  = watch source (v => set seen1 v)
  _sub2  = watch source (v => set seen2 v)

  assertEq (set source 7) Unit
  assertEq (get seen1) 7
  assertEq (get seen2) 7
}

@test "batch coalesces multiple watcher notifications into one"
batch_coalesces_watcher_calls = do Effect {
  count = signal 0
  calls = signal 0
  _sub  = watch count (_ => update calls (_ + 1))

  assertEq (batch (_ => {
        set count 1
        set count 2
        set count 3
  })) Unit
  assertEq (get count) 3
  assertEq (get calls) 1
}

@test "signal pipe with record field access"
signal_pipe_record_field = do Effect {
  state = signal { name: "Ada", score: 10 }
  name  = state |> .name

  assertEq (get name) "Ada"
  assertEq (state <| { name: "Grace" }) Unit
  assertEq (get name) "Grace"
}

@test "do Event exposes lifecycle signals"
event_exposes_lifecycle_signals = do Effect {
  saveEvent = do Event {
    pure 42
  }

  assertEq (get saveEvent.result) None
  assertEq (get saveEvent.error) None
  assertEq (get saveEvent.done) False
  assertEq (get saveEvent.running) False

  outcome <- attempt saveEvent.run

  assertEq outcome (Ok 42)
  assertEq (get saveEvent.result) (Some 42)
  assertEq (get saveEvent.error) None
  assertEq (get saveEvent.done) True
  assertEq (get saveEvent.running) False
}

topCounter : Signal Int
topCounter = signal 0

@test "top-level signal preserves identity across references"
top_level_signal_preserves_identity = do Effect {
  assertEq (peek topCounter) 0
  _ = set topCounter 42
  assertEq (peek topCounter) 42
  _ = update topCounter (_ + 1)
  assertEq (peek topCounter) 43
}

@no_prelude
module integrationTests.stdlib.aivi.secrets.tests

use aivi
use aivi.testing
use aivi.secrets
use aivi.text (fromBytes, toBytes, Utf8)

@test "blob accessors"
blob_accessors = do Effect {
  cipher = toBytes Utf8 "test-data"
  value  = blob "key-1" "aes-gcm" cipher
  _       <- assertEq (blobKeyId value) "key-1"
  _       <- assertEq (blobAlgorithm value) "aes-gcm"
  decoded <- assertOk (fromBytes Utf8 (blobCiphertext value))
  assertEq decoded "test-data"
}

@test "put get delete lifecycle"
put_get_delete_lifecycle = do Effect {
  key    = "integration-tests/secrets/token"
  secret = blob key "aes-256-gcm" (toBytes Utf8 "ciphertext-v1")

  _             <- delete key
  missingBefore <- get key
  _             <- assertNone missingBefore
  _             <- put key secret
  stored        <- get key
  saved         <- assertSome stored
  _             <- assertEq (blobKeyId saved) key
  _             <- assertEq (blobAlgorithm saved) "aes-256-gcm"
  decoded       <- assertOk (fromBytes Utf8 (blobCiphertext saved))
  _             <- assertEq decoded "ciphertext-v1"
  _             <- delete key
  missingAfter  <- get key
  assertNone missingAfter
}

@test "put replaces existing blob"
put_replaces_existing_blob = do Effect {
  key    = "integration-tests/secrets/replaced"
  first  = blob key "aes-256-gcm" (toBytes Utf8 "ciphertext-v1")
  second = blob key "chacha20-poly1305" (toBytes Utf8 "ciphertext-v2")

  _       <- delete key
  _       <- put key first
  _       <- put key second
  stored  <- get key
  saved   <- assertSome stored
  _       <- assertEq (blobAlgorithm saved) "chacha20-poly1305"
  decoded <- assertOk (fromBytes Utf8 (blobCiphertext saved))
  _       <- assertEq decoded "ciphertext-v2"
  delete key
}

@test "validateBlob checks non-empty metadata"
validateBlob_checks_non_empty_metadata = do Effect {
  valid            = blob "key-1" "aes-gcm" (toBytes Utf8 "")
  missingKey       = blob "" "aes-gcm" (toBytes Utf8 "cipher")
  missingAlgorithm = blob "key-1" "" (toBytes Utf8 "cipher")

  _ <- assertEq (validateBlob valid) True
  _ <- assertEq (validateBlob missingKey) False
  assertEq (validateBlob missingAlgorithm) False
}

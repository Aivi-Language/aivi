@no_prelude
module integrationTests.stdlib.aivi.secrets.tests

use aivi
use aivi.testing
use aivi.secrets
use aivi.text (fromBytes, toBytes, Utf8)

@test "blob accessors"
blob_accessors = {
  cipher = toBytes Utf8 "test-data"
  value  = blob "key-1" "aes-gcm" cipher
  assertEq (blobKeyId value) "key-1"
  assertEq (blobAlgorithm value) "aes-gcm"
  assertOk (fromBytes Utf8 (blobCiphertext value))
   |> assertEq "test-data"
}

@test "put get delete lifecycle"
put_get_delete_lifecycle = {
  key    = "integration-tests/secrets/token"
  secret = blob key "aes-256-gcm" (toBytes Utf8 "ciphertext-v1")

  delete key
  get key
   |> assertNone
  put key secret
  get key
   |> assertSome
   |> saved => {
        assertEq (blobKeyId saved) key
        assertEq (blobAlgorithm saved) "aes-256-gcm"
        assertOk (fromBytes Utf8 (blobCiphertext saved))
         |> assertEq "ciphertext-v1"
      }
  delete key
  get key
   |> assertNone
}

@test "put replaces existing blob"
put_replaces_existing_blob = {
  key    = "integration-tests/secrets/replaced"
  first  = blob key "aes-256-gcm" (toBytes Utf8 "ciphertext-v1")
  second = blob key "chacha20-poly1305" (toBytes Utf8 "ciphertext-v2")

  delete key
  put key first
  put key second
  get key
   |> assertSome
   |> saved => {
        assertEq (blobAlgorithm saved) "chacha20-poly1305"
        assertOk (fromBytes Utf8 (blobCiphertext saved))
         |> assertEq "ciphertext-v2"
      }
  delete key
}

@test "validateBlob checks non-empty metadata"
validateBlob_checks_non_empty_metadata = {
  valid            = blob "key-1" "aes-gcm" (toBytes Utf8 "")
  missingKey       = blob "" "aes-gcm" (toBytes Utf8 "cipher")
  missingAlgorithm = blob "key-1" "" (toBytes Utf8 "cipher")

  assertEq (validateBlob valid) True
  assertEq (validateBlob missingKey) False
  assertEq (validateBlob missingAlgorithm) False
}

module integrationTests.stdlib.aivi.crypto.tests

use aivi.testing
use aivi.crypto
use aivi.text (length)

// -- Hashing --

@test "sha256 hello"
sha256_hello = {
  s = sha256 "hello"
  assert (s == "2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824")
}

@test "sha384 hello"
sha384_hello = {
  s = sha384 "hello"
  assert (length s == 96)
}

@test "sha512 hello"
sha512_hello = {
  s = sha512 "hello"
  assert (length s == 128)
}

@test "sha256 empty"
sha256_empty = {
  s = sha256 ""
  assert (s == "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855")
}

// -- HMAC --

@test "hmac sha256"
hmacSha256_functional = {
  key = fromHex "0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b" match
    | Ok b  => b
    | Err _ => panic "bad hex"
  msg = fromHex "4869205468657265" match
    | Ok b  => b
    | Err _ => panic "bad hex"
  tag = hmacSha256 key msg
  assert (length (toHex tag) > 0)
}

@test "hmac sha512"
hmacSha512_functional = {
  key = fromHex "0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b" match
    | Ok b  => b
    | Err _ => panic "bad hex"
  msg = fromHex "4869205468657265" match
    | Ok b  => b
    | Err _ => panic "bad hex"
  tag = hmacSha512 key msg
  assert (length (toHex tag) > 0)
}

@test "hmac verify roundtrip"
hmacVerify_roundtrip = {
  key = fromHex "aabbccdd" match
    | Ok b  => b
    | Err _ => panic "bad hex"
  msg = fromHex "deadbeef" match
    | Ok b  => b
    | Err _ => panic "bad hex"
  tag   = hmacSha256 key msg
  valid = hmacVerify key msg tag
  assert valid
}

// -- Password Hashing --

@test "hash password and verify"
hashPassword_and_verify = hashPassword "myS3cret!"
  |> hashed => verifyPassword "myS3cret!" hashed
  |> assert

@test "verify password wrong"
verifyPassword_wrong = hashPassword "correct"
  |> hashed => verifyPassword "wrong" hashed
  |> ok => assert (not ok)

// -- Random --

@test "random bytes length"
randomBytes_length = randomBytes 32
  |> toHex
  |> length
  |> size => assert (size == 64)

@test "random uuid format"
randomUuid_format = randomUuid
  |> length
  |> size => assert (size == 36)

// -- Utilities --

@test "to hex from hex roundtrip"
toHex_fromHex_roundtrip = randomBytes 16
  |> original => {
       hex = toHex original
       decoded = fromHex hex match
         | Ok b  => b
         | Err _ => panic "fromHex failed"
       assert (secureEquals original decoded)
     }

@test "to base64url encodes url safe text without padding"
toBase64Url_known_vector = {
  original = fromHex "fbff" match
    | Ok b  => b
    | Err _ => panic "fromHex failed"
  encoded = toBase64Url original
  assert (encoded == "-_8")
}

@test "secure equals same"
secureEquals_same = randomBytes 8
  |> a => assert (secureEquals a a)

@test "secure equals different"
secureEquals_different = randomBytes 8
  |> a => randomBytes 8
    |> b => assert (not (secureEquals a b))

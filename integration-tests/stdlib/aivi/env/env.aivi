@no_prelude
module integrationTests.stdlib.aivi.env.tests

use aivi
use aivi.testing
use aivi.system

@test "env get missing"
env_get_missing = {
  // Reading a nonexistent env var should fail
  attempt (env.get "AIVI_TEST_NONEXISTENT_VAR_12345")
   |> assertErr
   |> text.isEmpty
   |> assertEq False
}

@test "env set and get"
env_set_and_get = {
  env.set "AIVI_TEST_KEY" "test_value"
  env.get "AIVI_TEST_KEY"
   |> assertEq "test_value"
}

@test "env remove"
env_remove = {
  env.set "AIVI_TEST_REMOVE" "to_remove"
  env.remove "AIVI_TEST_REMOVE"
  attempt (env.get "AIVI_TEST_REMOVE")
   |> assertErr
   |> text.isEmpty
   |> assertEq False
}

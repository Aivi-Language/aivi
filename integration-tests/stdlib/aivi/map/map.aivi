@no_prelude
module integrationTests.stdlib.aivi.map.tests

use aivi
use aivi.testing
use aivi.map

@test "map insert and get"
map_insertAndGet = do Effect {
  m = insert "a" 1 empty
  value <- assertSome (get "a" m)
  assertEq value 1
}

@test "map get or else"
map_getOrElse = do Effect {
  m   = insert "found" 7 empty
  val = getOrElse "found" 99 m
  assertEq val 7
  missing = getOrElse "missing" 99 m
  assertEq missing 99
}

@test "map get or else is pipe-friendly"
map_getOrElse_pipe = do Effect {
  m = insert "found" 7 empty
  assertEq (m |> getOrElse "found" 99) 7
  assertEq (m |> getOrElse "missing" 99) 99
}

@test "map remove"
map_remove = do Effect {
  m  = insert "a" 1 empty
  m2 = remove "a" m
  assertNone (get "a" m2)
}

@test "map has"
map_has = do Effect {
  m      = insert "key" 10 empty
  exists = has "key" m
  assert exists
  missing = has "nope" m
  assert (missing == False)
}

@test "map size"
map_size = do Effect {
  m  = insert "a" 1 (insert "b" 2 empty)
  s0 = size empty
  assertEq s0 0
  s2 = size m
  assertEq s2 2
}

@test "from list keeps last value for duplicate key"
map_fromList_lastValueWins = do Effect {
  m = fromList [("a", 1), ("a", 2), ("b", 3)]
  value <- assertSome (get "a" m)
  assertEq value 2
  assertEq (size m) 2
}

@test "union is right biased"
map_union_rightBiased = do Effect {
  left   = fromList [("a", 1), ("shared", 2)]
  right  = fromList [("shared", 5), ("b", 3)]
  merged = union left right
  shared <- assertSome (get "shared" merged)
  assertEq shared 5
  assertEq (size merged) 3
}

@test "update missing key is noop"
map_update_missing_key_is_noop = do Effect {
  original = insert "a" 1 empty
  updated  = update "missing" (_ => 99) original
  value <- assertSome (get "a" updated)
  assertEq value 1
  assertEq (size updated) 1
}

@test "alter inserts and removes"
map_alter_insertAndRemove = do Effect {
  inserted = alter "a" (_ => Some 1) empty
  value <- assertSome (get "a" inserted)
  assertEq value 1
  removed = alter "a" (_ => None) inserted
  assertNone (get "a" removed)
}

@test "mergeWith combines overlaps"
map_mergeWith_combines_overlap = do Effect {
  left   = fromList [("a", 1), ("shared", 2)]
  right  = fromList [("shared", 3), ("b", 4)]
  merged = mergeWith (_ leftValue rightValue => leftValue + rightValue) left right
  shared <- assertSome (get "shared" merged)
  assertEq shared 5
  onlyLeft <- assertSome (get "a" merged)
  assertEq onlyLeft 1
  onlyRight <- assertSome (get "b" merged)
  assertEq onlyRight 4
}

@no_prelude
module integrationTests.stdlib.aivi.chronos.calendarFormatting.tests

use aivi
use aivi.prelude (toText)
use aivi.testing
use aivi.chronos.calendar

@test "date to text and format"
date_toText_and_format = {
  d = { year: 2024, month: 5, day: 21 }

  assertEq (toText d) "2024-05-21"
  assertEq "{d}" "2024-05-21"
  assertEq (d |> format "dd.MM.yyyy") "21.05.2024"
}

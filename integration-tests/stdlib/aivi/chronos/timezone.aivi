@no_prelude
module integrationTests.stdlib.aivi.chronos.timezone.tests

use aivi
use aivi.prelude (toText)
use aivi.testing
use aivi.chronos.timezone (getOffset, toInstant, atZone, format)

@test "timezone functional"
timezone_functional = do Effect {
  // Test basic timezone creation and offset
  utc   = ~tz(UTC)
  paris = ~tz(Europe/Paris)

  // Test ZonedDateTime creation
  // 2024-05-21T12:00:00 in Paris (CEST = UTC+2)
  // Should be 10:00:00 UTC
  zdt = ~zdt(2024-05-21T12:00:00[Europe/Paris])

  // Check fields
  assertEq zdt.zone.id "Europe/Paris"
  assertEq zdt.dateTime 2024-05-21T12:00:00Z
  assertEq (toText zdt) "2024-05-21T12:00:00+02:00[Europe/Paris]"
  assertEq (zdt |> format "dd.MM.yyyy HH:mm XXX VV") "21.05.2024 12:00 +02:00 Europe/Paris"

  // Check offset (CEST is +2 hours = 7200000ms)
  assertEq zdt.offset.millis 7200000

  // Test toInstant (should be UTC timestamp)
  // 2024-05-21T10:00:00Z
  ts = toInstant zdt
  assertEq ts 2024-05-21T10:00:00Z

  // Test getOffset
  offset = getOffset paris ts
  assertEq offset.millis 7200000

  // Test atZone conversion
  // Convert Paris time (12:00 CEST) to Tokyo (JST = UTC+9)
  // 10:00 UTC + 9 hours = 19:00 JST
  tokyo    = ~tz(Asia/Tokyo)
  zdtTokyo = atZone zdt tokyo

  assertEq zdtTokyo.zone.id "Asia/Tokyo"
  assertEq zdtTokyo.dateTime 2024-05-21T19:00:00Z
  assertEq zdtTokyo.offset.millis 32400000 // 9 * 3600 * 1000

  // Verify instant is preserved
  tsTokyo = toInstant zdtTokyo
  assertEq ts tsTokyo
}

@test "timezone preserves fractional seconds across conversions"
timezone_preserves_fractional_seconds = do Effect {
  paris = ~tz(Europe/Paris)
  tokyo = ~tz(Asia/Tokyo)
  zdt   = ~zdt(2024-05-21T12:00:00.123456789[Europe/Paris])

  assertEq zdt.dateTime 2024-05-21T12:00:00.123456789Z

  ts = toInstant zdt
  assertEq ts 2024-05-21T10:00:00.123456789Z
  assertEq (getOffset paris ts).millis 7200000

  tokyoView = atZone zdt tokyo
  assertEq tokyoView.dateTime 2024-05-21T19:00:00.123456789Z
  assertEq tokyoView.offset.millis 32400000
  assertEq (toInstant tokyoView) ts
}

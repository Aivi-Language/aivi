@no_prelude
module integrationTests.stdlib.aivi.console.interactive.readLine.tests

use aivi
use aivi.testing
use aivi.console (readLine)

@test "read line"
readLine_functional = readLine
  |> result => result match
    | Ok line => assert (text.length line >= 0)
    | Err err => assert (text.length err > 0)

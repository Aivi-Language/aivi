@no_prelude
module integrationTests.stdlib.aivi.console.tests

use aivi
use aivi.testing
use aivi.console (Blue, Red, Yellow, bgColor, color, error, log, print, println, strip, style)

@test "error"
error_functional = do Effect {
  result <- attempt (error "err")
  result match
    | Ok unit => assertEq unit Unit
    | Err _   => assert False
}

@test "log"
log_functional = do Effect {
  result <- attempt (log "log")
  result match
    | Ok unit => assertEq unit Unit
    | Err _   => assert False
}

@test "print"
print_functional = do Effect {
  result <- attempt (print "p")
  result match
    | Ok unit => assertEq unit Unit
    | Err _   => assert False
}

@test "println"
println_functional = do Effect {
  result <- attempt (println "pl")
  result match
    | Ok unit => assertEq unit Unit
    | Err _   => assert False
}

@test "color"
color_functional = do Effect {
  styled = color Red "warning"
  assert (styled != "warning")
  assert (text.contains styled "[31m")
  assertEq (strip styled) "warning"
}

@test "background color"
bgColor_functional = do Effect {
  styled = bgColor Blue "warning"
  assert (styled != "warning")
  assert (text.contains styled "[44m")
  assertEq (strip styled) "warning"
}

@test "style"
style_functional = do Effect {
  styled = style {
    fg: Some Yellow
    bg: Some Blue
    bold: True
    dim: False
    italic: True
    underline: True
    blink: False
    inverse: False
    hidden: False
    strike: True
  } "status"
  assert (text.contains styled "[33;44;1;3;4;9m")
  assertEq (strip styled) "status"
}

@test "strip"
strip_functional = do Effect {
  styled = color Red "plain"
  assertEq (strip styled) "plain"
}

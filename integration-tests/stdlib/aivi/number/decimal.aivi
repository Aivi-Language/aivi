@no_prelude
module integrationTests.stdlib.aivi.number.decimal.tests

use aivi
use aivi.testing
use aivi.math (abs)
use aivi.number.decimal

@test "decimal helpers and domain arithmetic"
decimal_helpers_and_domain_arithmetic = {
  value    = fromFloat 3.14159
  rounded  = round value 2
  total    = fromFloat 1.25 + fromFloat 2.75
  quotient = total / fromFloat 2.0

  assert (abs (toFloat rounded - 3.14) < 0.01)
  assert (abs (toFloat total - 4.0) < 0.01)
  assert (abs (toFloat quotient - 2.0) < 0.01)
}

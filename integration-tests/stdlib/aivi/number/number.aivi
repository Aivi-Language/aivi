@no_prelude
module integrationTests.stdlib.aivi.number.tests

use aivi
use aivi.testing
use aivi.number
use aivi.number (
  bigint (domain BigInt)
  rational (fromBigInts)
)
use aivi.number.decimal as dec
use aivi.math

// -- Decimal --

@test "decimal from float"
decimal_fromFloat = do Effect {
  d = fromFloat 3.14
  f = toFloat d
  assert (abs (f - 3.14) < 0.01)
}

@test "decimal round"
decimal_round = do Effect {
  d = fromFloat 3.14159
  r = dec.round d 2
  f = toFloat r
  assert (abs (f - 3.14) < 0.01)
}

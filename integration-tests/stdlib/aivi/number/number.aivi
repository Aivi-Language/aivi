@no_prelude
module integrationTests.stdlib.aivi.number.tests

use aivi
use aivi.testing
use aivi (
  math (abs)
)
use aivi.number as num

@test "number facade decimal helpers"
number_facade_decimal_helpers = {
  value   = num.fromFloat 3.14159
  rounded = num.round value 2
  output  = num.toFloat rounded

  assert (abs (output - 3.14) < 0.01)
}

@test "number facade bigint roundtrip"
number_facade_bigint_roundtrip = {
  assertEq (num.toInt (num.fromInt 42)) (Some 42)
}

@test "number facade rational helpers"
number_facade_rational_helpers = {
  value = num.normalize (num.fromBigInts (num.fromInt 6) (num.fromInt 8))

  assertEq (num.toInt (num.numerator value)) (Some 3)
  assertEq (num.toInt (num.denominator value)) (Some 4)
}

@test "number facade complex constant"
number_facade_complex_constant = {
  assertEq num.i { re: 0.0, im: 1.0 }
}

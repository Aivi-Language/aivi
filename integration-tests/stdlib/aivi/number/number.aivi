@no_prelude
module integrationTests.stdlib.aivi.number.tests

use aivi
use aivi.testing
use aivi.math
use aivi.number.bigint
use aivi.number.decimal as dec

// -- Decimal --

@test "decimal from float"
decimal_fromFloat = do Effect {
  d = dec.fromFloat 3.14
  f = dec.toFloat d
  assert (abs (f - 3.14) < 0.01)
}

@test "decimal round"
decimal_round = do Effect {
  d = dec.fromFloat 3.14159
  r = dec.round d 2
  f = dec.toFloat r
  assert (abs (f - 3.14) < 0.01)
}

// -- BigInt --

@test "bigint arithmetic and overflow"
bigint_arithmetic_and_overflow = do Effect {
  seven  = fromInt 7
  eight  = fromInt 8
  offset = fromInt (absInt (-14))
  exact  = seven * eight - offset

  seed = fromInt 1000000
  one  = fromInt 1
  huge = seed * seed * seed * seed + one

  assertEq (toInt exact) (Some 42)
  assertEq (toInt huge) None
}

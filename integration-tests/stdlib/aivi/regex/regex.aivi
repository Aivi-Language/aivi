@no_prelude
module integrationTests.stdlib.aivi.regex.tests

use aivi
use aivi.testing
use aivi.regex

@test "compile valid"
compile_valid = {
  res = compile "^hello"
  res match
    | Ok r  => assert (test r "hello")
    | Err _ => assert False
}

@test "compile invalid"
compile_invalid = {
  res = compile "[invalid"
  res match
    | Ok _                     => assert False
    | Err (InvalidPattern msg) => assert (!(msg == ""))
}

@test "test match"
test_match = assertOk (compile "\\d+")
  |> r => {
       assert (test r "abc123def")
       assert (test r "42")
       assert (!(test r "no digits"))
     }

@test "test no match"
test_no_match = assertOk (compile "^hello$")
  |> r => {
       assert (test r "hello")
       assert (!(test r "say hello"))
     }

@test "match first"
match_first = assertOk (compile "\\d+")
  |> r => {
       m = match r "abc 123 def 456"
       m match
         | Some first => {
             assertEq first.full "123"
             assertEq first.start 4
             assertEq first.end 7
           }
         | None => assert False
     }

@test "matches all"
matches_all = assertOk (compile "\\d+")
  |> r => {
       ms = matches r "a1b2c3"
       assert (List.length ms == 3)
     }

@test "split"
split_functional = assertOk (compile "[,;]")
  |> r => {
       parts = split r "a,b;c,d"
       assert (List.length parts == 4)
     }

@test "replace"
replace_functional = assertOk (compile "\\d+")
  |> r => {
       result = replace r "abc123def456" "NUM"
       assert (result == "abcNUMdef456")
     }

@test "replace all"
replaceAll_functional = assertOk (compile "\\d+")
  |> r => {
       result = replaceAll r "abc123def456" "NUM"
       assert (result == "abcNUMdefNUM")
     }

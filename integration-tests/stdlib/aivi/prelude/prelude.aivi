@no_prelude
module integrationTests.stdlib.aivi.prelude.tests

use aivi.prelude
use aivi.testing

@test "bool"
bool_functional = {
  assert (True && True)
  assert (True || False)
  assert (False || True)
  assert (!False)
  assert (!(True && False))
  assert (True != False)
  assert (True == True)
}

@test "float"
float_functional = {
  assert (1.0 + 2.0 == 3.0)
  assert (2.0 * 3.0 == 6.0)
  assert (4.0 / 2.0 == 2.0)
  assert (1.0 < 2.0)
  assert (2.0 > 1.0)
  assert (1.0 <= 1.0)
  assert (1.0 >= 1.0)
}

@test "int"
int_functional = {
  assertEq (1 + 2) 3
  assertEq (2 * 3) 6
  assertEq (4 / 2) 2
  assert (1 < 2)
  assert (2 > 1)
  assert (1 <= 1)
  assert (1 >= 1)
  minInt = a b => if a < b then a else b
  maxInt = a b => if a > b then a else b
  assert (minInt 1 2 == 1)
  assert (maxInt 1 2 == 2)
}

len = xs => xs match
  | []           => 0
  | [_, ...rest] => 1 + len rest

map = f xs => xs match
  | []           => []
  | [x, ...rest] => [f x, ...(map f rest)]

@test "list"
list_functional = {
  l      = [1, 2, 3]
  mapped = map (x => x + 1) l
  assertEq (len l) 3
  assertEq mapped [2, 3, 4]
}

@test "option"
option_functional = {
  some = Some 1
  some match
    | Some n => assertEq n 1
    | None   => assert False

  none = None
  assertEq none None
}

@test "patch"
patch_functional = {
  user  = { name: "A", age: 30 }
  older = user <| { age: _ + 1 }
  assertEq older.age 31
}

@test "result"
result_functional = {
  ok = Ok 1
  ok match
    | Ok n  => assertEq n 1
    | Err _ => assert False

  err = Err "nope"
  err match
    | Ok _  => assert False
    | Err e => assertEq e "nope"
}

@test "prelude helpers"
prelude_helpers = {
  assertEq (not False) True
  assertEq (not True) False
  assertEq (any (n => n > 2) [1, 2, 3]) True
  assertEq (any (n => n > 5) [1, 2, 3]) False
}

@test "to text"
toText_functional = {
  assertEq (toText "abc") "abc"
  assertEq (toText 123) "123"
}

@test "tuple"
tuple_functional = {
  pair = (1, "two")
  assertEq pair (1, "two")
}

@test "to text 2"
toText_functional_2 = {
  assertEq (toText 0) "0"
}

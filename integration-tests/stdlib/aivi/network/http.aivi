@no_prelude
module integrationTests.stdlib.aivi.network.http.tests

use aivi
use aivi.testing
use aivi.net.http
use aivi.net.httpServer (Http, RawBytes)
use aivi (
  concurrency (sleep)
)
use aivi.json
use aivi.text as text

startServer = address => handler => do Effect {
  result <- attempt (httpServer.listen { address: address } handler)
  server <- assertOk result
  _      <- sleep 25
  pure server
}

stopServer = server => do Effect {
  result <- attempt (httpServer.stop server)
  _      <- assertOk result
  pure Unit
}

headerValue = name => headers => headers match
  | []                => None
  | [header, ...rest] =>
    if text.toLower header.name == text.toLower name
      then Some header.value
      else headerValue name rest

bytesTextReply = status => body => Http {
  status: status
  headers: [{ name: "Content-Type", value: "text/plain" }]
  body: RawBytes body
}

jsonBytesReply = status => body => Http {
  status: status
  headers: [{ name: "Content-Type", value: "application/json" }]
  body: RawBytes body
}

// -- Request construction --

@test "get performs request and exposes response"
getPerformsRequest = do Effect {
  handler = request => do Effect {
    matchesRequest = request.method == "GET" && request.path == "/echo?lang=aivi"
    pure (
      if matchesRequest
        then Http {
          status: 200
          headers: [{ name: "Content-Type", value: "text/plain" }]
          body: "ok"
        }
        else Http {
          status: 404
          headers: [{ name: "Content-Type", value: "text/plain" }]
          body: "bad"
        }
    )
  }

  server   <- startServer "127.0.0.1:39081" handler
  result   <- get ~u(http://127.0.0.1:39081/echo?lang=aivi)
  _        <- stopServer server
  response <- assertOk result
  _        <- assert_eq response.status 200
  _        <- assert_eq response.body "ok"
  assert_eq (headerValue "content-type" response.headers) (Some "text/plain")
}

@test "server response record coerces to json and adds application json header"
serverResponseRecordCoercesToJson = do Effect {
  handler = request => do Effect {
    matchesRequest = request.method == "GET" && (request.path == "/json-response" || request.path == "/json-response?")
    pure (
      if matchesRequest
        then Http {
          status: 200
          headers: []
          body: { name: "Ada", age: 42 }
        }
        else Http {
          status: 404
          headers: [{ name: "Content-Type", value: "text/plain" }]
          body: "bad"
        }
    )
  }

  server   <- startServer "127.0.0.1:39085" handler
  result   <- get ~u(http://127.0.0.1:39085/json-response)
  _        <- stopServer server
  response <- assertOk result
  _        <- assert_eq response.status 200
  _        <- assert_eq response.body "\{\"age\":42,\"name\":\"Ada\"}"
  assert_eq (headerValue "content-type" response.headers) (Some "application/json")
}

@test "post sends plain text body"
postSendsPlainTextBody = do Effect {
  handler = request => do Effect {
    matchesRequest = request.method == "POST" && (request.path == "/submit" || request.path == "/submit?")
    pure (
      if matchesRequest
        then bytesTextReply 200 request.body
        else bytesTextReply 405 [110, 111]
    )
  }

  server   <- startServer "127.0.0.1:39082" handler
  result   <- post ~u(http://127.0.0.1:39082/submit) "hello world"
  _        <- stopServer server
  response <- assertOk result
  _        <- assert_eq response.status 200
  assert_eq response.body "hello world"
}

@test "fetch json body adds application json header"
fetchJsonBodyAddsApplicationJsonHeader = do Effect {
  handler = request => do Effect {
    matchesRequest = request.method == "PATCH" && (request.path == "/json" || request.path == "/json?") && headerValue "content-type" request.headers == Some "application/json"
    pure (
      if matchesRequest
        then jsonBytesReply 200 request.body
        else bytesTextReply 400 [98, 97, 100]
    )
  }

  server <- startServer "127.0.0.1:39083" handler
  result <- fetch {
    method: "PATCH"
    url: ~u(http://127.0.0.1:39083/json)
    headers: []
    body: Some (Json (toJson { name: "Ada", age: 42 }))
  }
  _        <- stopServer server
  response <- assertOk result
  _        <- assert_eq response.status 200
  assert_eq response.body "\{\"age\":42,\"name\":\"Ada\"}"
}

@test "fetch form body percent encodes pairs"
fetchFormBodyPercentEncodesPairs = do Effect {
  handler = request => do Effect {
    matchesRequest = request.method == "POST" && (request.path == "/form" || request.path == "/form?") && headerValue "content-type" request.headers == Some "application/x-www-form-urlencoded"
    pure (
      if matchesRequest
        then bytesTextReply 200 request.body
        else bytesTextReply 400 [98, 97, 100]
    )
  }

  server <- startServer "127.0.0.1:39084" handler
  result <- fetch {
    method: "POST"
    url: ~u(http://127.0.0.1:39084/form)
    headers: [{ name: "Content-Type", value: "application/x-www-form-urlencoded" }]
    body: Some (
      Form [
        { name: "name", value: "Ada Lovelace" }
        { name: "city", value: "Paris" }
      ]
    )
  }
  _        <- stopServer server
  response <- assertOk result
  _        <- assert_eq response.status 200
  assert_eq response.body "name=Ada+Lovelace&city=Paris"
}

@no_prelude
module integrationTests.stdlib.aivi.network.http.tests

use aivi
use aivi.concurrency (sleep)
use aivi.testing
use aivi.net.http
use aivi.net.httpServer (Http, RawBytes)
use aivi.json
use aivi.text as text

startServer = address => handler =>
  attempt (httpServer.listen { address: address } handler)
  |> assertOk
  |> server => {
      sleep 25
      pure server
    }

stopServer = server =>
  attempt (httpServer.stop server)
|> assertOk

headerValue = name => headers => headers match
  | []                => None
  | [header, ...rest] =>
    if text.toLower header.name == text.toLower name
      then Some header.value
      else headerValue name rest

bytesTextReply = status => body => Http {
  status: status
  headers: [{ name: "Content-Type", value: "text/plain" }]
  body: RawBytes body
}

jsonBytesReply = status => body => Http {
  status: status
  headers: [{ name: "Content-Type", value: "application/json" }]
  body: RawBytes body
}

// -- Request construction --

@test "get performs request and exposes response"
getPerformsRequest = {
  handler = request => pure (
    if request.method == "GET" && request.path == "/echo?lang=aivi"
      then Http {
        status: 200
        headers: [{ name: "Content-Type", value: "text/plain" }]
        body: "ok"
      }
      else Http {
        status: 404
        headers: [{ name: "Content-Type", value: "text/plain" }]
        body: "bad"
      }
  )
  requestUrl = ~u(http://127.0.0.1:39081/echo?lang=aivi)

  handler
  |> runningHandler => startServer "127.0.0.1:39081" runningHandler@cleanup stopServer#server
  |> server => {
      get requestUrl
      |> assertOk
      |> response => {
          assert_eq response.status 200
          assert_eq response.body "ok"
          assert_eq (headerValue "content-type" response.headers) (Some "text/plain")
        }
    }
}

@test "server response record coerces to json and adds application json header"
serverResponseRecordCoercesToJson = {
  handler = request => pure (
    if request.method == "GET" && (request.path == "/json-response" || request.path == "/json-response?")
      then Http {
        status: 200
        headers: []
        body: { name: "Ada", age: 42 }
      }
      else Http {
        status: 404
        headers: [{ name: "Content-Type", value: "text/plain" }]
        body: "bad"
      }
  )
  requestUrl = ~u(http://127.0.0.1:39085/json-response)

  handler
  |> runningHandler => startServer "127.0.0.1:39085" runningHandler@cleanup stopServer#server
  |> server => {
      get requestUrl
      |> assertOk
      |> response => {
          assert_eq response.status 200
          assert_eq response.body "\{\"age\":42,\"name\":\"Ada\"}"
          assert_eq (headerValue "content-type" response.headers) (Some "application/json")
        }
    }
}

@test "post sends plain text body"
postSendsPlainTextBody = {
  handler = request => pure (
    if request.method == "POST" && (request.path == "/submit" || request.path == "/submit?")
      then bytesTextReply 200 request.body
      else bytesTextReply 405 [110, 111]
  )
  requestUrl = ~u(http://127.0.0.1:39082/submit)

  handler
  |> runningHandler => startServer "127.0.0.1:39082" runningHandler@cleanup stopServer#server
  |> server => {
      post requestUrl "hello world"
      |> assertOk
      |> response => {
          assert_eq response.status 200
          assert_eq response.body "hello world"
        }
    }
}

@test "fetch json body adds application json header"
fetchJsonBodyAddsApplicationJsonHeader = {
  handler = request => pure (
    if request.method == "PATCH" && (request.path == "/json" || request.path == "/json?") && headerValue "content-type" request.headers == Some "application/json"
      then jsonBytesReply 200 request.body
      else bytesTextReply 400 [98, 97, 100]
  )
  request = {
    method: "PATCH"
    url: ~u(http://127.0.0.1:39083/json)
    headers: []
    body: Some (Json (toJson { name: "Ada", age: 42 }))
  }

  handler
  |> runningHandler => startServer "127.0.0.1:39083" runningHandler@cleanup stopServer#server
  |> server => {
      fetch request
      |> assertOk
      |> response => {
          assert_eq response.status 200
          assert_eq response.body "\{\"age\":42,\"name\":\"Ada\"}"
        }
    }
}

@test "fetch form body percent encodes pairs"
fetchFormBodyPercentEncodesPairs = {
  handler = request => pure (
    if request.method == "POST" && (request.path == "/form" || request.path == "/form?") && headerValue "content-type" request.headers == Some "application/x-www-form-urlencoded"
      then bytesTextReply 200 request.body
      else bytesTextReply 400 [98, 97, 100]
  )
  request = {
    method: "POST"
    url: ~u(http://127.0.0.1:39084/form)
    headers: [{ name: "Content-Type", value: "application/x-www-form-urlencoded" }]
    body: Some (
      Form [
        { name: "name", value: "Ada Lovelace" }
        { name: "city", value: "Paris" }
      ]
    )
  }

  handler
  |> runningHandler => startServer "127.0.0.1:39084" runningHandler@cleanup stopServer#server
  |> server => {
      fetch request
      |> assertOk
      |> response => {
          assert_eq response.status 200
          assert_eq response.body "name=Ada+Lovelace&city=Paris"
        }
    }
}

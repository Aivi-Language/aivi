@no_prelude
module integrationTests.stdlib.aivi.network.http_server.tests

use aivi
use aivi.testing
use aivi.net.httpServer
use aivi.net.http (get, post)
use aivi.concurrency
use aivi.system (env)
use aivi.text as text
use aivi.url (parse)

parseEnvPort : Text -> (Int -> Effect Text Unit) -> Effect Text Unit
parseEnvPort = raw => run => (
  raw
  |> text.parseInt#parsed
  |> _ => parsed match
    | Some port => run port
    | None      => pure Unit
)

withEnvPort : Text -> (Int -> Effect Text Unit) -> Effect Text Unit
withEnvPort = key => run => (
  Unit
  |> _ => attempt (env.get key)#envResult
  |> _ => envResult match
    | Err _  => pure Unit
    | Ok raw => parseEnvPort raw run
)

addressAt = port => text.concat ["127.0.0.1:", text.debugText port]

urlAt = port => path => (
  text.concat ["http://", addressAt port, path]
  |> parse
  |> assertOk
)

isEchoPost = request =>
  request.method == "POST"
  && request.path == "/echo"
  && request.body == [99, 108, 105, 101, 110, 116, 45, 98, 111, 100, 121]
  && (request.remoteAddr match
    | Some _ => True
    | None   => False
  )

httpHandler = request => pure (
  if isEchoPost request
    then Http {
      status: 200
      headers: [{ name: "Content-Type", value: "text/plain" }]
      body: [111, 107]
    }
    else Http {
      status: 400
      headers: [{ name: "Content-Type", value: "text/plain" }]
      body: [98, 97, 100]
    }
)

startServer : Text -> (Request -> Effect HttpError ServerReply) -> Effect Text Server
startServer = address => handler => (
  attempt (listen { address: address } handler)
   |> assertOk#server
  ~|>_ => sleep 25
   |> _ => pure server
)

stopServer : Server -> Effect Text Unit
stopServer = server => (
  attempt (stop server)
  |> assertOk
)

wsEcho = socket => (
  socket
  |> wsRecv#message
  |> _ => wsSend socket message
  |> _ => wsClose socket
)

wsHandler = request =>
  if request.path == "/ws" || request.path == "/ws?" then pure (Ws wsEcho)
  else pure (Http { status: 404, headers: [], body: RawBytes [] })

listenResourceRoundTrip = port => requestUrl => (
  Unit
  |> _ => startServer (addressAt port) httpHandler@cleanup stopServer#server
  |> _ => post requestUrl "client-body"#responseResult
  |> _ => pure { responseResult: responseResult }
)

websocketRoundTrip = port => (
  Unit
   |> _ => startServer (addressAt port) wsHandler#server
  ~|>_ => sleep 500
  ~|>_ => stopServer server
   |> _ => pure Unit
)

listenAndStopHandleHttpRequestsCase = port => (
  Unit
   |> _ => urlAt port "/echo"#requestUrl
   |> _ => startServer (addressAt port) httpHandler#server
   |> _ => post requestUrl "client-body"#responseResult
  ~|>_ => stopServer server
   |> _ => get requestUrl#stoppedResult
   |> _ => assertOk responseResult#response
  ~|>response => assert_eq response.status 200
  ~|>response => assert_eq response.body "ok"
  ~|>_ => assertErr stoppedResult
   |> _ => pure Unit
)

listenResourceCleanupStopsTheHttpServerOnScopeExitCase = port => (
  Unit
   |> _ => urlAt port "/echo"#requestUrl
   |> _ => listenResourceRoundTrip port requestUrl#workflow
   |> _ => assertOk workflow.responseResult#response
  ~|>response => assert_eq response.status 200
  ~|>response => assert_eq response.body "ok"
   |> _ => get requestUrl#stoppedResult
  ~|>_ => assertErr stoppedResult
   |> _ => pure Unit
)

assertHttpReply = reply => expectedStatus => expectedBody => (
  reply match
    | Http response =>
        Unit
        ~|>_ => assert_eq response.status expectedStatus
         |> _ => assert_eq response.body expectedBody
    | _ => assert False
)

@test "listen and stop handle a real http request"
listen_and_stop_handle_http_requests = withEnvPort "AIVI_TEST_HTTP_SERVER_PORT" listenAndStopHandleHttpRequestsCase

@test "listen resource cleanup stops the http server on scope exit"
listen_resource_cleanup_stops_the_http_server_on_scope_exit = withEnvPort "AIVI_TEST_HTTP_SERVER_PORT" listenResourceCleanupStopsTheHttpServerOnScopeExitCase

@test "websocket receive send and close echo a real client message"
websocket_receive_send_and_close_echo = withEnvPort "AIVI_TEST_HTTP_WS_PORT" websocketRoundTrip

@test "server config"
server_config = {
  cfg = { address: "127.0.0.1:0" }

  Unit
  ~|>_ => assert_eq cfg.address "127.0.0.1:0"
}

@test "request fields"
request_fields = {
  req = {
    method: "GET"
    path: "/health"
    headers: []
    body: []
    remoteAddr: Some "127.0.0.1"
  }

  Unit
  ~|>_ => assert_eq req.method "GET"
  ~|>_ => assert_eq req.path "/health"
  ~|>_ => assert_eq req.remoteAddr (Some "127.0.0.1")
}

@test "response construction"
response_construction = {
  textReply = Http {
    status: 200
    headers: [{ name: "Content-Type", value: "text/plain" }]
    body: "Hello"
  }
  bytesReply = Http {
    status: 200
    headers: [{ name: "Content-Type", value: "text/plain" }]
    body: [72, 101, 108, 108, 111]
  }
  jsonReply = Http {
    status: 200
    headers: []
    body: { message: "hi" }
  }

  Unit
  ~|>_ => assertHttpReply textReply 200 (Plain "Hello")
  ~|>_ => assertHttpReply bytesReply 200 (RawBytes [72, 101, 108, 108, 111])
  ~|>_ => assertHttpReply jsonReply 200 (Json (toJson { message: "hi" }))
}

@test "ws message variants"
ws_message_variants = {
  textMsg   = TextMsg "hello ws"
  binaryMsg = BinaryMsg [1, 2, 3]

  Unit
  ~|>_ => (
    textMsg match
      | TextMsg text => assert_eq text "hello ws"
      | _            => assert False
  )
  ~|>_ => (
    binaryMsg match
      | BinaryMsg bytes => assert_eq (List.length bytes) 3
      | _               => assert False
  )
  ~|>_ => assert_eq Ping Ping
  ~|>_ => assert_eq Pong Pong
  ~|>_ => assert_eq Close Close
}

@test "server reply http variant"
server_reply_http = {
  reply = Http { status: 404, headers: [], body: RawBytes [] }

  reply match
    | Http response => assert_eq response.status 404
    | _             => assert False
}

@test "http and ws error fields"
http_and_ws_error_fields = {
  httpErr = { message: "internal server error" }
  wsErr   = { message: "connection closed" }

  Unit
  ~|>_ => assert_eq httpErr.message "internal server error"
  ~|>_ => assert_eq wsErr.message "connection closed"
}

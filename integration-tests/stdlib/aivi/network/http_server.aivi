@no_prelude
module integrationTests.stdlib.aivi.network.http_server.tests

use aivi
use aivi.testing
use aivi.net.httpServer
use aivi.net.http (get, post)
use aivi.concurrency
use aivi.system (env)
use aivi.text as text
use aivi.url (parse)

withEnvPort = key run => do Effect {
  portResult <- attempt (load (env.get key))
  portResult match
    | Err _     => pure Unit
    | Ok raw    => text.parseInt raw match
      | Some port => run port
      | None      => pure Unit
}

addressAt = port => text.concat ["127.0.0.1:", text.debugText port]

urlAt = port path => assertOk (parse (text.concat ["http://", addressAt port, path]))

isEchoPost = request =>
  request.method == "POST"
  && request.path == "/echo"
  && request.body == [99, 108, 105, 101, 110, 116, 45, 98, 111, 100, 121]
  && (request.remoteAddr match
    | Some _ => True
    | None   => False
  )

httpHandler = request => pure (
  if isEchoPost request
    then Http {
      status: 200
      headers: [{ name: "Content-Type", value: "text/plain" }]
      body: [111, 107]
    }
    else Http {
      status: 400
      headers: [{ name: "Content-Type", value: "text/plain" }]
      body: [98, 97, 100]
    }
)

wsEcho = tx => socket => do Effect {
  message <- wsRecv socket
  message match
    | TextMsg text => do Effect {
        _ <- wsSend socket (TextMsg text)
        _ <- send tx text
        wsClose socket
      }
    | _ => do Effect {
        _ <- send tx "unexpected"
        wsClose socket
      }
}

wsHandler = tx => request =>
  if request.path == "/ws" then pure (Ws (wsEcho tx))
  else pure (Http { status: 404, headers: [], body: RawBytes [] })

@test "listen and stop handle a real http request"
listen_and_stop_handle_http_requests = withEnvPort "AIVI_TEST_HTTP_SERVER_PORT" (port => do Effect {
    requestUrl     <- urlAt port "/echo"
    workflowResult <- attempt (do Effect {
        server         <- listen { address: addressAt port } httpHandler
        responseResult <- attempt (post requestUrl "client-body")
        _              <- stop server
        stoppedResult  <- attempt (get requestUrl)
        pure { responseResult: responseResult, stoppedResult: stoppedResult }
    })
    workflow        <- assertOk workflowResult
    responseResult  <- assertOk workflow.responseResult
    response        <- assertOk responseResult
    _               <- assert_eq response.status 200
    _               <- assert_eq response.body "ok"
    stoppedResponse <- assertOk workflow.stoppedResult
    _               <- assertErr stoppedResponse
    pure Unit
})

@test "listen resource cleanup stops the http server on scope exit"
listen_resource_cleanup_stops_the_http_server_on_scope_exit = withEnvPort "AIVI_TEST_HTTP_SERVER_PORT" (port => do Effect {
    requestUrl     <- urlAt port "/echo"
    workflowResult <- attempt (do Effect {
        _              <- listen { address: addressAt port } httpHandler
        responseResult <- attempt (post requestUrl "client-body")
        pure { responseResult: responseResult }
    })
    workflow        <- assertOk workflowResult
    responseResult  <- assertOk workflow.responseResult
    response        <- assertOk responseResult
    _               <- assert_eq response.status 200
    _               <- assert_eq response.body "ok"
    stoppedResult   <- attempt (get requestUrl)
    stoppedResponse <- assertOk stoppedResult
    _               <- assertErr stoppedResponse
    pure Unit
})

@test "websocket receive send and close echo a real client message"
websocket_receive_send_and_close_echo = withEnvPort "AIVI_TEST_HTTP_WS_PORT" (port => do Effect {
    wsResult <- attempt (do Effect {
        (tx, rx) <- make ""
        server   <- listen { address: addressAt port } (wsHandler tx)
        result   <- attempt (timeoutWith 10000 "missing websocket message" (recv rx))
        _        <- close tx
        _        <- stop server
        pure result
    })
    received <- assertOk wsResult
    result   <- assertOk received
    result match
      | Ok value => assert_eq value "hello websocket"
      | Err _    => assert False
})

@test "server config"
server_config = do Effect {
  cfg = { address: "127.0.0.1:0" }
  assert_eq cfg.address "127.0.0.1:0"
}

@test "request fields"
request_fields = do Effect {
  req = {
    method: "GET"
    path: "/health"
    headers: []
    body: []
    remoteAddr: Some "127.0.0.1"
  }
  _ <- assert_eq req.method "GET"
  _ <- assert_eq req.path "/health"
  assert_eq req.remoteAddr (Some "127.0.0.1")
}

@test "response construction"
response_construction = do Effect {
  textReply = Http {
    status: 200
    headers: [{ name: "Content-Type", value: "text/plain" }]
    body: "Hello"
  }
  bytesReply = Http {
    status: 200
    headers: [{ name: "Content-Type", value: "text/plain" }]
    body: [72, 101, 108, 108, 111]
  }
  jsonReply = Http {
    status: 200
    headers: []
    body: { message: "hi" }
  }
  _ <- (textReply match
    | Http response => do Effect {
        _ <- assert_eq response.status 200
        assert_eq response.body (Plain "Hello")
      }
    | _ => assert False
  )
  _ <- (bytesReply match
    | Http response => assert_eq response.body (RawBytes [72, 101, 108, 108, 111])
    | _             => assert False
  )
  jsonReply match
    | Http response => assert_eq response.body (Json (toJson { message: "hi" }))
    | _             => assert False
}

@test "ws message variants"
ws_message_variants = do Effect {
  textMsg   = TextMsg "hello ws"
  binaryMsg = BinaryMsg [1, 2, 3]
  _ <- (textMsg match
    | TextMsg text => assert_eq text "hello ws"
    | _            => assert False
  )
  _ <- (binaryMsg match
    | BinaryMsg bytes => assert_eq (List.length bytes) 3
    | _               => assert False
  )
  _ <- assert_eq Ping Ping
  _ <- assert_eq Pong Pong
  assert_eq Close Close
}

@test "server reply http variant"
server_reply_http = do Effect {
  reply = Http { status: 404, headers: [], body: RawBytes [] }
  reply match
    | Http response => assert_eq response.status 404
    | _             => assert False
}

@test "http and ws error fields"
http_and_ws_error_fields = do Effect {
  httpErr = { message: "internal server error" }
  wsErr   = { message: "connection closed" }
  _ <- assert_eq httpErr.message "internal server error"
  assert_eq wsErr.message "connection closed"
}

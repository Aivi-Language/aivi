@no_prelude
module integrationTests.stdlib.aivi.network.httpJsonBody.tests

use aivi
use aivi.testing
use aivi.net.http
use aivi.json
use aivi.url (parse)

expectUrl = raw =>
  parse raw
|> assertOk

@test "Json body variant construction"
jsonBodyVariant = "https://example.com/token"
  |> expectUrl#reqUrl
  |> _ => pure {
    method: "POST"
    url: reqUrl
    headers: []
    body: Some (Json (toJson { grant_type: "authorization_code", code: "abc123" }))
  }#req
  ~|>_ => assertEq req.method "POST"
   |> _ => req.body
  ||>Some (Json _) => assert True
  ||>_ => assert False

@test "record literal coerces to Body"
recordCoercesToBody = "https://example.com/token"
  |> expectUrl#reqUrl
  |> _ => pure {
    method: "POST"
    url: reqUrl
    headers: []
    body: Some (Json (toJson { grant_type: "authorization_code", code: "abc123" }))
  }#req
   |> _ => req.body
  ||>Some (Json _) => assert True
  ||>_ => assert False

@test "text coerces to Body via Plain"
textCoercesToBody = "https://example.com/token"
  |> expectUrl#reqUrl
  |> _ => pure {
    method: "POST"
    url: reqUrl
    headers: []
    body: Some (Plain "hello world")
  }#req
   |> _ => req.body
  ||>Some (Plain t) => assertEq t "hello world"
  ||>_ => assert False

@test "toJson encodes record to JsonObject"
toJsonRecord = toJson { name: "Alice", age: 30 }
||>JsonObject _ => assert True
||>_ => assert False

@test "toJson encodes text to JsonString"
toJsonText = toJson "hello"
  |> assertEq (JsonString "hello")

@test "toJson encodes int to JsonInt"
toJsonInt = toJson 42
  |> assertEq (JsonInt 42)

@test "toJson encodes None to JsonNull"
toJsonNone = toJson None
  |> assertEq JsonNull

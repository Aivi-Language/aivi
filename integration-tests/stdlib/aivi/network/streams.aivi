@no_prelude
module integrationTests.stdlib.aivi.network.streams.tests

use aivi
use aivi.testing
use aivi.logic
use aivi.net.streams

// -- Type construction --

@test "stream error fields"
streamErrorFields = {
  err = { message: "stream closed unexpectedly" }

  Unit
  ~|>_ => assertEq err.message "stream closed unexpectedly"
}

@test "stream error empty message"
streamErrorEmpty = {
  err = { message: "" }

  Unit
  ~|>_ => assertEq err.message ""
}

// -- fromList / fold --

@test "fold sums a list stream"
foldSum = streams.fromList [1, 2, 3, 4, 5]
  |> streams.fold (acc x => acc + x) 0
  |> assertEq 15

@test "fold empty stream returns seed"
foldEmpty = streams.fromList []
  |> streams.fold (acc x => acc + x) 42
  |> assertEq 42

@test "fold collects items into list"
foldCollect = streams.fromList [10, 20, 30]
  |> streams.fold (acc x => [...acc, x]) []
  |> assertEq [10, 20, 30]

// -- map --

@test "map doubles each element"
mapDouble = streams.fromList [1, 2, 3]
  |> streams.map (x => x * 2)
  |> streams.fold (acc x => [...acc, x]) []
  |> assertEq [2, 4, 6]

@test "map over empty stream"
mapEmpty = streams.fromList []
  |> streams.map (x => x + 1)
  |> streams.fold (acc x => [...acc, x]) []
  |> assertEq []

// -- filter --

@test "filter keeps even numbers"
filterEvens = streams.fromList [1, 2, 3, 4, 5, 6]
  |> streams.filter (x => x % 2 == 0)
  |> streams.fold (acc x => [...acc, x]) []
  |> assertEq [2, 4, 6]

@test "filter removes all"
filterNone = streams.fromList [1, 3, 5]
  |> streams.filter (x => x % 2 == 0)
  |> streams.fold (acc x => [...acc, x]) []
  |> assertEq []

// -- take --

@test "take first n items"
takeN = streams.fromList [10, 20, 30, 40, 50]
  |> streams.take 3
  |> streams.fold (acc x => [...acc, x]) []
  |> assertEq [10, 20, 30]

@test "take zero yields empty"
takeZero = streams.fromList [1, 2, 3]
  |> streams.take 0
  |> streams.fold (acc x => [...acc, x]) []
  |> assertEq []

@test "take more than length yields all"
takeAll = streams.fromList [1, 2]
  |> streams.take 100
  |> streams.fold (acc x => [...acc, x]) []
  |> assertEq [1, 2]

// -- drop --

@test "drop first n items"
dropN = streams.fromList [10, 20, 30, 40, 50]
  |> streams.drop 2
  |> streams.fold (acc x => [...acc, x]) []
  |> assertEq [30, 40, 50]

@test "drop zero keeps all"
dropZero = streams.fromList [1, 2, 3]
  |> streams.drop 0
  |> streams.fold (acc x => [...acc, x]) []
  |> assertEq [1, 2, 3]

@test "drop more than length yields empty"
dropAll = streams.fromList [1, 2]
  |> streams.drop 100
  |> streams.fold (acc x => [...acc, x]) []
  |> assertEq []

// -- flatMap --

@test "flatMap expands each element"
flatMapExpand = streams.fromList [1, 2, 3]
  |> streams.flatMap (x => streams.fromList [x, x * 10])
  |> streams.fold (acc x => [...acc, x]) []
  |> assertEq [1, 10, 2, 20, 3, 30]

@test "flatMap with empty inner streams"
flatMapEmpty = streams.fromList [1, 2, 3]
  |> streams.flatMap (_ => streams.fromList [])
  |> streams.fold (acc x => [...acc, x]) []
  |> assertEq []

// -- merge --

@test "merge concatenates left then right"
mergeConcat = streams.merge (streams.fromList [1, 2, 3]) (streams.fromList [4, 5, 6])
  |> streams.fold (acc x => [...acc, x]) []
  |> assertEq [1, 2, 3, 4, 5, 6]

@test "merge with empty left"
mergeEmptyLeft = streams.merge (streams.fromList []) (streams.fromList [7, 8])
  |> streams.fold (acc x => [...acc, x]) []
  |> assertEq [7, 8]

// -- combinator composition --

@test "map then filter"
mapThenFilter = streams.fromList [1, 2, 3, 4, 5]
  |> streams.map (x => x * 3)
  |> streams.filter (x => x > 6)
  |> streams.fold (acc x => [...acc, x]) []
  |> assertEq [9, 12, 15]

@test "take after drop"
takeAfterDrop = streams.fromList [1, 2, 3, 4, 5]
  |> streams.drop 1
  |> streams.take 3
  |> streams.fold (acc x => [...acc, x]) []
  |> assertEq [2, 3, 4]

// -- HKT class instances --

@test "Functor map via class dispatch"
functorMap = streams.fromList [10, 20, 30]
  |> map (x => x + 1)
  |> streams.fold (acc x => [...acc, x]) []
  |> assertEq [11, 21, 31]

@test "Filterable filter via class dispatch"
filterableFilter = streams.fromList [1, 2, 3, 4, 5, 6]
  |> filter (x => x > 3)
  |> streams.fold (acc x => [...acc, x]) []
  |> assertEq [4, 5, 6]

@test "Functor then Filterable via class dispatch"
functorThenFilterable = streams.fromList [1, 2, 3, 4, 5]
  |> map (x => x * 2)
  |> filter (x => x > 4)
  |> streams.fold (acc x => [...acc, x]) []
  |> assertEq [6, 8, 10]

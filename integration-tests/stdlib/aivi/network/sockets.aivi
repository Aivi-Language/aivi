@no_prelude
module integrationTests.stdlib.aivi.network.sockets.tests

use aivi
use aivi.testing
use aivi.net.sockets
use aivi (
  system (env)
  text (parseInt)
)

withEnvPort = key run => do Effect {
  portResult <- attempt (env.get key)
  portResult match
    | Err _     => pure Unit
    | Ok raw    => parseInt raw match
      | Some port => run port
      | None      => pure Unit
}

@test "connect send recv close exercises a real socket roundtrip"
connect_send_recv_close_roundtrip = withEnvPort "AIVI_TEST_SOCKET_SERVER_PORT" (port => do Effect {
    roundtrip <- attempt (do Effect {
        conn      <- connect { host: "127.0.0.1", port: port }
        _         <- send conn [112, 105, 110, 103]
        first     <- recv conn
        second    <- recv conn
        _         <- close conn
        pure { first: first, second: second }
    })
    payload <- assertOk roundtrip
    _       <- assertEq payload.first [112, 111, 110, 103]
    assertEq payload.second []
})

@test "listen accept recv send close exercises a real socket roundtrip"
listen_accept_recv_send_close_roundtrip = withEnvPort "AIVI_TEST_SOCKET_LISTEN_PORT" (port => do Effect {
    requestResult <- attempt (do Effect {
        listener      <- listen { host: "127.0.0.1", port: port }
        conn          <- accept listener
        request       <- recv conn
        _             <- send conn [119, 111, 114, 108, 100]
        _             <- close conn
        pure request
    })
    request <- assertOk requestResult
    assertEq request [104, 101, 108, 108, 111]
})

@test "connect rejects an out of range port as SocketError"
connect_rejects_out_of_range_port_as_socket_error = do Effect {
  result <- attempt (connect { host: "127.0.0.1", port: 70000 })
  result match
    | Err err => assertEq err.message "Address.port must be in 0..65535"
    | Ok _    => assert False
}

@test "listen rejects an out of range port as SocketError"
listen_rejects_out_of_range_port_as_socket_error = do Effect {
  result <- attempt (do Effect {
      _      <- listen { host: "127.0.0.1", port: 70000 }
      pure Unit
  })
  result match
    | Err err => assertEq err.message "Address.port must be in 0..65535"
    | Ok _    => assert False
}

@test "send rejects out of range bytes as SocketError"
send_rejects_out_of_range_bytes_as_socket_error = withEnvPort "AIVI_TEST_SOCKET_INVALID_SEND_PORT" (port => do Effect {
    workflow   <- attempt (do Effect {
        conn       <- connect { host: "127.0.0.1", port: port }
        sendResult <- attempt (send conn [256])
        _          <- close conn
        pure sendResult
    })
    result <- assertOk workflow
    result match
      | Err err => assertEq err.message "byte value must be in 0..255"
      | Ok _    => assert False
})

@test "socket error fields"
socket_error_fields = do Effect {
  err = { message: "connection refused" }
  assertEq err.message "connection refused"
}

@test "address fields"
address_fields = do Effect {
  addr = { host: "127.0.0.1", port: 8080 }
  _ <- assertEq addr.host "127.0.0.1"
  assertEq addr.port 8080
}

@test "address zero port"
address_zero_port = do Effect {
  addr = { host: "0.0.0.0", port: 0 }
  assertEq addr.port 0
  assertEq addr.host "0.0.0.0"
}

@test "address ipv6"
address_ipv6 = do Effect {
  addr = { host: "::1", port: 443 }
  assertEq addr.host "::1"
  assertEq addr.port 443
}

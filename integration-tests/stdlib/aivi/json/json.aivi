@no_prelude
module integrationTests.stdlib.aivi.json.tests

use aivi
use aivi.testing
use aivi.json

@test "strict fields"
strict_fields = {
  payload = encodeObject [
    ("id", encodeInt 1)
    ("name", encodeText "a")
  ]
  assertOk (strictFields ["id", "name"] payload)
   |> assertEq payload
}

@test "strict fields rejects unknown key"
strict_fields_reject_unknown_key = {
  payload = encodeObject [
    ("id", encodeInt 1)
    ("extra", encodeBool True)
  ]
  assertErr (strictFields ["id"] payload)
   |> .message
   |> assertEq "json.strictFields: unknown key"
}

@test "schema required fields"
schema_required_fields = {
  payload = encodeObject [("id", encodeInt 1)]
  schema  = { required: ["id", "name"], strict: True }
  issues  = validateSchema schema payload
  assertEq issues [{ path: "$.name", message: "missing required field" }]
}

@test "validate schema ignores strict flag"
validate_schema_ignores_strict_flag = {
  payload = encodeObject [
    ("id", encodeInt 1)
    ("extra", encodeBool True)
  ]
  schema = { required: ["id"], strict: True }
  issues = validateSchema schema payload
  assertEq issues []
}

@test "decode field missing"
decode_field_missing = {
  payload = encodeObject [("id", encodeInt 1)]
  assertErr (decodeField "name" payload)
   |> .message
   |> assertEq "missing field: name"
}

@test "decode list decodes items"
decode_list_decodes_items = {
  payload = encodeArray [encodeInt 1, encodeInt 2, encodeInt 3]
  assertOk (decodeList decodeInt payload)
   |> assertEq [1, 2, 3]
}

@test "decode list surfaces item errors"
decode_list_surfaces_item_errors = {
  payload = encodeArray [encodeInt 1, encodeText "oops"]
  assertErr (decodeList decodeInt payload)
   |> .message
   |> assertEq "expected Int"
}

@test "decode unavailable"
decode_unavailable = assertErr (decode "[]")
  |> .message
  |> assertEq "json.decode: native JSON parsing not yet available"

@test "migrate object"
migrate_object = {
  payload  = encodeObject [("name", encodeText "old")]
  migrated = migrateObject (entries => [("name", encodeText "new"), ...entries]) payload
  assertOk (decodeField "name" migrated)
   |> assertEq (encodeText "new")
}

@no_prelude
module integrationTests.stdlib.aivi.json.tests

use aivi
use aivi.testing
use aivi.json

@test "strict fields"
strict_fields = do Effect {
  payload = encodeObject [
    ("id", encodeInt 1)
    ("name", encodeText "a")
  ]
  value <- assertOk (strictFields ["id", "name"] payload)
  assertEq value payload
}

@test "strict fields rejects unknown key"
strict_fields_reject_unknown_key = do Effect {
  payload = encodeObject [
    ("id", encodeInt 1)
    ("extra", encodeBool True)
  ]
  err <- assertErr (strictFields ["id"] payload)
  assertEq err.message "json.strictFields: unknown key"
}

@test "schema required fields"
schema_required_fields = do Effect {
  payload = encodeObject [("id", encodeInt 1)]
  schema  = { required: ["id", "name"], strict: True }
  issues  = validateSchema schema payload
  assertEq issues [{ path: "$.name", message: "missing required field" }]
}

@test "validate schema ignores strict flag"
validate_schema_ignores_strict_flag = do Effect {
  payload = encodeObject [
    ("id", encodeInt 1)
    ("extra", encodeBool True)
  ]
  schema = { required: ["id"], strict: True }
  issues = validateSchema schema payload
  assertEq issues []
}

@test "decode field missing"
decode_field_missing = do Effect {
  payload = encodeObject [("id", encodeInt 1)]
  err <- assertErr (decodeField "name" payload)
  assertEq err.message "missing field: name"
}

@test "decode list decodes items"
decode_list_decodes_items = do Effect {
  payload = encodeArray [encodeInt 1, encodeInt 2, encodeInt 3]
  values <- assertOk (decodeList decodeInt payload)
  assertEq values [1, 2, 3]
}

@test "decode list surfaces item errors"
decode_list_surfaces_item_errors = do Effect {
  payload = encodeArray [encodeInt 1, encodeText "oops"]
  err <- assertErr (decodeList decodeInt payload)
  assertEq err.message "expected Int"
}

@test "decode unavailable"
decode_unavailable = do Effect {
  err <- assertErr (decode "[]")
  assertEq err.message "json.decode: native JSON parsing not yet available"
}

@test "migrate object"
migrate_object = do Effect {
  payload  = encodeObject [("name", encodeText "old")]
  migrated = migrateObject (entries => [("name", encodeText "new"), ...entries]) payload
  field <- assertOk (decodeField "name" migrated)
  assertEq field (encodeText "new")
}

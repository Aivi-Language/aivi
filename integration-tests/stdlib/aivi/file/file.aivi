@no_prelude
module integrationTests.stdlib.aivi.file.tests

use aivi
use aivi.testing
use aivi.file
use aivi.list as List
use aivi.text as text

roundtripPath = "target/aivi_stdlib_file_roundtrip.txt"
statPath      = "target/aivi_stdlib_file_stat.txt"
lifecyclePath = "target/aivi_stdlib_file_lifecycle.txt"
missingPath   = "target/aivi_stdlib_file_missing.txt"
resourcePath  = "target/aivi_stdlib_file_resource.txt"
jsonPath      = "target/aivi_stdlib_file_config.json"
csvPath       = "target/aivi_stdlib_file_users.csv"
imagePath     = "vscode/assets/aivi-64.png"

JsonConfig    = { host: Text, port: Int, enabled: Bool }
CsvUser       = { id: Int, name: Text, active: Bool }
ImageMetaInfo = { width: Int, height: Int, format: Text }
Pixel         = (Int, Int, Int)
PixelImage    = { width: Int, height: Int, format: Text, pixels: List (List Pixel) }

readConfig : Text -> Effect Text JsonConfig
readConfig = path => readJson path

readUsers : Text -> Effect Text (List CsvUser)
readUsers = path => readCsv path

readFixtureImageMeta : Text -> Effect Text ImageMetaInfo
readFixtureImageMeta = path => imageMeta path

readFixtureImage : Text -> Effect Text PixelImage
readFixtureImage = path => image path

cleanupPath = path => do Effect {
  present <- exists path
  if present
    then do Effect {
      deleteResult <- delete path
      _            <- assertOk deleteResult
      pure Unit
    }
    else pure Unit
}

@test "exists missing"
exists_missing = do Effect {
  _   <- cleanupPath missingPath
  res <- exists missingPath
  assert (res == False)
}

@test "write text read text roundtrip"
writeText_readText_roundtrip = do Effect {
  _             <- cleanupPath roundtripPath
  writeResult   <- writeText roundtripPath "hello aivi"
  _             <- assertOk writeResult
  contentResult <- readText roundtripPath
  content       <- assertOk contentResult
  assertEq content "hello aivi"
  deleteResult <- delete roundtripPath
  _            <- assertOk deleteResult
  existsAfter  <- exists roundtripPath
  assertEq existsAfter False
}

@test "stat reports written file"
stat_reports_written_file = do Effect {
  _           <- cleanupPath statPath
  writeResult <- writeText statPath "hello"
  _           <- assertOk writeResult
  statsResult <- stat statPath
  stats       <- assertOk statsResult
  assertEq stats.size 5
  assert stats.isFile
  assertEq stats.isDirectory False
  assert (stats.modified >= stats.created)
  _ <- cleanupPath statPath
}

@test "read text missing returns err"
readText_missing_returns_err = do Effect {
  _             <- cleanupPath missingPath
  contentResult <- readText missingPath
  err           <- assertErr contentResult
  assert (text.length err > 0)
}

@test "delete missing returns err"
delete_missing_returns_err = do Effect {
  _            <- cleanupPath missingPath
  deleteResult <- delete missingPath
  err          <- assertErr deleteResult
  assert (text.length err > 0)
}

@test "exists tracks lifecycle"
exists_tracks_lifecycle = do Effect {
  _      <- cleanupPath lifecyclePath
  before <- exists lifecyclePath
  assertEq before False
  writeResult <- writeText lifecyclePath "created"
  _           <- assertOk writeResult
  during      <- exists lifecyclePath
  assertEq during True
  deleteResult <- delete lifecyclePath
  _            <- assertOk deleteResult
  after        <- exists lifecyclePath
  assertEq after False
}

@test "open readAll close prevents further reads"
open_readAll_close_prevents_further_reads = do Effect {
  _              <- cleanupPath resourcePath
  writeResult    <- writeText resourcePath "hello from handle"
  _              <- assertOk writeResult
  handle         <- open resourcePath
  contentResult  <- readAll handle
  content        <- assertOk contentResult
  _              <- assertEq content "hello from handle"
  _              <- close handle
  readAfterClose <- readAll handle
  err            <- assertErr readAfterClose
  _              <- assert (text.length err > 0)
  _              <- cleanupPath resourcePath
  pure Unit
}

@test "open auto-closes when scope exits"
open_auto_closes_when_scope_exits = do Effect {
  _             <- cleanupPath resourcePath
  writeResult   <- writeText resourcePath "hello from scope"
  _             <- assertOk writeResult
  escapedHandle <- do Effect {
    handle        <- open resourcePath
    pure handle
  }
  readAfterScope <- readAll escapedHandle
  err            <- assertErr readAfterScope
  _              <- assert (text.length err > 0)
  _              <- cleanupPath resourcePath
  pure Unit
}

@test "readJson decodes typed record"
readJson_decodes_typed_record = do Effect {
  _           <- cleanupPath jsonPath
  writeResult <- writeText jsonPath "\{\"host\":\"localhost\",\"port\":8080,\"enabled\":true}"
  _           <- assertOk writeResult
  config      <- readConfig jsonPath
  _           <- assertEq config.host "localhost"
  _           <- assertEq config.port 8080
  _           <- assertEq config.enabled True
  _           <- cleanupPath jsonPath
  pure Unit
}

@test "readCsv decodes typed rows"
readCsv_decodes_typed_rows = do Effect {
  _           <- cleanupPath csvPath
  writeResult <- writeText csvPath "id,name,active\n1,Ada,true\n2,Lin,false\n"
  _           <- assertOk writeResult
  users       <- readUsers csvPath
  _           <- assertEq (List.length users) 2
  first       <- assertSome (List.at 0 users)
  second      <- assertSome (List.at 1 users)
  _           <- assertEq first.id 1
  _           <- assertEq first.name "Ada"
  _           <- assertEq first.active True
  _           <- assertEq second.id 2
  _           <- assertEq second.name "Lin"
  _           <- assertEq second.active False
  _           <- cleanupPath csvPath
  pure Unit
}

@test "imageMeta reads fixture metadata"
imageMeta_reads_fixture_metadata = do Effect {
  meta <- readFixtureImageMeta imagePath
  _    <- assertEq meta.width 64
  _    <- assertEq meta.height 64
  assertEq meta.format "Png"
}

@test "image reads fixture pixels"
image_reads_fixture_pixels = do Effect {
  img         <- readFixtureImage imagePath
  _           <- assertEq img.width 64
  _           <- assertEq img.height 64
  _           <- assertEq img.format "Rgb8"
  _           <- assertEq (List.length img.pixels) 64
  firstRow    <- assertSome (List.at 0 img.pixels)
  _           <- assertEq (List.length firstRow) 64
  sampleRow   <- assertSome (List.at 20 img.pixels)
  samplePixel <- assertSome (List.at 20 sampleRow)
  assertEq samplePixel (7, 129, 247)
}

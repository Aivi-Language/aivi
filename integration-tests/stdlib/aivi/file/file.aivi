@no_prelude
module integrationTests.stdlib.aivi.file.tests

use aivi
use aivi.testing
use aivi.file
use aivi.list as List
use aivi.text as text

roundtripPath = "target/aivi_stdlib_file_roundtrip.txt"
statPath      = "target/aivi_stdlib_file_stat.txt"
lifecyclePath = "target/aivi_stdlib_file_lifecycle.txt"
missingPath   = "target/aivi_stdlib_file_missing.txt"
resourcePath  = "target/aivi_stdlib_file_resource.txt"
jsonPath      = "target/aivi_stdlib_file_config.json"
csvPath       = "target/aivi_stdlib_file_users.csv"
imagePath     = "vscode/assets/aivi-64.png"

JsonConfig    = { host: Text, port: Int, enabled: Bool }
CsvUser       = { id: Int, name: Text, active: Bool }
ImageMetaInfo = { width: Int, height: Int, format: Text }
Pixel         = (Int, Int, Int)
PixelImage    = { width: Int, height: Int, format: Text, pixels: List (List Pixel) }

readConfig : Text -> Effect Text JsonConfig
readConfig = path => readJson path

readUsers : Text -> Effect Text (List CsvUser)
readUsers = path => readCsv path

readFixtureImageMeta : Text -> Effect Text ImageMetaInfo
readFixtureImageMeta = path => imageMeta path

readFixtureImage : Text -> Effect Text PixelImage
readFixtureImage = path => image path

cleanupPath = path =>
  exists path
  |> present =>
       if present then deleteOk path else pure Unit

writeTextOk = path => contents =>
  writeText path contents
  |> assertOk

deleteOk = path =>
  delete path
  |> assertOk

assertNonEmptyErr = result =>
  result
  |> assertErr
  |> err => assert (text.length err > 0)

escapeHandle = path =>
  path
  |> file.open @cleanup file.close #handle

@test "exists missing"
exists_missing = {
  cleanupPath missingPath
  exists missingPath
  |> assertEq False
}

@test "write text read text roundtrip"
writeText_readText_roundtrip = {
  path = roundtripPath

  cleanupPath path
  writeTextOk path "hello aivi"
  readText path
  |> assertOk
  |> content => {
      assertEq content "hello aivi"
      deleteOk path
      exists path
      |> assertEq False
    }
}

@test "stat reports written file"
stat_reports_written_file = {
  path = statPath

  cleanupPath path
  writeTextOk path "hello"
  stat path
  |> assertOk
  |> stats => {
      assertEq stats.size 5
      assert stats.isFile
      assertEq stats.isDirectory False
      assert (stats.modified >= stats.created)
      cleanupPath path
    }
}

@test "read text missing returns err"
readText_missing_returns_err = {
  cleanupPath missingPath
  readText missingPath
  |> assertNonEmptyErr
}

@test "delete missing returns err"
delete_missing_returns_err = {
  cleanupPath missingPath
  delete missingPath
  |> assertNonEmptyErr
}

@test "exists tracks lifecycle"
exists_tracks_lifecycle = {
  path = lifecyclePath

  cleanupPath path
  exists path
  |> assertEq False
  writeTextOk path "created"
  exists path
  |> assertEq True
  deleteOk path
  exists path
  |> assertEq False
}

@test "open readAll close prevents further reads"
open_readAll_close_prevents_further_reads = {
  path = resourcePath

  cleanupPath path
  writeTextOk path "hello from handle"
  open path
  |> handle => {
      readAll handle
      |> assertOk
      |> content => assertEq content "hello from handle"
      close handle
      readAll handle
      |> assertNonEmptyErr
      cleanupPath path
    }
}

@test "open auto-closes when scope exits"
open_auto_closes_when_scope_exits = {
  path = resourcePath

  cleanupPath path
  writeTextOk path "hello from scope"
  escapeHandle path
  |> escapedHandle => {
      readAll escapedHandle
      |> assertNonEmptyErr
      cleanupPath path
    }
}

@test "readJson decodes typed record"
readJson_decodes_typed_record = {
  path = jsonPath

  cleanupPath path
  writeTextOk path "\{\"host\":\"localhost\",\"port\":8080,\"enabled\":true}"
  readConfig path
  |> config => {
      assertEq config.host "localhost"
      assertEq config.port 8080
      assertEq config.enabled True
      cleanupPath path
    }
}

@test "readCsv decodes typed rows"
readCsv_decodes_typed_rows = {
  path = csvPath

  cleanupPath path
  writeTextOk path "id,name,active\n1,Ada,true\n2,Lin,false\n"
  readUsers path
  |> users => {
      assertEq (List.length users) 2
      List.at 0 users
      |> assertSome
      |> first => {
          assertEq first.id 1
          assertEq first.name "Ada"
          assertEq first.active True
        }
      List.at 1 users
      |> assertSome
      |> second => {
          assertEq second.id 2
          assertEq second.name "Lin"
          assertEq second.active False
          cleanupPath path
        }
    }
}

@test "imageMeta reads fixture metadata"
imageMeta_reads_fixture_metadata =
  readFixtureImageMeta imagePath
  |> meta => {
      assertEq meta.width 64
      assertEq meta.height 64
      assertEq meta.format "Png"
    }

@test "image reads fixture pixels"
image_reads_fixture_pixels =
  readFixtureImage imagePath
  |> img => {
      assertEq img.width 64
      assertEq img.height 64
      assertEq img.format "Rgb8"
      assertEq (List.length img.pixels) 64
      List.at 0 img.pixels
      |> assertSome
      |> firstRow => assertEq (List.length firstRow) 64
      List.at 20 img.pixels
      |> assertSome
      |> sampleRow => {
          List.at 20 sampleRow
          |> assertSome
          |> samplePixel => assertEq samplePixel (7, 129, 247)
        }
    }

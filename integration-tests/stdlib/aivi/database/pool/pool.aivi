@no_prelude
module integrationTests.stdlib.aivi.database.pool.tests

use aivi
use aivi.file as File
use aivi.testing
use aivi.concurrency
use aivi.list as List
use aivi.reactive
use aivi.database as Db
use aivi.database.pool as Pool

IntPoolHarness = {
  nextId: Signal Int
  released: Signal (List Int)
  healthy: Signal Bool
}

IntPoolOptions = {
  maxSize: Int
  minIdle: Int
  acquireTimeout: { millis: Int }
  idleTimeout: Option { millis: Int }
  healthCheckInterval: Option { millis: Int }
  backoffPolicy: Pool.BackoffPolicy
  queuePolicy: Pool.QueuePolicy
}

mkHarness : Unit -> IntPoolHarness
mkHarness = _ => {
  nextId: signal 0
  released: signal []
  healthy: signal True
}

mkIntPoolConfig : IntPoolOptions -> IntPoolHarness -> Pool.Config Int
mkIntPoolConfig = options => harness => {
  maxSize: options.maxSize
  minIdle: options.minIdle
  acquireTimeout: options.acquireTimeout
  idleTimeout: options.idleTimeout
  healthCheckInterval: options.healthCheckInterval
  backoffPolicy: options.backoffPolicy
  queuePolicy: options.queuePolicy
  acquire: _ => {
    current = get harness.nextId
    _       = set harness.nextId (current + 1)
    pure current
  }
  release: conn => {
    _ = update harness.released (items => [...items, conn])
    pure Unit
  }
  healthCheck: _ => pure (get harness.healthy)
}

assertInvalidConfig : Result PoolError A -> Text -> Effect Text Unit
assertInvalidConfig = result => expected =>
  result
  |> assertErr
  |> err => err match
    | InvalidConfig reason => assertEq reason expected
    | _                    => assert False

createIntPool = options => harness =>
  Pool.create (mkIntPoolConfig options harness)
   |> assertOk

expectAcquireInt = pool =>
  pool
  |> Pool.acquire
  |> assertOk

exerciseQueuePolicy = queuePolicy => expected => {
  harness = mkHarness Unit
  options = {
    maxSize: 2
    minIdle: 0
    acquireTimeout: { millis: 20 }
    idleTimeout: None
    healthCheckInterval: None
    backoffPolicy: Pool.Fixed ({ millis: 1 })
    queuePolicy: queuePolicy
  }

  createIntPool options harness
  |> pool => {
    expectAcquireInt pool
    |> first => {
      expectAcquireInt pool
      |> second => {
        Pool.release pool first
        Pool.release pool second
        expectAcquireInt pool
        |> reused => {
          assertEq reused expected
          Pool.release pool reused
          Pool.close pool
          assertEq (List.length (get harness.released)) 2
        }
      }
    }
  }
}

boomConn : Int -> Effect Text Int
boomConn = _ => fail "boom"

@test "pool error construct"
poolError_construct = {
  e1 = Pool.Timeout
  e2 = Pool.Closed
  e3 = Pool.HealthFailed
  e4 = Pool.InvalidConfig "bad"

  assertEq e1 Pool.Timeout
  assertEq e2 Pool.Closed
  assertEq e3 Pool.HealthFailed
  e4 match
    | InvalidConfig reason => assertEq reason "bad"
    | _                    => assert False
}

@test "queue policy construct"
queuePolicy_construct = {
  assertEq Pool.Fifo Pool.Fifo
  assertEq Pool.Lifo Pool.Lifo
}

assertFixedPolicy : Pool.BackoffPolicy -> Effect Text Unit
assertFixedPolicy = policy => policy match
  | Fixed span => assertEq span.millis 25
  | _          => assert False

assertExponentialPolicy : Pool.BackoffPolicy -> Effect Text Unit
assertExponentialPolicy = policy => policy match
  | Exponential opts => {
      assertEq opts.base.millis 5
      assertEq opts.max.millis 40
    }
  | _ => assert False

@test "backoff policy construct"
backoffPolicy_construct = {
  assertFixedPolicy (Pool.Fixed ({ millis: 25 }))
  assertExponentialPolicy (Pool.Exponential { base: { millis: 5 }, max: { millis: 40 } })
}

@test "pool stats type"
poolStats_type = {
  s = { size: 4, idle: 2, inUse: 2, waiters: 0, closed: False }

  assertEq s.size 4
  assertEq s.idle 2
  assert (s.closed == False)
}

@test "create validates pool config"
create_validates_pool_config = {
  harness = mkHarness Unit

  zeroSize = {
    maxSize: 0
    minIdle: 0
    acquireTimeout: { millis: 20 }
    idleTimeout: None
    healthCheckInterval: None
    backoffPolicy: Pool.Fixed ({ millis: 1 })
    queuePolicy: Pool.Fifo
  }

  tooManyIdle = {
    maxSize: 1
    minIdle: 2
    acquireTimeout: { millis: 20 }
    idleTimeout: None
    healthCheckInterval: None
    backoffPolicy: Pool.Fixed ({ millis: 1 })
    queuePolicy: Pool.Fifo
  }

  negativeAcquireTimeout = {
    maxSize: 1
    minIdle: 0
    acquireTimeout: { millis: -1 }
    idleTimeout: None
    healthCheckInterval: None
    backoffPolicy: Pool.Fixed ({ millis: 1 })
    queuePolicy: Pool.Fifo
  }

  negativeIdleTimeout = {
    maxSize: 1
    minIdle: 0
    acquireTimeout: { millis: 20 }
    idleTimeout: Some { millis: -1 }
    healthCheckInterval: None
    backoffPolicy: Pool.Fixed ({ millis: 1 })
    queuePolicy: Pool.Fifo
  }

  invalidBackoff = {
    maxSize: 1
    minIdle: 0
    acquireTimeout: { millis: 20 }
    idleTimeout: None
    healthCheckInterval: None
    backoffPolicy: Pool.Exponential { base: { millis: 10 }, max: { millis: 5 } }
    queuePolicy: Pool.Fifo
  }

  Pool.create (mkIntPoolConfig zeroSize harness)
  |> zeroSizeResult => {
    assertInvalidConfig zeroSizeResult "maxSize must be > 0"

    Pool.create (mkIntPoolConfig tooManyIdle harness)
    |> tooManyIdleResult => {
      assertInvalidConfig tooManyIdleResult "minIdle must be <= maxSize"

      Pool.create (mkIntPoolConfig negativeAcquireTimeout harness)
      |> negativeAcquireTimeoutResult => {
        assertInvalidConfig negativeAcquireTimeoutResult "acquireTimeout must be >= 0"

        Pool.create (mkIntPoolConfig negativeIdleTimeout harness)
        |> negativeIdleTimeoutResult => {
          assertInvalidConfig negativeIdleTimeoutResult "idleTimeout must be >= 0 when present"

          Pool.create (mkIntPoolConfig invalidBackoff harness)
          |> invalidBackoffResult => {
            assertInvalidConfig invalidBackoffResult "backoffPolicy.Exponential.max must be >= base"

            Pool.create {
              maxSize: 1
              minIdle: 0
              acquireTimeout: { millis: 20 }
              idleTimeout: None
              extraSetting: None
              healthCheckInterval: None
              backoffPolicy: Pool.Fixed ({ millis: 1 })
              queuePolicy: Pool.Fifo
              acquire: _ => pure 1
              release: _ => pure Unit
              healthCheck: _ => pure True
            }
            |> unexpectedFieldResult => {
              assertInvalidConfig unexpectedFieldResult "unexpected pool config field(s): extraSetting"
              assertEq (get harness.released) []
            }
          }
        }
      }
    }
  }
}

@test "queue policy controls idle reuse order"
queue_policy_controls_idle_reuse_order = {
  exerciseQueuePolicy Pool.Fifo 0
  exerciseQueuePolicy Pool.Lifo 1
}

@test "stats reflect pool lifecycle"
stats_reflect_pool_lifecycle = {
  harness = mkHarness Unit
  options = {
    maxSize: 2
    minIdle: 1
    acquireTimeout: { millis: 20 }
    idleTimeout: None
    healthCheckInterval: None
    backoffPolicy: Pool.Fixed ({ millis: 1 })
    queuePolicy: Pool.Fifo
  }

  createIntPool options harness
  |> pool => {
    Pool.stats pool
    |> initial => {
      assertEq initial.size 1
      assertEq initial.idle 1
      assertEq initial.inUse 0
      assertEq initial.waiters 0
      assertEq initial.closed False

      expectAcquireInt pool
      |> conn => {
        Pool.stats pool
        |> borrowed => {
          assertEq conn 0
          assertEq borrowed.size 1
          assertEq borrowed.idle 0
          assertEq borrowed.inUse 1
          assertEq (get harness.released) []

          Pool.release pool conn
          Pool.stats pool
          |> returned => {
            assertEq returned.size 1
            assertEq returned.idle 1
            assertEq returned.inUse 0
            assertEq returned.closed False

            Pool.close pool
            Pool.stats pool
            |> closed => {
              assertEq closed.size 0
              assertEq closed.idle 0
              assertEq closed.inUse 0
              assertEq closed.closed True
              assertEq (get harness.released) [0]

              Pool.acquire pool
              |> assertErr
              |> closedErr => assertEq closedErr Pool.Closed
            }
          }
        }
      }
    }
  }
}

@test "acquire times out when pool is exhausted"
acquire_times_out_when_pool_is_exhausted = {
  harness = mkHarness Unit
  options = {
    maxSize: 1
    minIdle: 1
    acquireTimeout: { millis: 10 }
    idleTimeout: None
    healthCheckInterval: None
    backoffPolicy: Pool.Fixed ({ millis: 1 })
    queuePolicy: Pool.Fifo
  }

  createIntPool options harness
  |> pool => {
    expectAcquireInt pool
    |> conn => {
      Pool.acquire pool
      |> assertErr
      |> timeoutErr => {
        Pool.stats pool
        |> busyStats => {
          assertEq timeoutErr Pool.Timeout
          assertEq busyStats.inUse 1
          assertEq busyStats.idle 0
          Pool.release pool conn
          Pool.close pool
          assertEq (get harness.released) [0]
        }
      }
    }
  }
}

@test "withConn releases connection after user failure"
withConn_releases_connection_after_user_failure = {
  harness = mkHarness Unit
  options = {
    maxSize: 1
    minIdle: 0
    acquireTimeout: { millis: 20 }
    idleTimeout: None
    healthCheckInterval: None
    backoffPolicy: Pool.Fixed ({ millis: 1 })
    queuePolicy: Pool.Fifo
  }

  createIntPool options harness
  |> pool => {
    attempt (Pool.withConn pool boomConn)
    |> result => {
      result match
        | Err msg => assertEq msg "boom"
        | Ok _    => assert False

      Pool.stats pool
      |> stats => {
        assertEq stats.idle 1
        assertEq stats.inUse 0
        Pool.close pool
        assertEq (get harness.released) [0]
      }
    }
  }
}

delayedRelease = pool => conn =>
  {
    sleep 10
    Pool.release pool conn
  }

releaseLater = pool => conn => spawn (delayedRelease pool conn)

@test "drain releases idle connections and keeps pool open"
drain_releases_idle_connections_and_keeps_pool_open = {
  harness = mkHarness Unit
  options = {
    maxSize: 2
    minIdle: 0
    acquireTimeout: { millis: 20 }
    idleTimeout: None
    healthCheckInterval: None
    backoffPolicy: Pool.Fixed ({ millis: 1 })
    queuePolicy: Pool.Fifo
  }

  createIntPool options harness
  |> pool => {
    expectAcquireInt pool
    |> conn0 => {
      expectAcquireInt pool
      |> conn1 => {
        Pool.release pool conn0
        releaseLater pool conn1
        |> releaser => {
          Pool.drain pool
          releaser.join

          Pool.stats pool
          |> drained => {
            assertEq drained.size 0
            assertEq drained.idle 0
            assertEq drained.inUse 0
            assertEq drained.closed False
            assertEq (get harness.released) [0, conn1]

            expectAcquireInt pool
            |> reused => {
              assertEq reused 2
              Pool.release pool reused
              Pool.close pool
              assertEq (get harness.released) [0, conn1, 2]
            }
          }
        }
      }
    }
  }
}

poolPath = "/tmp/aivi-db-pool-transaction.sqlite"

users : Db.Relation { id: Int, name: Text }
users = Db.relation "pool_users" [
  { name: "id",   type: Db.IntType,     constraints: [Db.NotNull], default: None }
  { name: "name", type: Db.Varchar 255, constraints: [Db.NotNull], default: None }
] []

poolCfg : Pool.Config DbConnection
poolCfg = {
  maxSize: 2
  minIdle: 0
  acquireTimeout: { millis: 1000 }
  idleTimeout: None
  healthCheckInterval: None
  backoffPolicy: Pool.Fixed ({ millis: 25 })
  queuePolicy: Pool.Fifo
  acquire: _ => Db.connect { driver: Sqlite, url: poolPath }
  release: Db.close
  healthCheck: _ => pure True
}

@test "pooled connections isolate uncommitted writes"
pooled_connections_isolate_uncommitted_writes = {
  File.delete poolPath

  Db.connect { driver: Sqlite, url: poolPath }
  |> init => {
    Db.runMigrationsOn init [users]
    Db.close init

    Pool.create poolCfg
    |> assertOk
    |> pool => {
      Pool.withConn pool (conn1 => {
        Db.beginTxOn conn1
        Db.insertOn conn1 users { id: 1, name: "Outer" }

        Pool.withConn pool (conn2 => Db.rowsOn conn2 users)
        |> assertOk
        |> rowsBefore => {
          assertEq (List.length rowsBefore) 0
          Db.commitTxOn conn1

          Pool.withConn pool (conn2 => Db.rowsOn conn2 users)
          |> assertOk
        }
      })
      |> assertOk
      |> rows => {
        Pool.close pool
        File.delete poolPath
        assertEq (List.length rows) 1
      }
    }
  }
}

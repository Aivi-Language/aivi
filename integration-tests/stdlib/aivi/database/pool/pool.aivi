@no_prelude
module integrationTests.stdlib.aivi.database.pool.tests

use aivi
use aivi.file as File
use aivi.testing
use aivi.concurrency
use aivi.list as List
use aivi.reactive
use aivi.database as Db
use aivi.database.pool as Pool

IntPoolHarness = {
  nextId: Signal Int
  released: Signal (List Int)
  healthy: Signal Bool
}

IntPoolOptions = {
  maxSize: Int
  minIdle: Int
  acquireTimeout: { millis: Int }
  idleTimeout: Option { millis: Int }
  healthCheckInterval: Option { millis: Int }
  backoffPolicy: Pool.BackoffPolicy
  queuePolicy: Pool.QueuePolicy
}

mkHarness : Unit -> IntPoolHarness
mkHarness = _ => {
  nextId: signal 0
  released: signal []
  healthy: signal True
}

mkIntPoolConfig : IntPoolOptions -> IntPoolHarness -> Pool.Config Int
mkIntPoolConfig = options => harness => {
  maxSize: options.maxSize
  minIdle: options.minIdle
  acquireTimeout: options.acquireTimeout
  idleTimeout: options.idleTimeout
  healthCheckInterval: options.healthCheckInterval
  backoffPolicy: options.backoffPolicy
  queuePolicy: options.queuePolicy
  acquire: _ => {
    current = get harness.nextId
    _       = set harness.nextId (current + 1)
    pure current
  }
  release: conn => {
    _ = update harness.released (items => [...items, conn])
    pure Unit
  }
  healthCheck: _ => pure (get harness.healthy)
}

assertInvalidConfig : Result PoolError A -> Text -> Effect Text Unit
assertInvalidConfig = result => expected =>
  result
|> assertErr#err
|> _ => err match
  | InvalidConfig reason => assertEq reason expected
  | _                    => assert False

createIntPool = options => harness =>
  Unit
|> _ => Pool.create (mkIntPoolConfig options harness)#poolResult
|> _ => assertOk poolResult

expectAcquireInt = pool =>
  Unit
|> _ => Pool.acquire pool#connResult
|> _ => assertOk connResult

exerciseQueuePolicy = queuePolicy => expected => {
  harness = mkHarness Unit
  options = {
    maxSize: 2
    minIdle: 0
    acquireTimeout: { millis: 20 }
    idleTimeout: None
    healthCheckInterval: None
    backoffPolicy: Pool.Fixed ({ millis: 1 })
    queuePolicy: queuePolicy
  }

  Unit
   |> _ => createIntPool options harness#pool
   |> _ => expectAcquireInt pool#first
   |> _ => expectAcquireInt pool#second
  ~|>_ => Pool.release pool first
  ~|>_ => Pool.release pool second
   |> _ => expectAcquireInt pool#reused
  ~|>_ => assertEq reused expected
  ~|>_ => Pool.release pool reused
  ~|>_ => Pool.close pool
   |> _ => assertEq (List.length (get harness.released)) 2
}

boomConn : Int -> Effect Text Int
boomConn = _ => fail "boom"

@test "pool error construct"
poolError_construct = {
  e1 = Pool.Timeout
  e2 = Pool.Closed
  e3 = Pool.HealthFailed
  e4 = Pool.InvalidConfig "bad"

  Unit
  ~|>_ => assertEq e1 Pool.Timeout
  ~|>_ => assertEq e2 Pool.Closed
  ~|>_ => assertEq e3 Pool.HealthFailed
   |> _ => e4 match
    | InvalidConfig reason => assertEq reason "bad"
    | _                    => assert False
}

@test "queue policy construct"
queuePolicy_construct = Unit
~|>_ => assertEq Pool.Fifo Pool.Fifo
 |> _ => assertEq Pool.Lifo Pool.Lifo

assertFixedPolicy : Pool.BackoffPolicy -> Effect Text Unit
assertFixedPolicy = policy => policy match
  | Fixed span => assertEq span.millis 25
  | _          => assert False

assertExponentialPolicy : Pool.BackoffPolicy -> Effect Text Unit
assertExponentialPolicy = policy => policy match
  | Exponential opts =>
      Unit
      ~|>_ => assertEq opts.base.millis 5
       |> _ => assertEq opts.max.millis 40
  | _ => assert False

@test "backoff policy construct"
backoffPolicy_construct = Unit
  |> _ => assertFixedPolicy (Pool.Fixed ({ millis: 25 }))
  |> _ => assertExponentialPolicy (Pool.Exponential { base: { millis: 5 }, max: { millis: 40 } })

@test "pool stats type"
poolStats_type = {
  s = { size: 4, idle: 2, inUse: 2, waiters: 0, closed: False }

  Unit
  ~|>_ => assertEq s.size 4
  ~|>_ => assertEq s.idle 2
   |> _ => assert (s.closed == False)
}

@test "create validates pool config"
create_validates_pool_config = {
  harness = mkHarness Unit

  zeroSize = {
    maxSize: 0
    minIdle: 0
    acquireTimeout: { millis: 20 }
    idleTimeout: None
    healthCheckInterval: None
    backoffPolicy: Pool.Fixed ({ millis: 1 })
    queuePolicy: Pool.Fifo
  }

  tooManyIdle = {
    maxSize: 1
    minIdle: 2
    acquireTimeout: { millis: 20 }
    idleTimeout: None
    healthCheckInterval: None
    backoffPolicy: Pool.Fixed ({ millis: 1 })
    queuePolicy: Pool.Fifo
  }

  negativeAcquireTimeout = {
    maxSize: 1
    minIdle: 0
    acquireTimeout: { millis: -1 }
    idleTimeout: None
    healthCheckInterval: None
    backoffPolicy: Pool.Fixed ({ millis: 1 })
    queuePolicy: Pool.Fifo
  }

  negativeIdleTimeout = {
    maxSize: 1
    minIdle: 0
    acquireTimeout: { millis: 20 }
    idleTimeout: Some { millis: -1 }
    healthCheckInterval: None
    backoffPolicy: Pool.Fixed ({ millis: 1 })
    queuePolicy: Pool.Fifo
  }

  invalidBackoff = {
    maxSize: 1
    minIdle: 0
    acquireTimeout: { millis: 20 }
    idleTimeout: None
    healthCheckInterval: None
    backoffPolicy: Pool.Exponential { base: { millis: 10 }, max: { millis: 5 } }
    queuePolicy: Pool.Fifo
  }

  Unit
   |> _ => Pool.create (mkIntPoolConfig zeroSize harness)#zeroSizeResult
  ~|>_ => assertInvalidConfig zeroSizeResult "maxSize must be > 0"
   |> _ => Pool.create (mkIntPoolConfig tooManyIdle harness)#tooManyIdleResult
  ~|>_ => assertInvalidConfig tooManyIdleResult "minIdle must be <= maxSize"
   |> _ => Pool.create (mkIntPoolConfig negativeAcquireTimeout harness)#negativeAcquireTimeoutResult
  ~|>_ => assertInvalidConfig negativeAcquireTimeoutResult "acquireTimeout must be >= 0"
   |> _ => Pool.create (mkIntPoolConfig negativeIdleTimeout harness)#negativeIdleTimeoutResult
  ~|>_ => assertInvalidConfig negativeIdleTimeoutResult "idleTimeout must be >= 0 when present"
   |> _ => Pool.create (mkIntPoolConfig invalidBackoff harness)#invalidBackoffResult
  ~|>_ => assertInvalidConfig invalidBackoffResult "backoffPolicy.Exponential.max must be >= base"
   |> _ => Pool.create {
    maxSize: 1
    minIdle: 0
    acquireTimeout: { millis: 20 }
    idleTimeout: None
    extraSetting: None
    healthCheckInterval: None
    backoffPolicy: Pool.Fixed ({ millis: 1 })
    queuePolicy: Pool.Fifo
    acquire: _ => pure 1
    release: _ => pure Unit
    healthCheck: _ => pure True
  }#unexpectedFieldResult
  ~|>_ => assertInvalidConfig unexpectedFieldResult "unexpected pool config field(s): extraSetting"
   |> _ => assertEq (get harness.released) []
}

@test "queue policy controls idle reuse order"
queue_policy_controls_idle_reuse_order = Unit
~|>_ => exerciseQueuePolicy Pool.Fifo 0
 |> _ => exerciseQueuePolicy Pool.Lifo 1

@test "stats reflect pool lifecycle"
stats_reflect_pool_lifecycle = {
  harness = mkHarness Unit
  options = {
    maxSize: 2
    minIdle: 1
    acquireTimeout: { millis: 20 }
    idleTimeout: None
    healthCheckInterval: None
    backoffPolicy: Pool.Fixed ({ millis: 1 })
    queuePolicy: Pool.Fifo
  }

  Unit
   |> _ => createIntPool options harness#pool
   |> _ => Pool.stats pool#initial
  ~|>_ => assertEq initial.size 1
  ~|>_ => assertEq initial.idle 1
  ~|>_ => assertEq initial.inUse 0
  ~|>_ => assertEq initial.waiters 0
  ~|>_ => assertEq initial.closed False
   |> _ => expectAcquireInt pool#conn
   |> _ => Pool.stats pool#borrowed
  ~|>_ => assertEq conn 0
  ~|>_ => assertEq borrowed.size 1
  ~|>_ => assertEq borrowed.idle 0
  ~|>_ => assertEq borrowed.inUse 1
  ~|>_ => assertEq (get harness.released) []
  ~|>_ => Pool.release pool conn
   |> _ => Pool.stats pool#returned
  ~|>_ => assertEq returned.size 1
  ~|>_ => assertEq returned.idle 1
  ~|>_ => assertEq returned.inUse 0
  ~|>_ => assertEq returned.closed False
  ~|>_ => Pool.close pool
   |> _ => Pool.stats pool#closed
  ~|>_ => assertEq closed.size 0
  ~|>_ => assertEq closed.idle 0
  ~|>_ => assertEq closed.inUse 0
  ~|>_ => assertEq closed.closed True
  ~|>_ => assertEq (get harness.released) [0]
   |> _ => Pool.acquire pool#closedResult
   |> _ => assertErr closedResult#closedErr
   |> _ => assertEq closedErr Pool.Closed
}

@test "acquire times out when pool is exhausted"
acquire_times_out_when_pool_is_exhausted = {
  harness = mkHarness Unit
  options = {
    maxSize: 1
    minIdle: 1
    acquireTimeout: { millis: 10 }
    idleTimeout: None
    healthCheckInterval: None
    backoffPolicy: Pool.Fixed ({ millis: 1 })
    queuePolicy: Pool.Fifo
  }

  Unit
   |> _ => createIntPool options harness#pool
   |> _ => expectAcquireInt pool#conn
   |> _ => Pool.acquire pool#timeoutRes
   |> _ => assertErr timeoutRes#timeoutErr
   |> _ => Pool.stats pool#busyStats
  ~|>_ => assertEq timeoutErr Pool.Timeout
  ~|>_ => assertEq busyStats.inUse 1
  ~|>_ => assertEq busyStats.idle 0
  ~|>_ => Pool.release pool conn
  ~|>_ => Pool.close pool
   |> _ => assertEq (get harness.released) [0]
}

@test "withConn releases connection after user failure"
withConn_releases_connection_after_user_failure = {
  harness = mkHarness Unit
  options = {
    maxSize: 1
    minIdle: 0
    acquireTimeout: { millis: 20 }
    idleTimeout: None
    healthCheckInterval: None
    backoffPolicy: Pool.Fixed ({ millis: 1 })
    queuePolicy: Pool.Fifo
  }

  Unit
   |> _ => createIntPool options harness#pool
   |> _ => attempt (Pool.withConn pool boomConn)#result
  ~|>_ => result match
    | Err msg => assertEq msg "boom"
    | Ok _    => assert False
     |> _ => Pool.stats pool#stats
    ~|>_ => assertEq stats.idle 1
    ~|>_ => assertEq stats.inUse 0
    ~|>_ => Pool.close pool
     |> _ => assertEq (get harness.released) [0]
}

delayedRelease = pool => conn =>
  Unit
  ~|>_ => sleep 10
  ~|>_ => Pool.release pool conn

releaseLater = pool => conn => spawn (delayedRelease pool conn)

@test "drain releases idle connections and keeps pool open"
drain_releases_idle_connections_and_keeps_pool_open = {
  harness = mkHarness Unit
  options = {
    maxSize: 2
    minIdle: 0
    acquireTimeout: { millis: 20 }
    idleTimeout: None
    healthCheckInterval: None
    backoffPolicy: Pool.Fixed ({ millis: 1 })
    queuePolicy: Pool.Fifo
  }

  Unit
   |> _ => createIntPool options harness#pool
   |> _ => expectAcquireInt pool#conn0
   |> _ => expectAcquireInt pool#conn1
  ~|>_ => Pool.release pool conn0
   |> _ => releaseLater pool conn1#releaser
  ~|>_ => Pool.drain pool
  ~|>_ => releaser.join
   |> _ => Pool.stats pool#drained
  ~|>_ => assertEq drained.size 0
  ~|>_ => assertEq drained.idle 0
  ~|>_ => assertEq drained.inUse 0
  ~|>_ => assertEq drained.closed False
  ~|>_ => assertEq (get harness.released) [0, conn1]
   |> _ => expectAcquireInt pool#reused
  ~|>_ => assertEq reused 2
  ~|>_ => Pool.release pool reused
  ~|>_ => Pool.close pool
   |> _ => assertEq (get harness.released) [0, conn1, 2]
}

poolPath = "/tmp/aivi-db-pool-transaction.sqlite"

users : Db.Relation { id: Int, name: Text }
users = Db.relation "pool_users" [
  { name: "id",   type: Db.IntType,     constraints: [Db.NotNull], default: None }
  { name: "name", type: Db.Varchar 255, constraints: [Db.NotNull], default: None }
] []

poolCfg : Pool.Config DbConnection
poolCfg = {
  maxSize: 2
  minIdle: 0
  acquireTimeout: { millis: 1000 }
  idleTimeout: None
  healthCheckInterval: None
  backoffPolicy: Pool.Fixed ({ millis: 25 })
  queuePolicy: Pool.Fifo
  acquire: _ => Db.connect { driver: Sqlite, url: poolPath }
  release: Db.close
  healthCheck: _ => pure True
}

@test "pooled connections isolate uncommitted writes"
pooled_connections_isolate_uncommitted_writes = Unit
~|>_ => File.delete poolPath
 |> _ => Db.connect { driver: Sqlite, url: poolPath }#init
~|>_ => Db.runMigrationsOn init [users]
~|>_ => Db.close init
 |> _ => Pool.create poolCfg#poolResult
 |> _ => assertOk poolResult#pool
 |> _ => Pool.withConn pool (conn1 =>
  Unit
  ~|>_ => Db.beginTxOn conn1
  ~|>_ => Db.insertOn conn1 users { id: 1, name: "Outer" }
   |> _ => Pool.withConn pool (conn2 => Db.rowsOn conn2 users)#beforeResult
   |> _ => assertOk beforeResult#rowsBefore
  ~|>_ => assertEq (List.length rowsBefore) 0
  ~|>_ => Db.commitTxOn conn1
   |> _ => Pool.withConn pool (conn2 => Db.rowsOn conn2 users)#afterResult
   |> _ => assertOk afterResult
)#outerResult
 |> _ => assertOk outerResult#rows
~|>_ => Pool.close pool
~|>_ => File.delete poolPath
 |> _ => assertEq (List.length rows) 1

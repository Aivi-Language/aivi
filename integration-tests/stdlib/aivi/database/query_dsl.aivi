@no_prelude
module integrationTests.stdlib.aivi.database.queryDsl

use aivi
use aivi.testing
use aivi.database (
  Table, IntType, BoolType, Varchar,
  AutoIncrement, NotNull,
  DefaultBool,
  Sqlite,
  DbConnection, DbError,
  Query,
  Insert,
  emptyQuery,
  table, connect, close,
  runMigrationsOn, applyDeltaOn, runQueryOn,
  from, where, select, queryOf, guard, orderBy, limit, offset, count, exists,
  configure, runMigrations, applyDelta, runQuery
)

// ── shared schema ──────────────────────────────────────────────────────────

Product = { id: Int, name: Text, price: Int, active: Bool }

productTable : Table Product
productTable = table "products" [
  { name: "id",     type: IntType,    constraints: [AutoIncrement, NotNull], default: None }
  { name: "name",   type: Varchar 80, constraints: [NotNull],                default: None }
  { name: "price",  type: IntType,    constraints: [NotNull],                default: None }
  { name: "active", type: BoolType,   constraints: [NotNull],                default: Some (DefaultBool True) }
]

seedProducts : DbConnection -> Effect DbError Unit
seedProducts = conn => do Effect {
  _ <- applyDeltaOn conn productTable (Insert { id: 1, name: "Widget", price: 10, active: True })
  _ <- applyDeltaOn conn productTable (Insert { id: 2, name: "Gadget", price: 20, active: False })
  _ <- applyDeltaOn conn productTable (Insert { id: 3, name: "Doohick", price: 15, active: True })
  pure Unit
}

expectedProducts : List Product
expectedProducts = [
  { id: 1, name: "Widget",  price: 10, active: True }
  { id: 2, name: "Gadget",  price: 20, active: False }
  { id: 3, name: "Doohick", price: 15, active: True }
]

// ── tests ──────────────────────────────────────────────────────────────────

@test "from loads all rows"
from_loads_all_rows = do Effect {
  conn    <- connect { driver: Sqlite, url: ":memory:" }
  _       <- runMigrationsOn conn [productTable]
  _       <- seedProducts conn
  results <- runQueryOn conn (from productTable)
  _       <- close conn
  assertEq results expectedProducts
}

@test "where filters rows"
where_filters_rows = do Effect {
  conn    <- connect { driver: Sqlite, url: ":memory:" }
  _       <- runMigrationsOn conn [productTable]
  _       <- seedProducts conn
  results <- runQueryOn conn (where active (from productTable))
  _       <- close conn
  assertEq (List.length results) 2
}

@test "select projects rows"
select_projects_rows = do Effect {
  conn  <- connect { driver: Sqlite, url: ":memory:" }
  _     <- runMigrationsOn conn [productTable]
  _     <- seedProducts conn
  names <- runQueryOn conn (select.name (from productTable))
  _     <- close conn
  assertEq (List.length names) 3
}

@test "do Query from single bind"
do_query_from_single_bind = do Effect {
  conn    <- connect { driver: Sqlite, url: ":memory:" }
  _       <- runMigrationsOn conn [productTable]
  _       <- seedProducts conn
  results <- runQueryOn conn (do Query {
      p       <- from productTable
      queryOf p
  })
  _ <- close conn
  assertEq results expectedProducts
}

@test "do Query with guard filters"
do_query_guard_filters = do Effect {
  conn    <- connect { driver: Sqlite, url: ":memory:" }
  _       <- runMigrationsOn conn [productTable]
  _       <- seedProducts conn
  results <- runQueryOn conn (do Query {
      p       <- from productTable
      guard p.active
      queryOf p
  })
  _ <- close conn
  assertEq (List.length results) 2
}

@test "do Query projects field"
do_query_projects_field = do Effect {
  conn  <- connect { driver: Sqlite, url: ":memory:" }
  _     <- runMigrationsOn conn [productTable]
  _     <- seedProducts conn
  names <- runQueryOn conn (do Query {
      p     <- from productTable
      queryOf p.name
  })
  _ <- close conn
  assertEq (List.length names) 3
}

@test "do Query guard and project"
do_query_guard_and_project = do Effect {
  conn  <- connect { driver: Sqlite, url: ":memory:" }
  _     <- runMigrationsOn conn [productTable]
  _     <- seedProducts conn
  names <- runQueryOn conn (do Query {
      p     <- from productTable
      guard p.active
      queryOf p.name
  })
  _ <- close conn
  assertEq (List.length names) 2
}

@test "emptyQuery returns empty list"
empty_query_returns_empty = do Effect {
  conn    <- connect { driver: Sqlite, url: ":memory:" }
  results <- runQueryOn conn emptyQuery
  _       <- close conn
  assertEq (List.length results) 0
}

@test "queryOf wraps single value"
query_of_wraps_single_value = do Effect {
  conn    <- connect { driver: Sqlite, url: ":memory:" }
  results <- runQueryOn conn (queryOf 42)
  _       <- close conn
  assertEq results [42]
}

@test "do Query let binding"
do_query_let_binding = do Effect {
  conn    <- connect { driver: Sqlite, url: ":memory:" }
  _       <- runMigrationsOn conn [productTable]
  _       <- seedProducts conn
  results <- runQueryOn conn (do Query {
      p       <- from productTable
      doubled = p.price * 2
      queryOf doubled
  })
  _ <- close conn
  assertEq results [20, 40, 30]
}

@test "orderBy sorts rows ascending by key"
order_by_sorts_ascending = do Effect {
  conn <- connect { driver: Sqlite, url: ":memory:" }
  _    <- runMigrationsOn conn [productTable]
  _    <- seedProducts conn
  rows <- runQueryOn conn (orderBy.price (from productTable))
  _    <- close conn
  prices = List.map.price rows
  assertEq prices [10, 15, 20]
}

@test "orderBy sorts text field ascending"
order_by_sorts_text = do Effect {
  conn <- connect { driver: Sqlite, url: ":memory:" }
  _    <- runMigrationsOn conn [productTable]
  _    <- seedProducts conn
  rows <- runQueryOn conn (orderBy.name (from productTable))
  _    <- close conn
  names = List.map.name rows
  assertEq names ["Doohick", "Gadget", "Widget"]
}

@test "limit returns first n rows"
limit_returns_first_n = do Effect {
  conn    <- connect { driver: Sqlite, url: ":memory:" }
  _       <- runMigrationsOn conn [productTable]
  _       <- seedProducts conn
  results <- runQueryOn conn (limit 2 (from productTable))
  _       <- close conn
  assertEq results [
    { id: 1, name: "Widget", price: 10, active: True }
    { id: 2, name: "Gadget", price: 20, active: False }
  ]
}

@test "limit 0 returns empty list"
limit_zero_returns_empty = do Effect {
  conn    <- connect { driver: Sqlite, url: ":memory:" }
  _       <- runMigrationsOn conn [productTable]
  _       <- seedProducts conn
  results <- runQueryOn conn (limit 0 (from productTable))
  _       <- close conn
  assertEq (List.length results) 0
}

@test "offset skips first n rows"
offset_skips_first_n = do Effect {
  conn    <- connect { driver: Sqlite, url: ":memory:" }
  _       <- runMigrationsOn conn [productTable]
  _       <- seedProducts conn
  results <- runQueryOn conn (offset 1 (from productTable))
  _       <- close conn
  assertEq results [
    { id: 2, name: "Gadget",  price: 20, active: False }
    { id: 3, name: "Doohick", price: 15, active: True }
  ]
}

@test "offset beyond length returns empty"
offset_beyond_length = do Effect {
  conn    <- connect { driver: Sqlite, url: ":memory:" }
  _       <- runMigrationsOn conn [productTable]
  _       <- seedProducts conn
  results <- runQueryOn conn (offset 10 (from productTable))
  _       <- close conn
  assertEq (List.length results) 0
}

@test "orderBy then limit selects top n"
order_by_then_limit = do Effect {
  conn <- connect { driver: Sqlite, url: ":memory:" }
  _    <- runMigrationsOn conn [productTable]
  _    <- seedProducts conn
  rows <- runQueryOn conn (limit 2 (orderBy.price (from productTable)))
  _    <- close conn
  prices = List.map.price rows
  assertEq prices [10, 15]
}

@test "limit and offset for pagination"
limit_and_offset_pagination = do Effect {
  conn    <- connect { driver: Sqlite, url: ":memory:" }
  _       <- runMigrationsOn conn [productTable]
  _       <- seedProducts conn
  results <- runQueryOn conn (limit 1 (offset 1 (orderBy.price (from productTable))))
  _       <- close conn
  prices = List.map.price results
  assertEq prices [15]
}

@test "do Query with orderBy"
do_query_with_order_by = do Effect {
  conn <- connect { driver: Sqlite, url: ":memory:" }
  _    <- runMigrationsOn conn [productTable]
  _    <- seedProducts conn
  rows <- runQueryOn conn (do Query {
      p    <- from productTable
      guard p.active
      orderBy.price (queryOf p)
  })
  _ <- close conn
  assertEq (List.map.price rows) [10, 15]
}

// ── count ──────────────────────────────────────────────────────────────────

@test "count returns total number of rows"
count_returns_row_count = do Effect {
  conn   <- connect { driver: Sqlite, url: ":memory:" }
  _      <- runMigrationsOn conn [productTable]
  _      <- seedProducts conn
  result <- runQueryOn conn (count (from productTable))
  _      <- close conn
  assertEq result [3]
}

@test "count on filtered query returns filtered count"
count_filtered = do Effect {
  conn   <- connect { driver: Sqlite, url: ":memory:" }
  _      <- runMigrationsOn conn [productTable]
  _      <- seedProducts conn
  result <- runQueryOn conn (count (where active (from productTable)))
  _      <- close conn
  assertEq result [2]
}

@test "count on empty query returns zero"
count_empty = do Effect {
  conn   <- connect { driver: Sqlite, url: ":memory:" }
  result <- runQueryOn conn (count emptyQuery)
  _      <- close conn
  assertEq result [0]
}

activeProductsQ : Query Product
activeProductsQ = do Query {
  p <- from productTable
  guard p.active
  queryOf p
}

@test "count composes with do Query"
count_do_query = do Effect {
  conn   <- connect { driver: Sqlite, url: ":memory:" }
  _      <- runMigrationsOn conn [productTable]
  _      <- seedProducts conn
  result <- runQueryOn conn (count activeProductsQ)
  _      <- close conn
  assertEq result [2]
}

// ── exists ─────────────────────────────────────────────────────────────────

@test "exists returns True when rows are present"
exists_true_when_rows_present = do Effect {
  conn   <- connect { driver: Sqlite, url: ":memory:" }
  _      <- runMigrationsOn conn [productTable]
  _      <- seedProducts conn
  result <- runQueryOn conn (exists (from productTable))
  _      <- close conn
  assertEq result [True]
}

@test "exists returns False on empty query"
exists_false_when_empty = do Effect {
  conn   <- connect { driver: Sqlite, url: ":memory:" }
  result <- runQueryOn conn (exists emptyQuery)
  _      <- close conn
  assertEq result [False]
}

expensiveProductsQ : Query Product
expensiveProductsQ = where (p => p.price > 100) (from productTable)

@test "exists returns False when filter matches nothing"
exists_false_when_no_match = do Effect {
  conn   <- connect { driver: Sqlite, url: ":memory:" }
  _      <- runMigrationsOn conn [productTable]
  _      <- seedProducts conn
  result <- runQueryOn conn (exists expensiveProductsQ)
  _      <- close conn
  assertEq result [False]
}

affordableProductsQ : Query Product
affordableProductsQ = where (p => p.price > 10) (from productTable)

@test "exists returns True when at least one row matches"
exists_true_when_some_match = do Effect {
  conn   <- connect { driver: Sqlite, url: ":memory:" }
  _      <- runMigrationsOn conn [productTable]
  _      <- seedProducts conn
  result <- runQueryOn conn (exists affordableProductsQ)
  _      <- close conn
  assertEq result [True]
}

// ── multi-table composition ────────────────────────────────────────────────

Order = { id: Int, productId: Int, qty: Int }

orderTable : Table Order
orderTable = table "orders" [
  { name: "id",        type: IntType, constraints: [AutoIncrement, NotNull], default: None }
  { name: "productId", type: IntType, constraints: [NotNull],                default: None }
  { name: "qty",       type: IntType, constraints: [NotNull],                default: None }
]

seedOrders : DbConnection -> Effect DbError Unit
seedOrders = conn => do Effect {
  _ <- applyDeltaOn conn orderTable (Insert { id: 1, productId: 1, qty: 5 })
  _ <- applyDeltaOn conn orderTable (Insert { id: 2, productId: 3, qty: 2 })
  pure Unit
}

activeOrdersQ : Query Order
activeOrdersQ = do Query {
  order   <- from orderTable
  product <- from productTable
  guard (order.productId == product.id)
  guard product.active
  queryOf order
}

expectedActiveOrders : List Order
expectedActiveOrders = [
  { id: 1, productId: 1, qty: 5 }
  { id: 2, productId: 3, qty: 2 }
]

inactiveOrdersQ : Query Order
inactiveOrdersQ = do Query {
  order   <- from orderTable
  product <- from productTable
  guard (order.productId == product.id)
  guard (product.active == False)
  queryOf order
}

activeOrderSummariesQ : Query { orderId: Int, productName: Text }
activeOrderSummariesQ = do Query {
  order   <- from orderTable
  product <- from productTable
  guard (order.productId == product.id)
  guard product.active
  queryOf { orderId: order.id, productName: product.name }
}

@test "count orders for active products via cross-join"
count_orders_for_active_products = do Effect {
  conn   <- connect { driver: Sqlite, url: ":memory:" }
  _      <- runMigrationsOn conn [productTable, orderTable]
  _      <- seedProducts conn
  _      <- seedOrders conn
  result <- runQueryOn conn (count activeOrdersQ)
  _      <- close conn
  assertEq result [2]
}

@test "joined query returns whole order rows"
joined_query_returns_whole_order_rows = do Effect {
  conn   <- connect { driver: Sqlite, url: ":memory:" }
  _      <- runMigrationsOn conn [productTable, orderTable]
  _      <- seedProducts conn
  _      <- seedOrders conn
  result <- runQueryOn conn activeOrdersQ
  _      <- close conn
  assertEq result expectedActiveOrders
}

@test "exists for orders of inactive products is False"
exists_orders_for_inactive_products = do Effect {
  conn   <- connect { driver: Sqlite, url: ":memory:" }
  _      <- runMigrationsOn conn [productTable, orderTable]
  _      <- seedProducts conn
  _      <- seedOrders conn
  result <- runQueryOn conn (exists inactiveOrdersQ)
  _      <- close conn
  assertEq result [False]
}

@test "do Query join projects record summary"
do_query_join_projects_record = do Effect {
  conn    <- connect { driver: Sqlite, url: ":memory:" }
  _       <- runMigrationsOn conn [productTable, orderTable]
  _       <- seedProducts conn
  _       <- seedOrders conn
  results <- runQueryOn conn activeOrderSummariesQ
  _       <- close conn
  assertEq results [
    { orderId: 1, productName: "Widget" }
    { orderId: 2, productName: "Doohick" }
  ]
}

// ── runQuery (ambient connection) ──────────────────────────────────────────

@test "runQuery uses ambient connection to load all rows"
run_query_ambient_all_rows = do Effect {
  _       <- configure { driver: Sqlite, url: ":memory:" }
  _       <- runMigrations [productTable]
  _       <- applyDelta productTable (Insert { id: 1, name: "Widget", price: 10, active: True })
  _       <- applyDelta productTable (Insert { id: 2, name: "Gadget", price: 20, active: False })
  _       <- applyDelta productTable (Insert { id: 3, name: "Doohick", price: 15, active: True })
  results <- runQuery (from productTable)
  assertEq (List.length results) 3
}

@test "runQuery with where filter uses ambient connection"
run_query_ambient_with_filter = do Effect {
  _       <- configure { driver: Sqlite, url: ":memory:" }
  _       <- runMigrations [productTable]
  _       <- applyDelta productTable (Insert { id: 1, name: "Widget", price: 10, active: True })
  _       <- applyDelta productTable (Insert { id: 2, name: "Gadget", price: 20, active: False })
  _       <- applyDelta productTable (Insert { id: 3, name: "Doohick", price: 15, active: True })
  results <- runQuery (where active (from productTable))
  assertEq (List.length results) 2
}

@test "runQuery with do Query block uses ambient connection"
run_query_ambient_do_query = do Effect {
  _     <- configure { driver: Sqlite, url: ":memory:" }
  _     <- runMigrations [productTable]
  _     <- applyDelta productTable (Insert { id: 1, name: "Widget", price: 10, active: True })
  _     <- applyDelta productTable (Insert { id: 2, name: "Gadget", price: 20, active: False })
  _     <- applyDelta productTable (Insert { id: 3, name: "Doohick", price: 15, active: True })
  names <- runQuery (do Query {
      p     <- from productTable
      guard p.active
      queryOf p.name
  })
  assertEq (List.length names) 2
}

// ── nullable columns ─────────────────────────────────────────────────────────

Customer = { id: Int, email: Option Text }

customerTable : Table Customer
customerTable = table "customers" [
  { name: "id",    type: IntType,     constraints: [NotNull], default: None }
  { name: "email", type: Varchar 120, constraints: [],        default: None }
]

seedCustomers : DbConnection -> Effect DbError Unit
seedCustomers = conn => do Effect {
  _ <- applyDeltaOn conn customerTable (Insert { id: 1, email: Some "a@example.com" })
  _ <- applyDeltaOn conn customerTable (Insert { id: 2, email: None })
  pure Unit
}

@test "nullable row projection round-trips Option fields"
nullable_row_projection_round_trips_option_fields = do Effect {
  conn    <- connect { driver: Sqlite, url: ":memory:" }
  _       <- runMigrationsOn conn [customerTable]
  _       <- seedCustomers conn
  results <- runQueryOn conn (from customerTable)
  _       <- close conn
  assertEq results [
    { id: 1, email: Some "a@example.com" }
    { id: 2, email: None }
  ]
}

@test "nullable scalar projection round-trips Option fields"
nullable_scalar_projection_round_trips_option_fields = do Effect {
  conn   <- connect { driver: Sqlite, url: ":memory:" }
  _      <- runMigrationsOn conn [customerTable]
  _      <- seedCustomers conn
  emails <- runQueryOn conn (select.email (from customerTable))
  _      <- close conn
  assertEq emails [Some "a@example.com", None]
}

@no_prelude
module integrationTests.stdlib.aivi.database.queryDsl

use aivi
use aivi.testing
use aivi.database (
  Relation, Query, DbConnection, DbError,
  IntType, BoolType, Varchar,
  NotNull,
  Sqlite,
  relation, hasMany, belongsTo,
  connect, close, runMigrationsOn, insertOn,
  rowsOn, firstOn, countOn, existsOn,
  orderBy, limit, offset, distinct, selectMap, groupBy, having,
  asc, desc, key, count, sum, max
)

User         = { id: Int, email: Text, active: Bool, age: Int, createdAt: Int }
Order        = { id: Int, userId: Int, status: Text, total: Int, createdAt: Int }
UserSummary  = { id: Int, email: Text }
UserIdOnly   = { userId: Int }
OrderSummary = { id: Int, total: Int }
UserOrders   = { id: Int, orders: List OrderSummary }
SalesSummary = { userId: Int, orderCount: Int, totalSpent: Int, maxOrder: Int }

users : Relation User
users = relation "users" [
  { name: "id",        type: IntType,     constraints: [NotNull], default: None }
  { name: "email",     type: Varchar 120, constraints: [NotNull], default: None }
  { name: "active",    type: BoolType,    constraints: [NotNull], default: None }
  { name: "age",       type: IntType,     constraints: [NotNull], default: None }
  { name: "createdAt", type: IntType,     constraints: [NotNull], default: None }
] [
  hasMany "orders" "orders" .id .userId
]

orders : Relation Order
orders = relation "orders" [
  { name: "id",        type: IntType,    constraints: [NotNull], default: None }
  { name: "userId",    type: IntType,    constraints: [NotNull], default: None }
  { name: "status",    type: Varchar 40, constraints: [NotNull], default: None }
  { name: "total",     type: IntType,    constraints: [NotNull], default: None }
  { name: "createdAt", type: IntType,    constraints: [NotNull], default: None }
] [
  belongsTo "user" "users" .userId .id
]

allUsersById : Query User
allUsersById = users |> orderBy (asc .id)

activeAdultUsers : Query User
activeAdultUsers = users[active && age > 18] |> orderBy (asc .id)

pagedActiveUsers : Query UserSummary
pagedActiveUsers = users[active] |> orderBy (desc .createdAt, asc .id) |> limit 2 |> offset 1 |> selectMap { id: .id, email: .email }

paidUserIds : Query UserIdOnly
paidUserIds = orders[status == "paid"] |> orderBy (asc .userId, asc .id) |> selectMap { userId: .userId } |> distinct

usersWithLargePaidOrders : Query User
usersWithLargePaidOrders = users[orders[status == "paid" && total > 60]] |> orderBy (asc .id)

activeUsersWithPaidOrders : Query UserOrders
activeUsersWithPaidOrders = users[active] |> orderBy (asc .id) |> selectMap {
  id: .id
  orders: (.orders[status == "paid"] |> orderBy (desc .createdAt) |> limit 2 |> selectMap { id: .id, total: .total })
}

salesByUser : Query SalesSummary
salesByUser = orders[status == "paid"] |> groupBy .userId |> having (sum .total > 50) |> selectMap { userId: key, orderCount: count, totalSpent: sum .total, maxOrder: max .total } |> orderBy (desc .totalSpent)

highValuePaidUsers : Query User
highValuePaidUsers = users[id == 2]

usersByCreatedAt : Query User
usersByCreatedAt = users |> orderBy (asc .createdAt)

seed : DbConnection -> Effect DbError Unit
seed = conn => do Effect {
  _ <- runMigrationsOn conn [users, orders]

  users1 <- insertOn conn users {
    id: 1
    email: "ada@example.com"
    active: True
    age: 31
    createdAt: 100
  }
  users2 <- insertOn conn users1 {
    id: 2
    email: "linus@example.com"
    active: False
    age: 19
    createdAt: 200
  }
  _ <- insertOn conn users2 {
    id: 3
    email: "grace@example.com"
    active: True
    age: 24
    createdAt: 300
  }

  orders1 <- insertOn conn orders {
    id: 1
    userId: 1
    status: "paid"
    total: 40
    createdAt: 10
  }
  orders2 <- insertOn conn orders1 {
    id: 2
    userId: 1
    status: "paid"
    total: 70
    createdAt: 30
  }
  orders3 <- insertOn conn orders2 {
    id: 3
    userId: 1
    status: "draft"
    total: 5
    createdAt: 40
  }
  orders4 <- insertOn conn orders3 {
    id: 4
    userId: 2
    status: "paid"
    total: 90
    createdAt: 20
  }
  _ <- insertOn conn orders4 {
    id: 5
    userId: 3
    status: "refunded"
    total: 15
    createdAt: 50
  }

  pure Unit
}

userIds = rows => List.map (u => u.id) rows

@test "relation roots execute as queries"
relation_roots_execute_as_queries = do Effect {
  conn  <- connect { driver: Sqlite, url: ":memory:" }
  _     <- seed conn
  found <- rowsOn conn allUsersById
  _     <- close conn
  assertEq (userIds found) [1, 2, 3]
}

@test "bracket filters use predicate lifting"
bracket_filters_use_predicate_lifting = do Effect {
  conn  <- connect { driver: Sqlite, url: ":memory:" }
  _     <- seed conn
  found <- rowsOn conn activeAdultUsers
  _     <- close conn
  assertEq (userIds found) [1, 3]
}

@test "orderBy limit offset and selectMap compose"
orderBy_limit_offset_and_selectMap_compose = do Effect {
  conn  <- connect { driver: Sqlite, url: ":memory:" }
  _     <- seed conn
  found <- rowsOn conn pagedActiveUsers
  _     <- close conn
  assertEq found [{ id: 1, email: "ada@example.com" }]
}

@test "distinct removes duplicate projected rows"
distinct_removes_duplicate_projected_rows = do Effect {
  conn  <- connect { driver: Sqlite, url: ":memory:" }
  _     <- seed conn
  found <- rowsOn conn paidUserIds
  _     <- close conn
  assertEq (List.length found) 2
  found match
    | [a, b] => assert ((a.userId == 1 && b.userId == 2) || (a.userId == 2 && b.userId == 1))
    | _      => assert False
}

@test "nested relation filters use exists semantics"
nested_relation_filters_use_exists_semantics = do Effect {
  conn  <- connect { driver: Sqlite, url: ":memory:" }
  _     <- seed conn
  found <- rowsOn conn usersWithLargePaidOrders
  _     <- close conn
  assertEq (userIds found) [1, 2]
}

@test "nested relation projections stay nested"
nested_relation_projections_stay_nested = do Effect {
  conn  <- connect { driver: Sqlite, url: ":memory:" }
  _     <- seed conn
  found <- rowsOn conn activeUsersWithPaidOrders
  _     <- close conn
  assertEq found [
    {
      id: 1
      orders: [
        { id: 2, total: 70 }
        { id: 1, total: 40 }
      ]
    }
    {
      id: 3
      orders: []
    }
  ]
}

@test "grouped queries support having aggregates and ordering"
grouped_queries_support_having_aggregates_and_ordering = do Effect {
  conn  <- connect { driver: Sqlite, url: ":memory:" }
  _     <- seed conn
  found <- rowsOn conn salesByUser
  _     <- close conn
  assertEq found [
    { userId: 1, orderCount: 2, totalSpent: 110, maxOrder: 70 }
    { userId: 2, orderCount: 1, totalSpent: 90,  maxOrder: 90 }
  ]
}

@test "rows first count and exists execute compiled queries"
rows_first_count_and_exists_execute_compiled_queries = do Effect {
  conn                  <- connect { driver: Sqlite, url: ":memory:" }
  _                     <- seed conn
  activeAdultCount      <- countOn conn activeAdultUsers
  hasHighValuePaidOrder <- existsOn conn highValuePaidUsers
  firstUser             <- firstOn conn usersByCreatedAt
  _                     <- close conn
  assertEq activeAdultCount 2
  assertEq hasHighValuePaidOrder True
  firstUser match
    | Some user => assertEq user.id 1
    | None      => assert False
}

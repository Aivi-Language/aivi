@no_prelude
module integrationTests.stdlib.aivi.database.domain_Database.tests

use aivi
use aivi.testing
use aivi.database (Delete, Insert, Table, Update, Upsert, load, table)
use aivi.database (domain Database)

len = xs => xs match
  | []           => 0
  | [_, ...rest] => 1 + len rest

@test "literal Delete"
literal_delete_functional = do Effect {
  users0 = table "users"[]
  users1 <- users0 + Insert { id: 1 }
  users2 <- users1 + Delete (u => u.id == 1)
  rows   <- load users2
  assert (len rows == 0)
}

@test "literal Insert"
literal_insert_functional = do Effect {
  users0 = table "users"[]
  users1 <- users0 + Insert { id: 1 }
  rows   <- load users1
  assert (len rows == 1)
}

@test "literal Update"
literal_update_functional = do Effect {
  users0 = table "users"[]
  users1 <- users0 + Insert { id: 1, name: "A" }
  users2 <- users1 + Update (u => u.id == 1) (u => u <| { name: "B" })
  rows   <- load users2
  rows match
    | [u] => assertEq u.name "B"
    | _   => assert False
}

@test "literal Upsert"
literal_upsert_functional = do Effect {
  users0 = table "users"[]
  users1 <- users0 + Upsert (u => u.id == 1) { id: 1, name: "A", active: False } (u => u <| { name: "B", active: True })
  users2 <- users1 + Upsert (u => u.id == 1) { id: 1, name: "X", active: False } (u => u <| { name: "C" })
  rows   <- load users2
  rows match
    | [u] => do Effect {
        assertEq u.name "C"
        assertEq u.active False
      }
    | _ => assert False
}

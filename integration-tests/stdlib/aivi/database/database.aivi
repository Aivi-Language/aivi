@test "upsert convenience inserts when missing"
upsert_convenience_inserts = do Effect {
  users0 = table "upsert_ins_users"[]
  users1 <- upsert users0[id == 99] { id: 99, name: "New" } { id: 99, name: "New" }
  rows   <- dbLoad users1
  assertEq (List.length rows) 1
  rows match
    | [row] => assertEq row.name "New"
    | _     => assert False
}

@test "upsert convenience updates when present"
upsert_convenience_updates = do Effect {
  users0 = table "upsert_upd_users"[]
  users1 <- insert users0 { id: 1, name: "Alice" }
  users2 <- upsert users1[id == 1] { id: 1, name: "Alice" } { name: "Updated" }
  rows   <- dbLoad users2
  assertEq (List.length rows) 1
  rows match
    | [row] => assertEq row.name "Updated"
    | _     => assert False
}

@test "upsertOn convenience"
upsertOn_convenience = do Effect {
  conn <- connect { driver: Sqlite, url: ":memory:" }
  users0 = table "upsertOn_users"[]
  _      <- runMigrationsOn conn [users0]
  users1 <- upsertOn conn users0[id == 1] { id: 1, name: "Alice" } { name: "Updated" }
  users2 <- upsertOn conn users1[id == 1] { id: 1, name: "Alice" } { name: "Updated" }
  rows   <- loadOn conn users2
  _      <- close conn
  assertEq (List.length rows) 1
  rows match
    | [row] => assertEq row.name "Updated"
    | _     => assert False
}

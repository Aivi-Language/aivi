@no_prelude
module integrationTests.stdlib.aivi.database.tests

use aivi
use aivi.testing
use aivi.database (
  IntType, BoolType, TimestampType, Varchar,
  AutoIncrement, NotNull,
  DefaultBool, DefaultInt, DefaultText, DefaultNow,
  Sqlite, Postgresql, Mysql,
  configure, configureSqlite, connect, close,
  table, load as dbLoad, loadOn, runMigrationsOn, runMigrationSql,
  beginTx, beginTxOn, commitTx, commitTxOn, rollbackTxOn,
  savepoint, savepointOn, releaseSavepoint, rollbackToSavepointOn,
  inTransactionOn,
  applyDelta, applyDeltaOn, chunkDeltas,
  ftsDoc, ftsMatchAny, ftsMatchAll,
  Insert, Delete, Upsert,
  insert, insertOn, rows, first, firstOn, delete, deleteOn, update, updateOn, upsert, upsertOn
)

// Test that types are well-formed

@test "column type construct"
columnType_construct = do Effect {
  ct1 = IntType
  ct2 = BoolType
  ct3 = TimestampType
  ct4 = Varchar 255
  assertEq ct1 IntType
  assertEq ct2 BoolType
  assertEq ct3 TimestampType
  ct4 match
    | Varchar n => assertEq n 255
    | _         => assert False
}

@test "column constraint construct"
columnConstraint_construct = do Effect {
  c1 = AutoIncrement
  c2 = NotNull
  assertEq c1 AutoIncrement
  assertEq c2 NotNull
}

@test "column default construct"
columnDefault_construct = do Effect {
  d1 = DefaultBool True
  d2 = DefaultInt 0
  d3 = DefaultText "hello"
  d4 = DefaultNow
  d1 match
    | DefaultBool value => assertEq value True
    | _                 => assert False
    d2 match
      | DefaultInt value => assertEq value 0
      | _                => assert False
    d3 match
      | DefaultText value => assertEq value "hello"
      | _                 => assert False
    assertEq d4 DefaultNow
}

@test "driver construct"
driver_construct = do Effect {
  d1 = Sqlite
  d2 = Postgresql
  d3 = Mysql
  assertEq d1 Sqlite
  assertEq d2 Postgresql
  assertEq d3 Mysql
}

@test "db config construct"
dbConfig_construct = do Effect {
  cfg = { driver: Sqlite, url: ":memory:" }
  assertEq cfg.driver Sqlite
  assertEq cfg.url ":memory:"
}

@test "column construct"
column_construct = do Effect {
  col =
    {
      name: "id"
      type: IntType
      constraints: [AutoIncrement, NotNull]
      default: None
    }
    assertEq col.name "id"
}

@test "delta construct"
delta_construct = do Effect {
  user        = { id: 1, name: "Alice" }
  insertDelta = Insert user
  deleteDelta = Delete (u => u.id == 1)
  upsertDelta = Upsert (u => u.id == 1) user (u => u <| { name: "Bob" })
  users0      = table "users"[]
  users1 <- applyDelta users0 insertDelta
  users2 <- applyDelta users1 deleteDelta
  users3 <- applyDelta users2 upsertDelta
  rows   <- dbLoad users3
  rows match
    | [row] => do Effect {
        assertEq row.id 1
        assertEq row.name "Alice"
      }
    | _ => assert False
}

@test "sqlite tuning and transaction primitives"
sqlite_tuning_and_tx = do Effect {
  configure { driver: Sqlite, url: ":memory:" }
  configureSqlite { wal: True, busyTimeoutMs: 100 }
  beginTx
  savepoint "s1"
  releaseSavepoint "s1"
  commitTx
  assert True
}

@test "migration sql helper"
migration_sql_helper = do Effect {
  configure { driver: Sqlite, url: ":memory:" }
  runMigrationSql [
    { id: "001-create", sql: "CREATE TABLE IF NOT EXISTS people (id INTEGER PRIMARY KEY, name TEXT NOT NULL);" }
  ]
  assert True
}

@test "explicit connection commit and rollback"
explicit_connection_commit_and_rollback = do Effect {
  conn <- connect { driver: Sqlite, url: ":memory:" }
  users0 = table "users"[]
  _      <- runMigrationsOn conn [users0]
  _      <- beginTxOn conn
  users1 <- applyDeltaOn conn users0 (Insert { id: 1, name: "Alice" })
  _      <- commitTxOn conn
  rows1  <- loadOn conn users1
  assertEq (List.length rows1) 1

  _     <- beginTxOn conn
  _     <- applyDeltaOn conn users1 (Insert { id: 2, name: "Bob" })
  _     <- rollbackTxOn conn
  rows2 <- loadOn conn users0
  _     <- close conn
  assertEq (List.length rows2) 1
}

@test "savepoint rollback on explicit connection"
savepoint_rollback_on_explicit_connection = do Effect {
  conn <- connect { driver: Sqlite, url: ":memory:" }
  users0 = table "savepoint_users"[]
  _      <- runMigrationsOn conn [users0]
  _      <- beginTxOn conn
  users1 <- applyDeltaOn conn users0 (Insert { id: 1, name: "Alpha" })
  _      <- savepointOn conn "after_first"
  _      <- applyDeltaOn conn users1 (Insert { id: 2, name: "Beta" })
  _      <- rollbackToSavepointOn conn "after_first"
  _      <- commitTxOn conn
  rows   <- loadOn conn users0
  _      <- close conn
  assertEq (List.length rows) 1
}

@test "inTransactionOn rolls back on failure"
inTransactionOn_rolls_back_on_failure = do Effect {
  conn <- connect { driver: Sqlite, url: ":memory:" }
  users0 = table "tx_users"[]
  _      <- runMigrationsOn conn [users0]
  result <- attempt (inTransactionOn conn (do Effect {
        _      <- applyDeltaOn conn users0 (Insert { id: 1, name: "Tx" })
        fail "boom"
  }))
  rows <- loadOn conn users0
  _    <- close conn
  assertEq (List.length rows) 0
  result match
    | Err err => assertEq err "boom"
    | Ok _    => assert False
}

@test "delta chunk helper"
delta_chunk_helper = do Effect {
  deltas =
    [
      Insert { id: 1, name: "A" }
      Insert { id: 2, name: "B" }
      Delete (u => u.id == 1)
    ]
  chunks = chunkDeltas 2 deltas
  assertEq (List.length chunks) 2
}

@test "fts helpers"
fts_helpers = do Effect {
  doc      = ftsDoc "doc-1" ["hello", "world"]
  anyQuery = ftsMatchAny ["hello", "world"]
  allQuery = ftsMatchAll ["hello", "world"]
  assertEq doc.docId "doc-1"
  assertEq anyQuery.matchMode "any"
  assertEq allQuery.matchMode "all"
}

@test "insert convenience"
insert_convenience = do Effect {
  users0 = table "insert_users"[]
  users1 <- insert users0 { id: 1, name: "Alice" }
  users2 <- insert users1 { id: 2, name: "Bob" }
  rows   <- dbLoad users2
  assertEq (List.length rows) 2
}

@test "insertOn convenience"
insertOn_convenience = do Effect {
  conn <- connect { driver: Sqlite, url: ":memory:" }
  users0 = table "insertOn_users"[]
  _      <- runMigrationsOn conn [users0]
  users1 <- insertOn conn users0 { id: 1, name: "Alice" }
  rows   <- loadOn conn users1
  _      <- close conn
  assertEq (List.length rows) 1
}

@test "rows selector convenience"
rows_selector_convenience = do Effect {
  users0 = table "rows_users"[]
  users1  <- insert users0 { id: 1, name: "Alice" }
  users2  <- insert users1 { id: 2, name: "Bob" }
  matched <- rows users2[id == 1]
  assertEq (List.length matched) 1
  matched match
    | [row] => assertEq row.name "Alice"
    | _     => assert False
}

@test "selector predicate lifting supports bare bool fields"
selector_predicate_lifting_bool_field = do Effect {
  users0 = table "selector_bool_users"[]
  users1  <- insert users0 { id: 1, name: "Alice", active: True }
  users2  <- insert users1 { id: 2, name: "Bob", active: False }
  matched <- rows users2[active]
  assertEq (List.length matched) 1
  matched match
    | [row] => do Effect {
        assertEq row.name "Alice"
        assertEq row.active True
      }
    | _ => assert False
}

@test "selector predicate lifting supports comparison predicates"
selector_predicate_lifting_comparison = do Effect {
  users0 = table "selector_name_users"[]
  users1 <- insert users0 { id: 1, name: "Alice", active: True }
  users2 <- insert users1 { id: 2, name: "Bob", active: False }
  found  <- first users2[name == "Alice"]
  found match
    | Some row => do Effect {
        assertEq row.id 1
        assertEq row.active True
      }
    | None => assert False
}

@test "firstOn selector convenience"
firstOn_selector_convenience = do Effect {
  conn <- connect { driver: Sqlite, url: ":memory:" }
  users0 = table "firstOn_users"[]
  _      <- runMigrationsOn conn [users0]
  users1 <- insertOn conn users0 { id: 1, name: "Alice" }
  users2 <- insertOn conn users1 { id: 2, name: "Bob" }
  found  <- firstOn conn users2[id == 2]
  _      <- close conn
  found match
    | Some row => assertEq row.name "Bob"
    | None     => assert False
}


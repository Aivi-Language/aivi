@no_prelude
module integrationTests.stdlib.aivi.database.tests

use aivi
use aivi.testing
use aivi.database (
  Relation,
  IntType, BoolType, TimestampType, Varchar,
  AutoIncrement, NotNull,
  DefaultBool, DefaultInt, DefaultText, DefaultNow,
  Sqlite, Postgresql, Mysql,
  configure, configureSqlite, connect, close,
  relation, runMigrations, runMigrationsOn, runMigrationSql,
  beginTx, beginTxOn, commitTx, commitTxOn, rollbackTxOn,
  savepoint, savepointOn, releaseSavepoint, rollbackToSavepointOn,
  inTransactionOn,
  ftsDoc, ftsMatchAny, ftsMatchAll,
  insert, insertOn, rows, rowsOn, first, delete, deleteOn, updateOn, upsert, upsertOn
)

User = { id: Int, name: Text, active: Bool }

users : Relation User
users = relation "users" [
  { name: "id",     type: IntType,     constraints: [AutoIncrement, NotNull], default: None }
  { name: "name",   type: Varchar 120, constraints: [NotNull],                default: None }
  { name: "active", type: BoolType,    constraints: [NotNull],                default: Some (DefaultBool True) }
] []

seedUsersOn = conn => do Effect {
  users1 <- insertOn conn users { id: 1, name: "Alice", active: True }
  users2 <- insertOn conn users1 { id: 2, name: "Bob", active: False }
  pure users2
}

@test "column types constraints defaults and drivers construct"
column_types_constraints_defaults_and_drivers_construct = do Effect {
  assertEq IntType IntType
  assertEq BoolType BoolType
  assertEq TimestampType TimestampType
  assertEq (Varchar 255) (Varchar 255)
  assertEq AutoIncrement AutoIncrement
  assertEq NotNull NotNull
  assertEq (DefaultBool True) (DefaultBool True)
  assertEq (DefaultInt 0) (DefaultInt 0)
  assertEq (DefaultText "hello") (DefaultText "hello")
  assertEq DefaultNow DefaultNow
  assertEq Sqlite Sqlite
  assertEq Postgresql Postgresql
  assertEq Mysql Mysql
}

@test "relation values keep schema metadata"
relation_values_keep_schema_metadata = do Effect {
  assertEq users.name "users"
  assertEq (List.length users.columns) 3
}

@test "sqlite tuning and ambient transaction primitives"
sqlite_tuning_and_ambient_transaction_primitives = do Effect {
  configure { driver: Sqlite, url: ":memory:" }
  configureSqlite { wal: True, busyTimeoutMs: 100 }
  beginTx
  savepoint "before_seed"
  releaseSavepoint "before_seed"
  commitTx
  assert True
}

@test "migration sql helper"
migration_sql_helper = do Effect {
  configure { driver: Sqlite, url: ":memory:" }
  runMigrationSql [
    {
      id: "001-create"
      sql: "CREATE TABLE IF NOT EXISTS notes (id INTEGER PRIMARY KEY, title TEXT NOT NULL);"
    }
  ]
  assert True
}

@test "explicit connection commit and rollback"
explicit_connection_commit_and_rollback = do Effect {
  conn <- connect { driver: Sqlite, url: ":memory:" }
  _    <- runMigrationsOn conn [users]

  _           <- beginTxOn conn
  users1      <- insertOn conn users { id: 1, name: "Alice", active: True }
  _           <- commitTxOn conn
  afterCommit <- rowsOn conn users1
  assertEq (List.length afterCommit) 1

  _             <- beginTxOn conn
  _             <- insertOn conn users1 { id: 2, name: "Bob", active: False }
  _             <- rollbackTxOn conn
  afterRollback <- rowsOn conn users1
  _             <- close conn
  assertEq (List.length afterRollback) 1
}

@test "savepoint rollback on explicit connection"
savepoint_rollback_on_explicit_connection = do Effect {
  conn      <- connect { driver: Sqlite, url: ":memory:" }
  _         <- runMigrationsOn conn [users]
  _         <- beginTxOn conn
  users1    <- insertOn conn users { id: 1, name: "Alpha", active: True }
  _         <- savepointOn conn "after_first"
  _         <- insertOn conn users1 { id: 2, name: "Beta", active: False }
  _         <- rollbackToSavepointOn conn "after_first"
  _         <- commitTxOn conn
  persisted <- rowsOn conn users1
  _         <- close conn
  assertEq (List.length persisted) 1
}

@test "inTransactionOn rolls back on failure"
inTransactionOn_rolls_back_on_failure = do Effect {
  conn   <- connect { driver: Sqlite, url: ":memory:" }
  _      <- runMigrationsOn conn [users]
  result <- attempt (inTransactionOn conn (do Effect {
        _      <- insertOn conn users { id: 1, name: "Tx", active: True }
        fail "boom"
  }))
  persisted <- rowsOn conn users
  _         <- close conn
  assertEq (List.length persisted) 0
  result match
    | Err err => assertEq err "boom"
    | Ok _    => assert False
}

@test "ambient rows and first helpers"
ambient_rows_and_first_helpers = do Effect {
  configure { driver: Sqlite, url: ":memory:" }
  _           <- runMigrations [users]
  users1      <- insert users { id: 1, name: "Alice", active: True }
  _           <- insert users1 { id: 2, name: "Bob", active: False }
  activeUsers <- rows users[active]
  firstBob    <- first users[name == "Bob"]
  assertEq (List.length activeUsers) 1
  firstBob match
    | Some user => assertEq user.id 2
    | None      => assert False
}

@test "delete and deleteOn helpers remove matched rows"
delete_and_deleteOn_helpers_remove_matched_rows = do Effect {
  configure { driver: Sqlite, url: ":memory:" }
  _                <- runMigrations [users]
  users1           <- insert users { id: 1, name: "Alice", active: True }
  _                <- insert users1 { id: 2, name: "Bob", active: False }
  _                <- delete users[id == 1]
  remainingAmbient <- rows users
  assertEq (List.length remainingAmbient) 1

  conn              <- connect { driver: Sqlite, url: ":memory:" }
  _                 <- runMigrationsOn conn [users]
  _                 <- seedUsersOn conn
  _                 <- deleteOn conn users[id == 2]
  remainingExplicit <- rowsOn conn users
  _                 <- close conn
  assertEq (List.length remainingExplicit) 1
}

@test "patch shorthand update and updateOn apply record patches"
patch_shorthand_update_and_updateOn_apply_record_patches = do Effect {
  configure { driver: Sqlite, url: ":memory:" }
  _           <- runMigrations [users]
  _           <- insert users { id: 1, name: "Alice", active: True }
  _           <- users[id == 1] <| { name: "Alicia" }
  ambientRows <- rows users
  ambientRows match
    | [user] => assertEq user.name "Alicia"
    | _      => assert False

  conn         <- connect { driver: Sqlite, url: ":memory:" }
  _            <- runMigrationsOn conn [users]
  _            <- insertOn conn users { id: 1, name: "Alice", active: True }
  _            <- updateOn conn users[id == 1] { name: "Alicia" }
  explicitRows <- rowsOn conn users
  _            <- close conn
  explicitRows match
    | [user] => assertEq user.name "Alicia"
    | _      => assert False
}

@test "upsert and upsertOn insert then update"
upsert_and_upsertOn_insert_then_update = do Effect {
  configure { driver: Sqlite, url: ":memory:" }
  _           <- runMigrations [users]
  _           <- upsert users[id == 99] { id: 99, name: "New", active: True } { name: "Updated" }
  _           <- upsert users[id == 99] { id: 99, name: "Unused", active: False } { name: "Updated" }
  ambientRows <- rows users
  ambientRows match
    | [user] => assertEq user.name "Updated"
    | _      => assert False

  conn         <- connect { driver: Sqlite, url: ":memory:" }
  _            <- runMigrationsOn conn [users]
  _            <- upsertOn conn users[id == 1] { id: 1, name: "Alice", active: True } { name: "Alicia" }
  _            <- upsertOn conn users[id == 1] { id: 1, name: "Unused", active: False } { name: "Alicia" }
  explicitRows <- rowsOn conn users
  _            <- close conn
  explicitRows match
    | [user] => assertEq user.name "Alicia"
    | _      => assert False
}

@test "fts helpers build portable query values"
fts_helpers_build_portable_query_values = do Effect {
  doc      = ftsDoc "doc-1" ["hello", "world"]
  anyQuery = ftsMatchAny ["hello", "world"]
  allQuery = ftsMatchAll ["hello", "world"]
  assertEq doc.docId "doc-1"
  assertEq anyQuery.matchMode "any"
  assertEq allQuery.matchMode "all"
}

@test "update selector shorthand"
update_selector_shorthand = do Effect {
  users0 = table "update_selector_users"[]
  users1 <- insert users0 { id: 1, name: "Alice" }
  users2 <- users1[id == 1] <| { name: "Alicia" }
  rows   <- dbLoad users2
  rows match
    | [row] => assertEq row.name "Alicia"
    | _     => assert False
}


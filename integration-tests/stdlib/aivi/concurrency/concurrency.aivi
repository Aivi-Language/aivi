@no_prelude
module integrationTests.stdlib.aivi.concurrency.tests

use aivi
use aivi.prelude
use aivi.testing
use aivi.concurrency
use aivi.reactive

@test "channel roundtrip"
channel_roundtrip = do Effect {
  (tx, rx) <- make True
  send tx True
  res <- recv rx
  res match
    | Ok payload => assertEq payload True
    | Err _      => assert False
    close tx
}

@test "close drains then Err Closed"
close_drains_then_closed = do Effect {
  (tx, rx) <- make True
  send tx True
  close tx
  first  <- recv rx
  second <- recv rx
  first match
    | Ok payload => assertEq payload True
    | Err _      => assert False
    second match
      | Ok _       => assert False
      | Err Closed => assert True
}

@test "makeBounded roundtrip"
make_bounded_roundtrip = do Effect {
  (tx, rx) <- makeBounded 1
  send tx 7
  res <- recv rx
  res match
    | Ok value => assertEq value 7
    | Err _    => assert False
    close tx
}

@test "fold accumulates"
fold_accumulates = do Effect {
  (tx, rx) <- make 0
  send tx 1
  send tx 2
  send tx 3
  close tx
  total <- fold 0 (acc => x => pure (acc + x)) rx
  assertEq total 6
}

@test "fold returns init on empty"
fold_empty = do Effect {
  (tx, rx) <- make 0
  close tx
  result <- fold 42 (acc => _ => pure (acc + 1)) rx
  assertEq result 42
}

@test "forEach processes in order"
forEach_order = do Effect {
  (tx, rx)       <- make 0
  (outTx, outRx) <- make 0
  send tx 10
  send tx 20
  close tx
  forEach rx (x => send outTx x)
  close outTx
  first  <- recv outRx
  second <- recv outRx
  first match
    | Ok v  => assertEq v 10
    | Err _ => assert False
    second match
      | Ok v  => assertEq v 20
      | Err _ => assert False
}

@test "par returns both"
par_success = do Effect {
  pair <- par (pure 1) (pure 2)
  pair match
    | (left, right) => assertEq (left + right) 3
}

@test "par propagates failure"
par_failure = do Effect {
  res <- attempt (par (pure 1) (fail "boom"))
  res match
    | Ok _    => assert False
    | Err msg => assertEq msg "boom"
}

@test "race picks faster right"
race_right_wins = do Effect {
  slow = _ => do Effect {
    sleep 50
    pure "left"
  }
  fast = _ => do Effect {
    sleep 0
    pure "right"
  }
  v <- race (slow Unit) (fast Unit)
  assertEq v "right"
}

@test "race picks faster left"
race_left_wins = do Effect {
  fast = _ => do Effect {
    sleep 0
    pure "left"
  }
  slow = _ => do Effect {
    sleep 50
    pure "right"
  }
  v <- race (fast Unit) (slow Unit)
  assertEq v "left"
}

@test "timeoutWith times out"
timeout_times_out = do Effect {
  inner = _ => do Effect {
    sleep 50
    pure 1
  }
  result <- attempt (timeoutWith 10 "timeout" (inner Unit))
  result match
    | Ok _      => assert False
    | Err value => assertEq value "timeout"
}

@test "timeoutWith returns when effect wins"
timeout_success = do Effect {
  value <- timeoutWith 50 "timeout" (pure 9)
  assertEq value 9
}

@test "spawn join"
spawn_join = do Effect {
  delayed = _ => do Effect {
    sleep 10
    pure 42
  }
  task  <- spawn (delayed Unit)
  value <- task.join
  assertEq value 42
}

@test "spawn cancel sets isCancelled"
spawn_cancel = do Effect {
  longRunning = _ => do Effect {
    sleep 1000
    pure 1
  }
  task <- spawn (longRunning Unit)
  _    <- task.cancel
  b    <- task.isCancelled
  assertEq b True
}

@test "spawned ticker updates a signal every 100ms"
spawned_ticker_updates_signal = do Effect {
  ticks = signal 0
  (tx, rx) <- make 0
  _watcher = watch ticks (value => send tx value)

  task <- spawn (do Effect {
      loop remaining = 3 => {
        if remaining == 0 then pure Unit
        else do Effect {
          sleep 100
          _ = update ticks (_ + 1)
          recurse (remaining - 1)
        }
      }
  })
  first  <- timeoutWith 250 "missing first tick" (recv rx)
  second <- timeoutWith 250 "missing second tick" (recv rx)
  third  <- timeoutWith 250 "missing third tick" (recv rx)
  _      <- task.join

  first match
    | Ok value => assertEq value 1
    | Err _    => assert False
    second match
      | Ok value => assertEq value 2
      | Err _    => assert False
    third match
      | Ok value => assertEq value 3
      | Err _    => assert False

  assertEq (get ticks) 3
  close tx
}

@test "two spawned threads can collect delayed computations"
spawn_collects_delayed_computations = do Effect {
  (tx, rx) <- make 0

  worker = value => delay => do Effect {
    sleep delay
    send tx value
    pure value
  }

  slowTask <- spawn (worker 2 140)
  fastTask <- spawn (worker 1 40)
  first    <- timeoutWith 200 "missing fast worker result" (recv rx)
  second   <- timeoutWith 300 "missing slow worker result" (recv rx)
  slow     <- slowTask.join
  fast     <- fastTask.join

  first match
    | Ok value => assertEq value 1
    | Err _    => assert False
    second match
      | Ok value => assertEq value 2
      | Err _    => assert False

  assertEq (slow + fast) 3
  close tx
}

@test "retry succeeds after transient failures"
retry_eventual_success = do Effect {
  (tx, rx) <- make 0
  send tx 0

  step = _ => do Effect {
    res <- recv rx
    res match
      | Err _ => fail "closed"
      | Ok n  =>
        if n < 2 then do Effect {
          send tx (n + 1)
          fail "no"
        }
        else pure n
  }

    value <- retry 5 (step Unit)
    assertEq value 2
    close tx
}

@test "multiple spawned threads can coordinate signal updates through a channel"
multiple_threads_coordinate_signal_updates_through_channel = do Effect {
  counter = signal 0
  (tx, rx) <- make 0

  worker = _ => do Effect {
    loop remaining = 10 => {
      if remaining == 0 then pure Unit
      else do Effect {
        send tx 1
        recurse (remaining - 1)
      }
    }
  }

  t1 <- spawn (worker Unit)
  t2 <- spawn (worker Unit)
  t3 <- spawn (worker Unit)
  _  <- t1.join
  _  <- t2.join
  _  <- t3.join
  close tx

  forEach rx (delta => do Effect {
      _ = update counter (_ + delta)
      pure Unit
  })

  assertEq (get counter) 30
}

@test "derived signal reflects final value after concurrent writes"
derived_reflects_final_after_concurrent = do Effect {
  base    = signal 0
  doubled = derive base (_ * 2)

  task <- spawn (do Effect {
      loop remaining = 5 => {
        if remaining == 0 then pure Unit
        else do Effect {
          _ = update base (_ + 1)
          recurse (remaining - 1)
        }
      }
  })
  _ <- task.join

  assertEq (get base) 5
  assertEq (get doubled) 10
}

@test "watcher fires for cross-thread signal updates via channel"
watcher_fires_cross_thread = do Effect {
  count = signal 0
  (tx, rx) <- make 0
  _watcher = watch count (value => send tx value)

  task <- spawn (do Effect {
      _ = set count 7
      pure Unit
  })
  _ <- task.join

  result <- timeoutWith 500 "missing watcher notification" (recv rx)
  result match
    | Ok value => assertEq value 7
    | Err _    => assert False
    close tx
}

@test "batch from spawned thread delivers consistent derived state"
batch_from_spawned_thread = do Effect {
  a     = signal 1
  b     = signal 2
  total = combineAll (a, b) ((x, y) => x + y)

  task <- spawn (do Effect {
      _ = batch (_ => {
          set a 10
          set b 20
      })
      pure Unit
  })
  _ <- task.join

  assertEq (get total) 30
}

@test "concurrent combineAll with many sources"
concurrent_combineAll_many_sources = do Effect {
  s1    = signal 0
  s2    = signal 0
  s3    = signal 0
  s4    = signal 0
  total = combineAll (s1, s2, s3, s4) ((a, b, c, d) => a + b + c + d)

  t1 <- spawn (do Effect {
      _ = set s1 10
      pure Unit
  })
  t2 <- spawn (do Effect {
      _ = set s2 20
      pure Unit
  })
  t3 <- spawn (do Effect {
      _ = set s3 30
      pure Unit
  })
  t4 <- spawn (do Effect {
      _ = set s4 40
      pure Unit
  })
  _ <- t1.join
  _ <- t2.join
  _ <- t3.join
  _ <- t4.join

  assertEq (get total) 100
}

@test "retry fails after attempts"
retry_failure = do Effect {
  (tx, rx) <- make 0
  send tx 0

  step = _ => do Effect {
    res <- recv rx
    res match
      | Err _ => fail "closed"
      | Ok n  => do Effect {
          send tx (n + 1)
          fail "no"
        }
  }

  result <- attempt (retry 2 (step Unit))
  result match
    | Ok _    => assert False
    | Err msg => assertEq msg "no"
    close tx
}

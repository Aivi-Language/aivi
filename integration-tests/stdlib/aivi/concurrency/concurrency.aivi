@no_prelude
module integrationTests.stdlib.aivi.concurrency.tests

use aivi
use aivi.testing
use aivi.concurrency
use aivi.reactive

withChannel : A -> ((Send A, Recv A) -> Effect Text B) -> Effect Text B
withChannel = initial => run =>
  make initial
    |> run

withBoundedChannel : Int -> ((Send A, Recv A) -> Effect Text B) -> Effect Text B
withBoundedChannel = size => run =>
  makeBounded size
    |> run

sleepThen : Int -> A -> Effect Text A
sleepThen = millis => value => {
  sleep millis
  pure value
}

setSignalTo : Signal Int -> Int -> Effect Text Unit
setSignalTo = sig => value => {
  _ = set sig value
  pure Unit
}

updateSignalBy : Signal Int -> Int -> Effect Text Unit
updateSignalBy = sig => delta => {
  _ = update sig (_ + delta)
  pure Unit
}

tickSignalNTimes : Signal Int -> Int -> Effect Text Unit
tickSignalNTimes = ticks => remaining =>
  if remaining == 0 then pure Unit
  else {
    sleep 100
    updateSignalBy ticks 1
    tickSignalNTimes ticks (remaining - 1)
  }

sendUnitNTimes : Send Int -> Int -> Effect Text Unit
sendUnitNTimes = tx => remaining =>
  if remaining == 0 then pure Unit
  else {
    send tx 1
    sendUnitNTimes tx (remaining - 1)
  }

incrementSignalNTimes : Signal Int -> Int -> Effect Text Unit
incrementSignalNTimes = sig => remaining =>
  if remaining == 0 then pure Unit
  else {
    updateSignalBy sig 1
    incrementSignalNTimes sig (remaining - 1)
  }

assertRecvOk : A -> Result ChannelError A -> Effect Text Unit
assertRecvOk = expected => result => result match
  | Ok value => assertEq value expected
  | Err _    => assert False

assertClosed : Result ChannelError A -> Effect Text Unit
assertClosed = result => result match
  | Ok _       => assert False
  | Err Closed => assert True

@test "channel roundtrip"
channel_roundtrip = withChannel True ((tx, rx) => {
  send tx True
  recv rx
    |> res => {
      close tx
      assertRecvOk True res
    }
})

@test "close drains then Err Closed"
close_drains_then_closed = withChannel True ((tx, rx) => {
  send tx True
  close tx
  recv rx
    |> first =>
         recv rx
           |> second => {
             assertRecvOk True first
             assertClosed second
           }
})

@test "makeBounded roundtrip"
make_bounded_roundtrip = withBoundedChannel 1 ((tx, rx) => {
  send tx 7
  recv rx
    |> res => {
      close tx
      assertRecvOk 7 res
    }
})

@test "fold accumulates"
fold_accumulates = withChannel 0 ((tx, rx) => {
  send tx 1
  send tx 2
  send tx 3
  close tx
  fold 0 (acc => x => pure (acc + x)) rx
    |> assertEq 6
})

@test "fold returns init on empty"
fold_empty = withChannel 0 ((tx, rx) => {
  close tx
  fold 42 (acc => _ => pure (acc + 1)) rx
    |> assertEq 42
})

@test "forEach processes in order"
forEach_order = withChannel 0 ((tx, rx) =>
  withChannel 0 ((outTx, outRx) => {
    send tx 10
    send tx 20
    close tx
    forEach rx (x => send outTx x)
    close outTx
    recv outRx
      |> first =>
           recv outRx
             |> second => {
               assertRecvOk 10 first
               assertRecvOk 20 second
             }
  })
)

@test "par returns both"
par_success =
  par (pure 1) (pure 2)
    |> ((left, right) => assertEq (left + right) 3)

@test "par propagates failure"
par_failure =
  attempt (par (pure 1) (fail "boom"))
    |> res => res match
      | Ok _    => assert False
      | Err msg => assertEq msg "boom"

@test "race picks faster right"
race_right_wins = {
  slow = _ => sleepThen 50 "left"
  fast = _ => sleepThen 0 "right"

  race (slow Unit) (fast Unit)
    |> assertEq "right"
}

@test "race picks faster left"
race_left_wins = {
  fast = _ => sleepThen 0 "left"
  slow = _ => sleepThen 50 "right"

  race (fast Unit) (slow Unit)
    |> assertEq "left"
}

@test "timeoutWith times out"
timeout_times_out = {
  inner = _ => sleepThen 50 1

  attempt (timeoutWith 10 "timeout" (inner Unit))
    |> result => result match
      | Ok _      => assert False
      | Err value => assertEq value "timeout"
}

@test "timeoutWith returns when effect wins"
timeout_success =
  timeoutWith 50 "timeout" (pure 9)
    |> assertEq 9

@test "spawn join"
spawn_join = {
  delayed = _ => sleepThen 10 42

  spawn (delayed Unit)
    |> task => task.join
    |> assertEq 42
}

@test "spawn cancel sets isCancelled"
spawn_cancel = {
  longRunning = _ => sleepThen 1000 1

  spawn (longRunning Unit)
    |> task => {
      task.cancel
      task.isCancelled
    }
    |> assertEq True
}

@test "spawned ticker updates a signal every 100ms"
spawned_ticker_updates_signal = withChannel 0 ((tx, rx) => {
  ticks    = signal 0
  _watcher = watch ticks (value => send tx value)

  checkTicks = task =>
    timeoutWith 250 "missing first tick" (recv rx)
      |> first =>
           timeoutWith 250 "missing second tick" (recv rx)
             |> second =>
                  timeoutWith 250 "missing third tick" (recv rx)
                    |> third => {
                      task.join
                      assertRecvOk 1 first
                      assertRecvOk 2 second
                      assertRecvOk 3 third
                      close tx
                      assertEq (get ticks) 3
                    }

  spawn (tickSignalNTimes ticks 3)
    |> checkTicks
})

@test "two spawned threads can collect delayed computations"
spawn_collects_delayed_computations = withChannel 0 ((tx, rx) => {
  worker = value => delay => {
    sleep delay
    send tx value
    pure value
  }

  spawn (worker 2 140)
    ~|> slowTask => spawn (worker 1 40)#fastTask
    ~|> slowTask => timeoutWith 200 "missing fast worker result" (recv rx)#first
    ~|> slowTask => timeoutWith 300 "missing slow worker result" (recv rx)#second
    ~|> slowTask => fastTask.join#fast
    ~|> slowTask => slowTask.join#slow
    ~|> slowTask => assertRecvOk 1 first
    ~|> slowTask => assertRecvOk 2 second
    ~|> slowTask => close tx
     |> slowTask => assertEq (slow + fast) 3
})

@test "retry succeeds after transient failures"
retry_eventual_success = withChannel 0 ((tx, rx) => {
  step = _ =>
    recv rx
      |> res => res match
        | Err _ => fail "closed"
        | Ok n  =>
            if n < 2 then {
              send tx (n + 1)
              fail "no"
            } else pure n

  send tx 0
  retry 5 (step Unit)
    |> value => {
      assertEq value 2
      close tx
    }
})

@test "multiple spawned threads can coordinate signal updates through a channel"
multiple_threads_coordinate_signal_updates_through_channel = withChannel 0 ((tx, rx) => {
  counter = signal 0

  awaitWorkers = t1 => t2 => t3 => {
    t1.join
    t2.join
    t3.join
    close tx
    forEach rx (delta => updateSignalBy counter delta)
    assertEq (get counter) 30
  }

  startThirdWorker = t1 => t2 =>
    spawn (sendUnitNTimes tx 10)
      |> t3 => awaitWorkers t1 t2 t3

  startSecondWorker = t1 =>
    spawn (sendUnitNTimes tx 10)
      |> t2 => startThirdWorker t1 t2

  spawn (sendUnitNTimes tx 10)
    |> startSecondWorker
})

@test "derived signal reflects final value after concurrent writes"
derived_reflects_final_after_concurrent = {
  base    = signal 0
  doubled = derive base (_ * 2)

  spawn (incrementSignalNTimes base 5)
    |> task => {
      task.join
      assertEq (get base) 5
      assertEq (get doubled) 10
    }
}

@test "watcher fires for cross-thread signal updates via channel"
watcher_fires_cross_thread = withChannel 0 ((tx, rx) => {
  count    = signal 0
  _watcher = watch count (value => send tx value)
  work     = setSignalTo count 7

  spawn work
    |> task => {
      task.join
      timeoutWith 500 "missing watcher notification" (recv rx)
        |> result => {
          close tx
          result match
            | Ok value => assertEq value 7
            | Err _    => assert False
        }
    }
})

@test "batch from spawned thread delivers consistent derived state"
batch_from_spawned_thread = {
  a     = signal 1
  b     = signal 2
  total = combineAll (a, b) ((x, y) => x + y)

  applyBatch = _ => {
    _ = batch (_ => {
      set a 10
      set b 20
    })
    pure Unit
  }

  spawn (applyBatch Unit)
    |> task => {
      task.join
      assertEq (get total) 30
    }
}

@test "concurrent combineAll with many sources"
concurrent_combineAll_many_sources = {
  s1    = signal 0
  s2    = signal 0
  s3    = signal 0
  s4    = signal 0
  total = combineAll (s1, s2, s3, s4) ((a, b, c, d) => a + b + c + d)

  awaitAll = t1 => t2 => t3 => t4 => {
    t1.join
    t2.join
    t3.join
    t4.join
    assertEq (get total) 100
  }

  startFourth = t1 => t2 => t3 =>
    spawn (setSignalTo s4 40)
      |> t4 => awaitAll t1 t2 t3 t4

  startThird = t1 => t2 =>
    spawn (setSignalTo s3 30)
      |> t3 => startFourth t1 t2 t3

  startSecond = t1 =>
    spawn (setSignalTo s2 20)
      |> t2 => startThird t1 t2

  spawn (setSignalTo s1 10)
    |> startSecond
}

@test "retry fails after attempts"
retry_failure = withChannel 0 ((tx, rx) => {
  step = _ =>
    recv rx
      |> res => res match
        | Err _ => fail "closed"
        | Ok n  => {
            send tx (n + 1)
            fail "no"
          }

  send tx 0
  attempt (retry 2 (step Unit))
    |> result => {
      close tx
      result match
        | Ok _    => assert False
        | Err msg => assertEq msg "no"
    }
})

@test "spawn join repeats settled result"
spawn_join_repeats_settled_result = {
  spawn (pure 42)
    ~|> task => task.join#first
    ~|> task => timeoutWith 100 "timeout" (task.join)#second
    ~|> task => task.join#third
    ~|> task => assertEq [first, second, third] [42, 42, 42]
     |> task => task.join
     |> assertEq 42
}

@test "par fails fast without waiting for cancelled branch"
par_fails_fast = withChannel 0 ((tx, rx) => {
  blocked = _ => {
    recv rx
    pure 2
  }

  attempt (timeoutWith 50 "timeout" (par (fail "boom") (blocked Unit)))
    |> result => {
      close tx
      result match
        | Ok _    => assert False
        | Err msg => assertEq msg "boom"
    }
})

@test "race returns winner without waiting for cancelled branch"
race_returns_winner_immediately = withChannel 0 ((tx, rx) => {
  blocked = _ => {
    recv rx
    pure "blocked"
  }

  timeoutWith 50 "timeout" (race (pure "winner") (blocked Unit))
    |> value => {
      close tx
      assertEq value "winner"
    }
})

@test "scope cancels spawned children on exit"
scope_cancels_spawned_children_on_exit = withChannel 0 ((tx, rx) => {
  child = {
    sleep 200
    send tx 1
  }

  scope (_ => {
    spawn child
    pure Unit
  })
  attempt (timeoutWith 100 "timeout" (recv rx))
    |> result => {
      close tx
      result match
        | Ok _    => assert False
        | Err msg => assertEq msg "timeout"
    }
})

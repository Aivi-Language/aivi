@no_prelude
module integrationTests.stdlib.aivi.ui.forms.tests

use aivi
use aivi.testing
use aivi.validation
use aivi.ui.forms
use aivi.ui.gtk4

Contact = {
  name: Text
  email: Text
}

State = {
  submitted: Bool
  name: Field Text
  email: Field Text
}

initialState : State
initialState = {
  submitted: False
  name: field ""
  email: field ""
}

nameRule : Text -> Validation (List Text) Text
nameRule = allOf [required, minLength 2]

emailRule : Text -> Validation (List Text) Text
emailRule = allOf [required, email]

nameErrors : State -> List Text
nameErrors = s => visibleErrors s.submitted nameRule s.name

emailErrors : State -> List Text
emailErrors = s => visibleErrors s.submitted emailRule s.email

MkContact : Text -> Text -> Contact
MkContact = name email => {
  name: name
  email: email
}

contactValidation : State -> Validation (List Text) Contact
contactValidation = s => ap (ap (Valid MkContact) (validate nameRule s.name)) (validate emailRule s.email)

@test "fields start pristine and hide errors"
fields_start_pristine = {
  assertEq initialState.name (field "")
  assertEq initialState.email (field "")
  assertEq (nameErrors initialState) []
  assertEq (emailErrors initialState) []
}

@test "input change marks field dirty but not touched"
input_change_marks_dirty = {
  s = initialState <| { name: setValue "A" initialState.name }
  assertEq s.name.value "A"
  assertEq s.name.dirty True
  assertEq s.name.touched False
  assertEq (nameErrors s) []
}

@test "blur reveals field validation"
blur_reveals_validation = {
  changed = initialState <| { name: setValue "A" initialState.name }
  blurred = changed <| { name: touch changed.name }
  assertEq blurred.name.touched True
  assertEq (nameErrors blurred) ["Must be at least 2 characters"]
}

@test "submit reveals untouched field errors"
submit_reveals_errors = {
  submitted = initialState <| { submitted: True }
  assertEq submitted.submitted True
  assertEq (nameErrors submitted) ["This field is required"]
  assertEq (emailErrors submitted) ["This field is required"]
}

@test "valid form produces typed payload"
valid_form_payload = {
  s      = initialState <| { name: setValue "Alice" initialState.name } <| { email: setValue "alice@example.com" initialState.email }
  result = contactValidation s
  assertEq result (Valid { name: "Alice", email: "alice@example.com" })
}

@test "form validation accumulates field errors"
form_validation_accumulates_errors = {
  s      = initialState <| { name: setValue "A" initialState.name } <| { email: setValue "not-an-email" initialState.email }
  result = contactValidation s
  assertEq result (Invalid ["Must be at least 2 characters", "Enter a valid email address"])
}

@test "gtk signal callbacks invoke field updates directly"
gtk_signal_callbacks_update_fields = {
  onNameChange  = txt => st => st <| { name: setValue txt st.name }
  onEmailChange = txt => st => st <| { email: setValue txt st.email }
  onNameBlur    = st => st <| { name: touch st.name }
  onEmailBlur   = st => st <| { email: touch st.email }
  onSubmit      = st => st <| { submitted: True }
  s0            = onNameChange "Ada" initialState
  assertEq s0.name.value "Ada"
  s1 = onEmailChange "ada@example.com" s0
  assertEq s1.email.value "ada@example.com"
  s2 = onNameBlur s0
  assertEq s2.name.touched True
  s3 = onSubmit initialState
  assertEq s3.submitted True
}

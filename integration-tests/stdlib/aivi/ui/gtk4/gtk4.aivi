@test "GtkCenterBox node is constructable"
gtk_center_box_node = do Effect {
  startChild  = gtkElement "GtkLabel" [gtkAttr "label" "Left"] []
  centerChild = gtkElement "GtkLabel" [gtkAttr "label" "Center"] []
  endChild    = gtkElement "GtkLabel" [gtkAttr "label" "Right"] []
  elem        = gtkElement "GtkCenterBox" [] [startChild, centerChild, endChild]
  getTag      = n => n match
    | GtkElement tag _ _ => tag
    | _                  => ""
    assertEq (getTag elem) "GtkCenterBox"
}

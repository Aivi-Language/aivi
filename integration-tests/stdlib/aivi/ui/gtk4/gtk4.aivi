@test "GtkCenterBox node is constructable"
gtk_center_box_node = do Effect {
  startChild  = gtkElement "GtkLabel" [] []
  centerChild = gtkElement "GtkLabel" [] []
  endChild    = gtkElement "GtkLabel" [] []
  elem        = gtkElement "GtkCenterBox" [] [startChild, centerChild, endChild]
  tag         = elem match
    | GtkElement name _ _ => name
    | _                   => ""
    assertEq tag "GtkCenterBox"
}

@no_prelude
module integrationTests.stdlib.aivi.ui.gtk4.tests

use aivi
use aivi.list as List
use aivi.testing
use aivi.ui.gtk4

getClickedPair = event => event match
  | GtkClicked wid name => (wid, name)
  | _                   => (0, "")

getInputTriple = event => event match
  | GtkInputChanged wid name txt => (wid, name, txt)
  | _                            => (0, "", "")

getToggledTriple = event => event match
  | GtkToggled wid name active => (wid, name, active)
  | _                          => (0, "", False)

getFocusPair = event => event match
  | GtkFocusIn wid name => (wid, name)
  | _                   => (0, "")

TestMsg      = Save | NameChanged Text | ToggledMsg Bool
TestMsg2     = TitleChanged Text | BodyChanged Text
DerivedRow   = { name: Text }
DerivedModel = { title: Text, rows: List DerivedRow }

toTestMsg = event => event match
  | GtkClicked _ _          => Some Save
  | GtkInputChanged _ _ txt => Some (NameChanged txt)
  | GtkToggled _ _ active   => Some (ToggledMsg active)
  | _                       => None

toTestMsg2 = event => event match
  | GtkInputChanged _ "titleInput" txt => Some (TitleChanged txt)
  | GtkInputChanged _ "bodyInput" txt  => Some (BodyChanged txt)
  | _                                  => None

titleDerived : DerivedModel -> Text
titleDerived =
  memo "gtk4.tests.titleDerived" (state =>
    "Title: {state.title}"
  )

rowDerived : DerivedModel -> List DerivedRow
rowDerived =
  derive (state => state.rows)

derivedView : DerivedModel -> GtkNode
derivedView = _ =>
  ~<gtk>
    <GtkBox orientation="vertical" spacing="4">
      <GtkLabel label={titleDerived} />
      <each items={rowDerived} as={row}>
        <GtkLabel label={row.name} />
      </each>
    </GtkBox>
  </gtk>

@test "GtkClicked carries widget name"
signal_clicked = do Effect {
  assertEq (getClickedPair (GtkClicked 1 "saveBtn")) (1, "saveBtn")
}

@test "GtkInputChanged carries widget name and text"
signal_input_changed = do Effect {
  assertEq (getInputTriple (GtkInputChanged 2 "nameInput" "hello")) (2, "nameInput", "hello")
}

@test "GtkToggled carries widget name and bool"
signal_toggled = do Effect {
  assertEq (getToggledTriple (GtkToggled 3 "checkBox" True)) (3, "checkBox", True)
}

@test "GtkFocusIn carries widget name"
signal_focus = do Effect {
  assertEq (getFocusPair (GtkFocusIn 4 "entry")) (4, "entry")
}

@test "GtkSignalEvent pattern matching with wildcard widget id"
signal_event_pattern_matching = do Effect {
  assertEq (toTestMsg (GtkClicked 1 "btn")) (Some Save)
  assertEq (toTestMsg (GtkInputChanged 2 "inp" "hi")) (Some (NameChanged "hi"))
  assertEq (toTestMsg (GtkToggled 3 "chk" True)) (Some (ToggledMsg True))
  assertEq (toTestMsg (GtkFocusIn 4 "x")) None
}

@test "GtkSignalEvent match by widget name"
signal_event_match_by_name = do Effect {
  assertEq (toTestMsg2 (GtkInputChanged 1 "titleInput" "hi")) (Some (TitleChanged "hi"))
  assertEq (toTestMsg2 (GtkInputChanged 2 "bodyInput" "lo")) (Some (BodyChanged "lo"))
  assertEq (toTestMsg2 (GtkInputChanged 3 "other" "x")) None
}

@test "GtkNode constructors"
gtk_node_constructors = do Effect {
  elem   = gtkElement "GtkBox" [gtkAttr "spacing" "8"] [gtkTextNode "hello"]
  getTag = n => n match
    | GtkElement tag _ _ => tag
    | _                  => ""
    assertEq (getTag elem) "GtkBox"
}

@test "gtk4 helper constructors are accessible"
type_signatures = do Effect {
  node = gtkElement "GtkBox" [gtkAttr "spacing" "8", gtkSignalAttr "clicked" Save] []
  assertEq node (gtkElement "GtkBox" [gtkAttr "spacing" "8", gtkSignalAttr "clicked" Save] [])
}

@test "app step helpers build blessed update values"
app_step_helpers = do Effect {
  bare        = appStep 3
  withCommand = appStepWith 4 [commandEmit Save]

  assertEq bare.model 3
  assertEq bare.commands []
  assertEq withCommand.model 4
  assertEq (List.length withCommand.commands) 1
}

@test "command and subscription helper constructors are available"
command_and_subscription_shapes = do Effect {
  command = commandAfter {
    key: "tick"
    millis: 100
    msg: Save
  }
  subscription = subscriptionEvery {
    key: "clock"
    millis: 250
    tag: Save
  }

  step = appStepWith 1 [command]
  assertEq (List.length step.commands) 1
  assertEq (List.length [subscription]) 1
}

@test "memo remains callable as a pure derived helper"
memo_pure_helper = do Effect {
  doubled = memo "gtk4.tests.double" (state => state.count + state.count)
  assertEq (doubled { count: 3 }) 6
}

@test "memo can drive subscription configuration from committed state"
memo_subscription_shape = do Effect {
  tickMillis = memo "gtk4.tests.tickMillis" (state =>
    if state.fast then 50 else 120
  )
  subscriptions = state => [
    subscriptionEvery {
      key: "clock"
      millis: tickMillis state
      tag: Save
    }
  ]

  first  = subscriptions { fast: True }
  second = subscriptions { fast: False }

  assertEq (List.length first) 1
  assertEq (List.length second) 1
  assertEq (tickMillis { fast: True }) 50
  assertEq (tickMillis { fast: False }) 120
}

@test "derive remains callable and readDerived is explicit"
derive_pure_helper = do Effect {
  title = derive (state => state.title)
  state = { title: "hello" }
  assertEq (title state) "hello"
  assertEq (readDerived title state) "hello"
}

@test "derived helpers compile inside gtk sigils"
derived_helpers_compile = do Effect {
  _ = derivedView
  assertEq True True
}

@test "auto is available as a gtkApp toMsg adapter"
auto_adapter_available = do Effect {
  mapped : Option TestMsg
  mapped = auto (GtkClicked 1 "")
  assertEq mapped None
}

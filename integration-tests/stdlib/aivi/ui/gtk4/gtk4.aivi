@no_prelude
module integrationTests.stdlib.aivi.ui.gtk4.tests

use aivi
use aivi.list as List
use aivi.reactive
use aivi.testing
use aivi.ui.gtk4

getClickedPair = event => event match
  | GtkClicked wid name => (wid, name)
  | _                   => (0, "")

getInputTriple = event => event match
  | GtkInputChanged wid name txt => (wid, name, txt)
  | _                            => (0, "", "")

getToggledTriple = event => event match
  | GtkToggled wid name active => (wid, name, active)
  | _                          => (0, "", False)

getFocusPair = event => event match
  | GtkFocusIn wid name => (wid, name)
  | _                   => (0, "")

getValueTriple = event => event match
  | GtkValueChanged wid name val => (wid, name, val)
  | _                            => (0, "", 0.0)

Row = { id: Text, name: Text }

signalDrivenView : Signal Text -> Signal Bool -> Signal (List Row) -> GtkNode
signalDrivenView = title => visible => rows =>
  ~<gtk>
    <GtkBox orientation="vertical" spacing="4">
      <GtkLabel label={derive title (txt => "Title: {txt}")} />
      <show when={visible}>
        <GtkLabel label="Visible" />
      </show>
      <each items={rows} as={row} key={row => row.id}>
        <GtkLabel label={row.name} />
      </each>
    </GtkBox>
  </gtk>

inputPayloadHandler : Text -> Unit
inputPayloadHandler = _ => Unit

togglePayloadHandler : Bool -> Unit
togglePayloadHandler = _ => Unit

selectPayloadHandler : Int -> Unit
selectPayloadHandler = _ => Unit

closedPayloadHandler : Unit -> Unit
closedPayloadHandler = _ => Unit

payloadCallbackView : GtkNode
payloadCallbackView =
  ~<gtk>
    <GtkBox orientation="vertical" spacing="4">
      <GtkEntry onInput={inputPayloadHandler} />
      <GtkSwitch onToggle={togglePayloadHandler} />
      <GtkDropDown strings="One\nTwo" selected={0} onSelect={selectPayloadHandler} />
    </GtkBox>
  </gtk>

payloadClosedDialogView : GtkNode
payloadClosedDialogView =
  ~<gtk>
    <AdwPreferencesDialog open={True} onClosed={closedPayloadHandler}>
      <AdwPreferencesPage title="General" />
    </AdwPreferencesDialog>
  </gtk>

@test "GtkClicked carries widget name"
signal_clicked = do Effect {
  assertEq (getClickedPair (GtkClicked 1 "saveBtn")) (1, "saveBtn")
}

@test "GtkInputChanged carries widget name and text"
signal_input_changed = do Effect {
  assertEq (getInputTriple (GtkInputChanged 2 "nameInput" "hello")) (2, "nameInput", "hello")
}

@test "GtkToggled carries widget name and bool"
signal_toggled = do Effect {
  assertEq (getToggledTriple (GtkToggled 3 "checkBox" True)) (3, "checkBox", True)
}

@test "GtkFocusIn carries widget name"
signal_focus = do Effect {
  assertEq (getFocusPair (GtkFocusIn 4 "entry")) (4, "entry")
}

@test "GtkSignalEvent pattern matching with wildcard widget id"
signal_event_pattern_matching = do Effect {
  clickHandled = (GtkClicked 1 "btn") match
    | GtkClicked _ _ => True
    | _              => False
    assertEq clickHandled True
    inputText = (GtkInputChanged 2 "inp" "hi") match
      | GtkInputChanged _ _ txt => txt
      | _                       => ""
    assertEq inputText "hi"
    toggleActive = (GtkToggled 3 "chk" True) match
      | GtkToggled _ _ active => active
      | _                     => False
    assertEq toggleActive True
    focusHandled = (GtkFocusIn 4 "x") match
      | GtkFocusIn _ _ => True
      | _              => False
    assertEq focusHandled True
}

@test "GtkSignalEvent match by widget name"
signal_event_match_by_name = do Effect {
  getTitleText = event => event match
    | GtkInputChanged _ "titleInput" txt => Some txt
    | _                                  => None
    getBodyText = event => event match
      | GtkInputChanged _ "bodyInput" txt => Some txt
      | _                                 => None
    assertEq (getTitleText (GtkInputChanged 1 "titleInput" "hi")) (Some "hi")
    assertEq (getBodyText (GtkInputChanged 2 "bodyInput" "lo")) (Some "lo")
    assertEq (getTitleText (GtkInputChanged 3 "other" "x")) None
}

@test "GtkNode constructors"
gtk_node_constructors = do Effect {
  elem = gtkElement "GtkBox" [] [gtkTextNode "hello"]
  tag  = elem match
    | GtkElement name _ _ => name
    | _                   => ""
    assertEq tag "GtkBox"
}

@test "gtk4 helper constructors are accessible"
type_signatures = do Effect {
  node       = gtkElement "GtkBox" [] [gtkTextNode "hello"]
  childCount = node match
    | GtkElement _ _ children => List.length children
    | _                       => 0
    assertEq childCount 1
}

@test "gtk sugar callbacks compile with ergonomic payloads"
gtk_sugar_callback_payloads = do Effect {
  _ = payloadCallbackView
  _ = payloadClosedDialogView
  assertEq True True
}

@test "signal-first gtk sigils compile with show each and derived signals"
signal_first_sigil_shapes = do Effect {
  title   = signal "Hello"
  visible = signal True
  rows    = signal [
    { id: "one", name: "First" }
    { id: "two", name: "Second" }
  ]
  combined =
    combineAll (title, visible) ((title, visible) =>
      if visible then "{title}!" else title
    )
  _ = combined
  _ = signalDrivenView title visible rows
  assertEq (get title) "Hello"
}

@test "keyed each mounts from gtk sigil"
keyed_each_mounts = do Effect {
  _   <- init Unit
  app <- appNew "integration-tests.keyed-each"
  win <- windowNew app "KeyedEach" 320 120
  rows = signal [
    { id: "one", name: "First" }
    { id: "two", name: "Second" }
  ]
  view =
    ~<gtk>
      <GtkBox orientation="vertical" spacing="4">
        <each items={rows} as={row} key={row => row.id}>
          <GtkLabel label={row.name} />
        </each>
      </GtkBox>
    </gtk>
    root <- buildFromNode view
    _    <- windowSetChild win root
    assertEq True True
}

@test "curated gtk imperative escape hatches remain available"
curated_gtk_escape_hatches_available = do Effect {
  _               = init
  _               = appNew
  _               = windowNew
  _               = mountAppWindow
  _               = runGtkApp
  _               = windowSetChild
  _               = windowPresent
  _               = appRun
  _               = buildFromNode
  _               = buildWithIds
  _               = reconcileNode
  _               = signalPoll
  _               = signalStream
  _               = signalEmit
  makeMenuModel   = () => menuModelNew Unit
  appendMenuItem  = menuId => menuModelAppendItem menuId "Preferences" "app.preferences"
  attachMenuModel = buttonId => modelId => menuButtonSetMenuModel buttonId modelId
  openDocs        = () => osOpenUri "https://example.com/docs"
  startTickFeed   = () => gtkSetInterval 1000
  _               = makeMenuModel
  _               = appendMenuItem
  _               = attachMenuModel
  _               = openDocs
  _               = startTickFeed
  assertEq True True
}

@test "root application window sigils compile"
root_application_window_sigil = do Effect {
  root = ~<gtk>
    <AdwApplicationWindow title="Counter" defaultWidth={320} defaultHeight={180}>
      <GtkBox orientation="vertical" spacing={8}>
        <GtkLabel label="Hello" />
      </GtkBox>
    </AdwApplicationWindow>
  </gtk>
  _ = root
  assertEq True True
}

@test "mountAppWindow accepts multiple live roots"
mount_app_window_accepts_multiple_live_roots = do Effect {
  _   <- init Unit
  app <- appNew "integration-tests.multi-root"
  windowRoot =
    ~<gtk>
      <AdwApplicationWindow id="root-window" title="Counter" defaultWidth={320} defaultHeight={180}>
        <GtkBox orientation="vertical" spacing={8}>
          <GtkLabel label="Hello" />
        </GtkBox>
      </AdwApplicationWindow>
    </gtk>
  dialogRoot =
    ~<gtk>
      <AdwPreferencesDialog id="prefs-dialog" title="Preferences" open={True}>
        <AdwPreferencesPage title="General" />
      </AdwPreferencesDialog>
    </gtk>
    win      <- mountAppWindow app [windowRoot, dialogRoot]
    lookedUp <- widgetById "root-window"
    dialogId <- widgetById "prefs-dialog"
    assertEq lookedUp win
    assertEq False (dialogId == 0)
    _ <- windowClose win
}

@test "GtkMenuButton accepts nested GtkPopover property graphs"
menu_button_accepts_nested_popover_property_graphs = do Effect {
  view =
    ~<gtk>
      <GtkMenuButton id="settings-btn" iconName="preferences-system-symbolic">
        <property name="popover">
          <GtkPopover id="settings-popover">
            <GtkBox id="settings-menu" orientation="vertical" spacing={4}>
              <GtkButton id="settings-ai-btn" label="AI settings" />
            </GtkBox>
          </GtkPopover>
        </property>
      </GtkMenuButton>
    </gtk>
    _         <- buildWithIds view
    buttonId  <- widgetById "settings-btn"
    popoverId <- widgetById "settings-popover"
    assertEq False (buttonId == 0)
    assertEq False (popoverId == 0)
}

@test "GtkValueChanged carries widget name and float value"
signal_value_changed = do Effect {
  assertEq (getValueTriple (GtkValueChanged 5 "slider" 0.75)) (5, "slider", 0.75)
}


@test "GtkCalendar day-selected signal is known"
gtk_calendar_signal = do Effect {
  event = GtkActivated 1 "calendar"
  pair  = event match
    | GtkActivated wid name => (wid, name)
    | _                     => (0, "")
    assertEq pair (1, "calendar")
}

@test "GtkActionBar node is constructable"
gtk_action_bar_node = do Effect {
  elem   = gtkElement "GtkActionBar" [gtkAttr "revealed" "true"] []
  getTag = n => n match
    | GtkElement tag _ _ => tag
    | _                  => ""
    assertEq (getTag elem) "GtkActionBar"

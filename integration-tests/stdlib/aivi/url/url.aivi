@no_prelude
module integrationTests.stdlib.aivi.url.tests

use aivi
use aivi.testing
use aivi.url (parse, toString, protocol, host, port, path, query, hash, domain Url)

@test "parse"
parse_functional = {
  assertOk (parse "https://example.com:8080/path?q=v&lang=en#hash")
   |> value => {
        assertEq (protocol value) "https"
        assertEq (host value) "example.com"
        assertEq (port value) (Some 8080)
        assertEq (path value) "/path"
        assertEq (query value) [("q", "v"), ("lang", "en")]
        assertEq (hash value) (Some "hash")
      }
}

@test "parse origin defaults path"
parse_origin_defaults_path = {
  assertOk (parse "http://example.com")
   |> value => {
        assertEq (path value) "/"
        assertEq (query value) []
        assertNone (hash value)
      }
}

@test "to string"
toString_functional = {
  assertOk (parse "http://example.com/path?q=v#hash")
   |> toString
   |> assertEq "http://example.com/path?q=v#hash"
}

@test "query add appends"
query_add_appends = {
  assertOk (parse "https://example.com/search?q=old")
   |> value => {
        updated = value + ("page", "1")
        assertEq (query updated) [("q", "old"), ("page", "1")]
      }
}

@test "query remove removes all matching keys"
query_remove_removes_all_matching_keys = {
  assertOk (parse "https://example.com/search?q=old&page=1")
   |> value => {
        updated = value + ("page", "2")
        cleaned = updated - "page"
        assertEq (query cleaned) [("q", "old")]
      }
}

@test "parse invalid returns error"
parse_invalid_returns_error = assertErr (parse "not a url")
  |> text.length
  |> length => assert (length > 0)

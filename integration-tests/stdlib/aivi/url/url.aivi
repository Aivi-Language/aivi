@no_prelude
module integrationTests.stdlib.aivi.url.tests

use aivi
use aivi.testing
use aivi.url

@test "parse"
parse_functional = do Effect {
  res = parse "https://example.com:8080/path?q=v#hash"
  r <- (res match
    | Ok re => do Effect { pure re }
    | Err _ => do Effect { fail "parse failed" }
  )
  assert (protocol r == "https")
  assert (host r == "example.com")
  assert (port r == Some 8080)
}

@test "to string"
toString_functional = do Effect {
  res = parse "http://example.com/"
  res match
    | Ok u  => assert (text.startsWith (toString u) "http://example.com")
    | Err _ => fail "parse failed"
}

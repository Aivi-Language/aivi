@no_prelude
module integrationTests.stdlib.aivi.log.tests

use aivi (attempt, Unit, Ok)
use aivi.testing
use aivi.log

@test "info"
info_functional = attempt (info "server started" [("port", "8080")])
  |> assertEq (Ok Unit)

@test "explicit level"
log_with_level_functional = attempt (log Warn "disk almost full" [("disk", "root")])
  |> assertEq (Ok Unit)

@test "logger re-export"
logger_reexport_functional = attempt (logger.debug "dbg" [("traceId", "abc")])
  |> assertEq (Ok Unit)

@no_prelude
module integrationTests.stdlib.aivi.duration.domain_Duration.tests

use aivi
use aivi.testing
use aivi.duration
use aivi.duration (domain Duration)

@test "literals"
literals_functional = do Effect {
  base = { millis: 0 }
  ms = base + 1ms
  s = base + 1s
  m = base + 1min
  assertEq ms.millis 1
  assertEq s.millis 1000
  assertEq m.millis 60000
}

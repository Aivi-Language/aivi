@no_prelude
module integrationTests.stdlib.aivi.units.tests

use aivi
use aivi (
  math (abs)
  units (convert, defineUnit, sameUnit, domain Units)
)
use aivi.testing

@test "quantity operators"
quantity_functional = do Effect {
  meter     = defineUnit "m" 1.0
  kilometer = defineUnit "km" 1000.0
  base      = { value: 750.0, unit: meter }
  relay     = convert { value: 2.0, unit: kilometer } meter
  total     = base + relay
  remain    = total - base
  doubled   = remain * 2.0
  halved    = doubled / 4.0
  assert (abs (total.value - 2750.0) < 0.0000001)
  assertEq total.unit.name "m"
  assert (abs (remain.value - 2000.0) < 0.0000001)
  assertEq remain.unit.name "m"
  assert (abs (doubled.value - 4000.0) < 0.0000001)
  assertEq doubled.unit.name "m"
  assert (abs (halved.value - 1000.0) < 0.0000001)
  assertEq halved.unit.name "m"
}

@test "unit"
unit_functional = do Effect {
  u = defineUnit "s" 1.0
  assert (u.name == "s")
  assert (u.factor == 1.0)
}

@test "convert"
convert_functional = do Effect {
  m   = defineUnit "m" 1.0
  km  = defineUnit "km" 1000.0
  q   = { value: 1500.0, unit: m }
  qKm = convert q km
  assert (abs (qKm.value - 1.5) < 0.0000001)
  assert (qKm.unit.name == "km")
}

@test "define unit"
defineUnit_functional = do Effect {
  m  = defineUnit "m" 1.0
  km = defineUnit "km" 1000.0
  assert (m.name == "m")
  assert (km.factor == 1000.0)
}

@test "same unit"
sameUnit_functional = do Effect {
  m  = defineUnit "m" 1.0
  km = defineUnit "km" 1000.0
  a  = { value: 1.0, unit: m }
  b  = { value: 2.0, unit: m }
  c  = { value: 1.0, unit: km }
  assert (sameUnit a b == True)
  assert (sameUnit a c == False)
}

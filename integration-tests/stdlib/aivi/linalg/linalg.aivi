@no_prelude
module integrationTests.stdlib.aivi.linalg.tests

use aivi
use aivi.testing
use aivi.linalg

@test "mat"
mat_functional = do Effect {
  m = { rows: 2, cols: 2, data: [1.0, 0.0, 0.0, 1.0] }
  assert (m.rows == 2)
}

@test "vec"
vec_functional = do Effect {
  v = { size: 3, data: [1.0, 2.0, 3.0] }
  assert (v.size == 3)
}

@test "dot"
dot_functional = do Effect {
  v1 = { size: 2, data: [1.0, 2.0] }
  v2 = { size: 2, data: [3.0, 4.0] }
  d  = dot v1 v2
  assert (d == 11.0)
}

@test "mat mul"
matMul_functional = do Effect {
  m1 = { rows: 1, cols: 2, data: [1.0, 2.0] }
  m2 = { rows: 2, cols: 1, data: [3.0, 4.0] }
  m3 = matMul m1 m2
  assert (m3.rows == 1)
  assert (m3.cols == 1)
  assert (m3.data == [11.0])
}

@test "solve2x2"
solve2x2_functional = do Effect {
  // x + y = 3
  // x - y = 1
  // => x=2, y=1
  m   = { rows: 2, cols: 2, data: [1.0, 1.0, 1.0, -1.0] }
  v   = { size: 2, data: [3.0, 1.0] }
  res = solve2x2 m v
  assert (res.data == [2.0, 1.0])
}

@test "dot zero vector"
dot_zero = do Effect {
  v1 = { size: 3, data: [1.0, 0.0, 0.0] }
  v2 = { size: 3, data: [0.0, 1.0, 0.0] }
  assert (dot v1 v2 == 0.0)
}

@test "dot self magnitude squared"
dot_self = do Effect {
  v = { size: 3, data: [3.0, 4.0, 0.0] }
  d = dot v v
  assert (d == 25.0)
}

@test "matMul with identity"
matMul_identity = do Effect {
  id2    = { rows: 2, cols: 2, data: [1.0, 0.0, 0.0, 1.0] }
  m      = { rows: 2, cols: 2, data: [5.0, 6.0, 7.0, 8.0] }
  result = matMul id2 m
  assert (result.data == m.data)
}

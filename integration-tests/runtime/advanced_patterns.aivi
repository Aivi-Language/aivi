@no_prelude
module integrationTests.runtime.advancedPatterns

use aivi
use aivi.testing
use aivi.logic
use aivi.list

// --- Nested pattern matching ---

Tree A = Leaf A | Branch (Tree A) (Tree A)

treeSum : Tree Int -> Int
treeSum = t => t match
  | Leaf n     => n
  | Branch l r => (treeSum l) + (treeSum r)

@test "nested tree pattern matching"
nestedTreeMatch = {
  tree = Branch (Branch (Leaf 1) (Leaf 2)) (Leaf 3)
  assertEq (treeSum tree) 6
}

maxInt : Int -> Int -> Int
maxInt = a b => if a > b then a else b

treeDepth : Tree A -> Int
treeDepth = t => t match
  | Leaf _     => 1
  | Branch l r => 1 + (maxInt (treeDepth l) (treeDepth r))

@test "tree depth"
treeDepthTest = {
  tree = Branch (Branch (Leaf 1) (Leaf 2)) (Leaf 3)
  assertEq (treeDepth tree) 3
}

// --- Complex currying and closures ---

@test "triple nested closure"
tripleNested = {
  make = a => b => c => d => a + b + c + d
  f    = make 1
  g    = f 2
  h    = g 3
  assertEq (h 4) 10
}

@test "closure captures computed value"
closureCapturesComputed = {
  x = 10 * 5
  f = n => n + x
  assertEq (f 8) 58
}

@test "closure in list operations"
closureInList = {
  multiplier = 3
  result     = map (x => x * multiplier) [1, 2, 3, 4]
  assertEq result [3, 6, 9, 12]
}

// --- Higher-order function chains ---

@test "chained map and filter"
chainedMapFilter = {
  result = List.map (x => x * 10) (List.filter (x => x > 2) [1, 2, 3, 4, 5, 6])
    assertEq result [30, 40, 50, 60]
}

@test "reduce with pipe"
foldlPipe = {
  result = List.foldl (acc x => acc + x) 0 [1, 2, 3, 4, 5]
    assertEq result 15
}

@test "map then reduce"
mapThenFold = {
  result = List.foldl (acc x => acc + x) 0 (List.map (x => x * x) [1, 2, 3])
    assertEq result 14
}

// --- Record construction and field access ---

@test "complex record with nested fields"
complexRecord = {
  user = {
    name: "Alice"
    age: 30
    address: {
      city: "Wonderland"
      zip: "12345"
    }
  }
  assertEq user.name "Alice"
  assertEq user.address.city "Wonderland"
  assertEq user.address.zip "12345"
}

@test "record patch with nested update"
recordPatchNested = {
  config  = { debug: False, maxRetries: 3, label: "prod" }
  updated = config <| { debug: True, label: "dev" }
  assertEq updated.debug True
  assertEq updated.maxRetries 3
  assertEq updated.label "dev"
}

@test "record as function return"
recordAsReturn = {
  mkPair = a b => { first: a, second: b }
  pair   = mkPair 1 "hello"
  assertEq pair.first 1
  assertEq pair.second "hello"
}

// --- Nested Result and Option logic ---

andThenText : Result Text A -> (A -> Result Text B) -> Result Text B
andThenText = result next => result match
  | Ok value => next value
  | Err err  => Err err

@test "nested Option logic in plain block"
nestedOptionInPlainBlock = {
  result = (Some 10, Some 20) match
    | (Some a, Some b) => Some (a + b)
    | _                => None
  assertEq result (Some 30)
}

@test "nested Result logic in plain block"
nestedResultInPlainBlock = {
  result = andThenText (Ok 5) (x =>
    andThenText (Ok 10) (y =>
      Ok (x * y)
    )
  )
  assertEq result (Ok 50)
}

@test "nested Result logic short-circuits"
nestedResultShort = {
  result = andThenText (Ok 5) (x =>
    andThenText (Err "bad") (y =>
      Ok (x + y)
    )
  )
  assertEq result (Err "bad")
}

@test "attempt and recover"
attemptRecover = attempt (fail "boom")
  |> result => assertEq (result match
    | Ok v  => v
    | Err _ => 42
  ) 42

// --- Multi-clause function definitions ---

Shape = Circle Float | Rectangle Float Float | Point

describeShape : Shape -> Text
describeShape =
  | Circle _      => "circle"
  | Rectangle _ _ => "rectangle"
  | Point         => "point"

@test "multi-clause shape"
multiClauseShape = {
  assertEq (describeShape (Circle 5.0)) "circle"
  assertEq (describeShape (Rectangle 3.0 4.0)) "rectangle"
  assertEq (describeShape Point) "point"
}

Expr = Num Int | Add Expr Expr | Mul Expr Expr

eval : Expr -> Int
eval = e => e match
  | Num n   => n
  | Add l r => (eval l) + (eval r)
  | Mul l r => (eval l) * (eval r)

@test "recursive ADT evaluation"
recursiveAdtEval = {
  expr = Add (Mul (Num 3) (Num 4)) (Num 5)
  assertEq (eval expr) 17
}

// --- Complex list expansion patterns ---

@test "nested list expansion"
listExpansion = {
  result = List.flatMap (x => List.map (y => x * y) [10, 20]) [1, 2, 3]
  assertEq result [10, 20, 20, 40, 30, 60]
}

// --- String interpolation with expressions ---

@test "string concatenation"
stringConcat = {
  name     = "world"
  greeting = "hello {name}"
  assertEq greeting "hello world"
}

// --- Tuple patterns ---

@test "tuple destructuring"
tupleDestructure = {
  pair   = (1, "hello")
  (a, b) = pair
  assertEq a 1
  assertEq b "hello"
}

@test "triple tuple"
tripleTuple = {
  t         = (1, 2, 3)
  (a, b, c) = t
  assertEq (a + b + c) 6
}

// --- Boolean operations ---

@test "boolean and or"
boolOps = {
  assertEq (True && True) True
  assertEq (True && False) False
  assertEq (False || True) True
  assertEq (False || False) False
}

// --- Equality on ADTs ---

Color = Red | Green | Blue

@test "adt equality"
adtEquality = {
  assertEq Red Red
  assertEq (Red == Green) False
  assertEq (Some 42) (Some 42)
  assertEq (Some 42 == None) False
}

// --- Recursive list function ---

myLength : List A -> Int
myLength = xs => xs match
  | []           => 0
  | [_, ...rest] => 1 + (myLength rest)

@test "recursive list length"
recursiveListLength = {
  assertEq (myLength [1, 2, 3]) 3
  assertEq (myLength []) 0
}

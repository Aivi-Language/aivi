@no_prelude
module integrationTests.runtime.textBuiltins

use aivi
use aivi.testing
use aivi.text

// --- Length and isEmpty ---

@test "length of text"
lengthTest = {
  assertEq (length "hello") 5
  assertEq (length "") 0
  assertEq (length "a") 1
}

@test "isEmpty"
isEmptyTest = {
  assertEq (isEmpty "") True
  assertEq (isEmpty "a") False
}

// --- Contains, startsWith, endsWith ---

@test "contains"
containsTest = {
  assertEq (contains "ell" "hello") True
  assertEq (contains "xyz" "hello") False
  assertEq (contains "" "hello") True
}

@test "startsWith"
startsWithTest = {
  assertEq (startsWith "hel" "hello") True
  assertEq (startsWith "xyz" "hello") False
  assertEq (startsWith "" "hello") True
}

@test "endsWith"
endsWithTest = {
  assertEq (endsWith "llo" "hello") True
  assertEq (endsWith "xyz" "hello") False
  assertEq (endsWith "" "hello") True
}

// --- indexOf, lastIndexOf, count ---

@test "indexOf found"
indexOfFound = {
  assertEq (indexOf "ll" "hello") (Some 2)
}

@test "indexOf not found"
indexOfNotFound = {
  assertEq (indexOf "xyz" "hello") None
}

@test "lastIndexOf"
lastIndexOfTest = {
  assertEq (lastIndexOf "l" "hello world") (Some 9)
}

@test "count occurrences"
countTest = {
  assertEq (count "l" "hello world") 3
  assertEq (count "z" "hello") 0
}

@test "compare"
compareTest = {
  assertEq (compare "a" "b") (-1)
  assertEq (compare "b" "a") 1
  assertEq (compare "a" "a") 0
}

// --- Trim ---

@test "trim"
trimTest = {
  assertEq (trim "  hello  ") "hello"
  assertEq (trim "hello") "hello"
  assertEq (trim "  ") ""
}

@test "trimStart"
trimStartTest = {
  assertEq (trimStart "  hello  ") "hello  "
}

@test "trimEnd"
trimEndTest = {
  assertEq (trimEnd "  hello  ") "  hello"
}

// --- Case conversion ---

@test "toLower"
toLowerTest = {
  assertEq (toLower "HELLO") "hello"
  assertEq (toLower "Hello World") "hello world"
  assertEq (toLower "") ""
}

@test "toUpper"
toUpperTest = {
  assertEq (toUpper "hello") "HELLO"
  assertEq (toUpper "") ""
}

@test "capitalize"
capitalizeTest = {
  assertEq (capitalize "hello") "Hello"
  assertEq (capitalize "") ""
}

@test "titleCase"
titleCaseTest = {
  assertEq (titleCase "hello world") "Hello World"
}

@test "caseFold"
caseFoldTest = {
  assertEq (caseFold "HELLO") "hello"
}

// --- Replace ---

@test "replace first occurrence"
replaceTest = {
  assertEq (replace "l" "r" "hello") "herlo"
}

@test "replaceAll"
replaceAllTest = {
  assertEq (replaceAll "l" "r" "hello") "herro"
}

@test "remove"
removeTest = {
  assertEq (remove "l" "hello") "heo"
}

// --- Split and join ---

@test "split"
splitTest = {
  assertEq (split "," "a,b,c") ["a", "b", "c"]
  assertEq (split "," "hello") ["hello"]
}

@test "splitLines"
splitLinesTest = {
  assertEq (splitLines "a\nb\nc") ["a", "b", "c"]
}

@test "concat"
concatTest = {
  assertEq (concat ["a", "b", "c"]) "abc"
  assertEq (concat []) ""
}

// --- Slice ---

@test "slice basic"
sliceBasic = {
  assertEq (slice 1 3 "hello") "el"
  assertEq (slice 0 5 "hello") "hello"
}

@test "slice empty result"
sliceEmpty = {
  assertEq (slice 3 3 "hello") ""
  assertEq (slice 5 3 "hello") ""
}

@test "slice negative index"
sliceNeg = {
  assertEq (slice (-2) 5 "hello") "lo"
}

// --- Pad ---

@test "padStart"
padStartTest = {
  assertEq (padStart 8 "0" "hello") "000hello"
}

@test "padEnd"
padEndTest = {
  assertEq (padEnd 8 "." "hello") "hello..."
}

@test "padStart no padding needed"
padStartNoPad = {
  assertEq (padStart 3 "0" "hello") "hello"
}

// --- Repeat and reverse ---

@test "repeat"
repeatTest = {
  assertEq (repeat 3 "ab") "ababab"
  assertEq (repeat 0 "ab") ""
}

@test "reverse"
reverseTest = {
  assertEq (reverse "hello") "olleh"
  assertEq (reverse "") ""
  assertEq (reverse "a") "a"
}

// --- Chunk ---

@test "chunk"
chunkTest = {
  assertEq (chunk 2 "abcde") ["ab", "cd", "e"]
  assertEq (chunk 3 "abcdef") ["abc", "def"]
}

// --- parseInt and parseFloat ---

@test "parseInt valid"
parseIntValid = {
  assertEq (parseInt "42") (Some 42)
  assertEq (parseInt "-7") (Some (-7))
}

@test "parseInt invalid"
parseIntInvalid = {
  assertEq (parseInt "abc") None
  assertEq (parseInt "") None
}

@test "parseFloat valid"
parseFloatValid = {
  assertEq (parseFloat "3.14") (Some 3.14)
}

@test "parseFloat invalid"
parseFloatInvalid = {
  assertEq (parseFloat "abc") None
}

// --- debugText ---

@test "debugText on int"
debugTextInt = {
  result = debugText 42
  assertEq result "42"
}

@no_prelude
module integrationTests.runtime.integerOverflow

use aivi
use aivi.testing

// AIVI integers are 64-bit signed (i64). Arithmetic uses Cranelift's iadd/isub/imul
// which are two's-complement wrapping instructions — no trap, no saturation.
//
// i64::MAX = 9223372036854775807
// i64::MIN = -(i64::MAX) - 1  (can't write the literal directly since
//            9223372036854775808 > i64::MAX would be parsed as f64)
//
// Design note: all overflow arithmetic uses LOCAL bindings so the JIT retains
// type information (CgType::Int) and lowers to the wrapping iadd/isub/imul
// instructions. Module-level bindings become boxed at runtime and would cause
// the slow-path eval to panic on overflow in debug builds.

@test "max + 1 wraps to min (two's-complement)"
overflowAdd = {
  // Both are local Int literals: JIT uses iadd which wraps.
  maxVal  = 9223372036854775807
  wrapped = maxVal + 1
  // Derive i64::MIN without an out-of-range literal.
  minVal = 0-9223372036854775807-1
  assertEq wrapped minVal
}

@test "min - 1 wraps to max (two's-complement)"
overflowSub = {
  minVal  = 0-9223372036854775807-1
  wrapped = minVal - 1
  maxVal  = 9223372036854775807
  assertEq wrapped maxVal
}

@test "multiply overflow wraps"
mulOverflow = {
  // 2 * i64::MAX = 2 * 9223372036854775807 mod 2^64 = -2
  maxVal = 9223372036854775807
  result = 2 * maxVal
  assertEq result (-2)
}

@test "max - min via subtraction of local values overflows to -1"
maxMinusMin = {
  // i64::MAX - i64::MIN = 9223372036854775807 - (-9223372036854775808) = -1 (wraps)
  maxVal = 9223372036854775807
  minVal = 0-9223372036854775807-1
  result = maxVal - minVal
  assertEq result (-1)
}

@test "small arithmetic stays correct"
smallArith = {
  assertEq (100 + 200) 300
  assertEq (1000-1) 999
  assertEq (7 * 6) 42
  assertEq (100 / 3) 33
  assertEq (100 % 3) 1
}

@test "zero arithmetic identity with large values"
zeroArithLarge = {
  maxVal = 9223372036854775807
  assertEq (maxVal + 0) maxVal
  assertEq (0 * maxVal) 0
}

@test "negative integer arithmetic"
negArith = {
  assertEq ((-5) + (-3)) (-8)
  assertEq ((-10) - (-4)) (-6)
  assertEq ((-3) * 4) (-12)
}

@test "integer division truncates toward zero"
intDivTrunc = {
  assertEq (7 / 2) 3
  assertEq ((-7) / 2) (-3)
  assertEq (7 / (-2)) (-3)
}

@test "integer remainder sign follows dividend"
intRemSign = {
  assertEq (7 % 3) 1
  assertEq ((-7) % 3) (-1)
  assertEq (7 % (-3)) 1
}

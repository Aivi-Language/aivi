@no_prelude
module integrationTests.runtime.evalOrderArgs

use aivi
use aivi.testing

// --- Argument position correctness ---
//
// AIVI is a strict language: all arguments to a function are evaluated before
// the call.  The position each expression occupies in the argument list
// determines which parameter it binds to.  These tests verify that the runtime
// delivers arguments to the function in left-to-right declaration order.

toList3 : A -> A -> A -> List A
toList3 = a b c => [a, b, c]

toList4 : A -> A -> A -> A -> List A
toList4 = a b c d => [a, b, c, d]

// Non-commutative helper to make position errors observable.
sub : Int -> Int -> Int
sub = a b => a - b

triple : Int -> Int -> Int -> (Int, Int, Int)
triple = a b c => (a, b, c)

// --- Basic positional correctness ---

@test "args arrive at correct positions – Int"
argPositionInt = do Effect {
  result = toList3 10 20 30
  assertEq result [10, 20, 30]
}

@test "args arrive at correct positions – Text"
argPositionText = do Effect {
  result = toList3 "first" "second" "third"
  assertEq result ["first", "second", "third"]
}

@test "four args arrive in declaration order"
argPositionFour = do Effect {
  result = toList4 1 2 3 4
  assertEq result [1, 2, 3, 4]
}

// --- Computed arguments preserve position ---

@test "computed args at correct positions"
computedArgPositions = do Effect {
  base   = 10
  result = toList3 (base + 1) (base * 2) (base * 3)
  assertEq result [11, 20, 30]
}

// --- Non-commutative: argument order changes the result ---

@test "sub(10,3) = 7, not sub(3,10)"
subArgOrder = do Effect {
  assertEq (sub 10 3) 7
  assertEq (sub 3 10) (-7)
}

@test "nested computed args respect position"
nestedComputedArgs = do Effect {
  f      = x => x * 2
  g      = x => x + 100
  result = toList3 (f 1) (g 2) (f (g 3))
  assertEq result [2, 102, 206]
}

// --- do Effect sequencing reflects L-to-R evaluation order ---
//
// In a do Effect block, each bind is sequenced: step1 runs before step2, etc.
// Collecting the results in order verifies that evaluation proceeds
// left-to-right through the block.

@test "do Effect sequencing is left-to-right"
doEffectSeqOrder = do Effect {
  a <- pure 100
  b <- pure 200
  c <- pure 300
  log = [a, b, c]
  assertEq log [100, 200, 300]
}

@test "multi-step accumulation preserves order"
multiStepAccumulation = do Effect {
  v1 <- pure (1 * 10)
  v2 <- pure (2 * 10)
  v3 <- pure (3 * 10)
  v4 <- pure (4 * 10)
  log = [v1, v2, v3, v4]
  assertEq log [10, 20, 30, 40]
}

// --- Triple destructure: all three positions must be distinct ---

@test "triple destructure preserves arg order"
tripleDestructure = do Effect {
  (a, b, c) = triple 7 8 9
  assertEq a 7
  assertEq b 8
  assertEq c 9
}

// --- Curried application: partial application preserves arg position ---

@test "partial application fixes first arg position"
partialAppFixesFirst = do Effect {
  sub5 = sub 5 // sub5 x = 5 - x
  assertEq (sub5 3) 2
  assertEq (sub5 5) 0
}

@test "chained partial application preserves order"
chainedPartial = do Effect {
  mkList = a b c => [a, b, c]
  f      = mkList 1
  g      = f 2
  assertEq (g 3) [1, 2, 3]
}

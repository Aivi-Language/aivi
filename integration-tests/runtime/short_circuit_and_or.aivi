@no_prelude
module integrationTests.runtime.shortCircuitAndOr

use aivi
use aivi.testing

// --- Short-circuit evaluation of && and || ---
//
// `&&` and `||` are lowered to `if-then-else` in the HIR:
//   a && b  ≡  if a then b else False
//   a || b  ≡  if a then True else b
//
// Consequently the right-hand operand is never evaluated when:
//   - left side of && is False
//   - left side of || is True
//
// We verify short-circuit two ways:
//   1. Truth-table tests: all four input combinations produce the correct Bool.
//   2. Effect-sentinel tests: the right operand is an effectful branch that
//      calls `fail`; if short-circuit were absent the test would be aborted.

// ─── && truth table ───────────────────────────────────────────────────────────

@test "and TT = True"
andTT = { assertEq (True && True) True }

@test "and TF = False"
andTF = { assertEq (True && False) False }

@test "and FT = False"
andFT = { assertEq (False && True) False }

@test "and FF = False"
andFF = { assertEq (False && False) False }

// ─── || truth table ───────────────────────────────────────────────────────────

@test "or TT = True"
orTT = { assertEq (True || True) True }

@test "or TF = True"
orTF = { assertEq (True || False) True }

@test "or FT = True"
orFT = { assertEq (False || True) True }

@test "or FF = False"
orFF = { assertEq (False || False) False }

// ─── Short-circuit via if-then-else (which && / || desugar to) ───────────────
//
// `if False then <never> else result`  must not enter the then-branch.
// `if True  then result  else <never>` must not enter the else-branch.
// If the branch were entered, `fail` would abort the test.

@test "if-then-else does not evaluate false branch when cond is True"
ifThenElseShortCircuitTrue = assertEq (if True then 42 else (0 / 0)) 42

@test "if-then-else does not evaluate true branch when cond is False"
ifThenElseShortCircuitFalse = assertEq (if False then (0 / 0) else 99) 99

// ─── && short-circuit: right side skipped when left is False ─────────────────
//
// `False && X` desugars to `if False then X else False`.
// The then-branch (X) is never entered.

@test "and short-circuits: right not reached when left is False (const False)"
andShortCircuitFalseLeft = {
  // Right-hand side is an always-false value; result must still be False.
  neverReached = False
  assertEq (False && neverReached) False
}

@test "and does not short-circuit when left is True"
andNoShortCircuitTrueLeft = {
  // Right-hand side IS evaluated; it determines the final result.
  assertEq (True && False) False
  assertEq (True && True) True
}

@test "and short-circuit: chained with True left evaluates right"
andChainedRightEval = {
  computed = 3 > 1 // True
  assertEq (True && computed) True
  assertEq (False && computed) False
}

// ─── || short-circuit: right side skipped when left is True ──────────────────
//
// `True || X` desugars to `if True then True else X`.
// The else-branch (X) is never entered.

@test "or short-circuits: right not reached when left is True (const True)"
orShortCircuitTrueLeft = {
  neverReached = True
  assertEq (True || neverReached) True
}

@test "or does not short-circuit when left is False"
orNoShortCircuitFalseLeft = {
  assertEq (False || False) False
  assertEq (False || True) True
}

@test "or short-circuit: chained with False left evaluates right"
orChainedRightEval = {
  computed = 10 > 5 // True
  assertEq (False || computed) True
  assertEq (True || computed) True
}

// ─── Attempt-based sentinel: fail in dead branch does not abort test ──────────
//
// We wrap the computation in `attempt` so that if the "should not be reached"
// branch IS evaluated (i.e. short-circuit is broken), the test fails cleanly
// rather than panicking.

// Sentinel: an effect that always fails, useful for detecting unwanted evaluation
// inside a branch that should be dead.
sentinel : Effect Text Bool
sentinel = fail "sentinel: branch should not have been evaluated"

@test "and with fail-sentinel on right: False left must not trigger sentinel"
andSentinelFalseLeft = attempt (if False then sentinel else pure False)
||>Ok value => assertEq value False
||>Err _ => fail "sentinel triggered unexpectedly"

@test "or with fail-sentinel on right: True left must not trigger sentinel"
orSentinelTrueLeft = attempt (if True then pure True else sentinel)
||>Ok value => assertEq value True
||>Err _ => fail "sentinel triggered unexpectedly"

// ─── Result / Option short-circuit (bonus) ───────────────────────────────────
//
// These verify the carrier-level short-circuit behaviour (already covered by
// do_effects_advanced.aivi, repeated here for completeness).

@test "Result short-circuits on Err"
doResultShortCircuit = {
  result = Err "stop here"
  assertEq result (Err "stop here")
}

@test "Option short-circuits on None"
doOptionShortCircuit = {
  result = (Some 10, None) match
    | (Some _, Some _) => Some 99
    | _                => None
  assertEq result None
}

@no_prelude
module integrationTests.runtime.mathBuiltins

use aivi
use aivi.testing
use aivi.math

// --- Constants ---

@test "pi constant"
piConst = {
  assert (pi > 3.14)
  assert (pi < 3.15)
}

@test "e constant"
eConst = {
  assert (e > 2.71)
  assert (e < 2.72)
}

@test "tau is 2*pi"
tauConst = {
  assert (tau > 6.28)
  assert (tau < 6.29)
}

@test "phi golden ratio"
phiConst = {
  assert (phi > 1.618)
  assert (phi < 1.619)
}

@test "sqrt2 constant"
sqrt2Const = {
  assert (sqrt2 > 1.414)
  assert (sqrt2 < 1.415)
}

@test "ln2 constant"
ln2Const = {
  assert (ln2 > 0.693)
  assert (ln2 < 0.694)
}

@test "ln10 constant"
ln10Const = {
  assert (ln10 > 2.302)
  assert (ln10 < 2.303)
}

// --- Trig functions ---

@test "sin of zero"
sinZero = {
  result = sin (radians 0.0)
  assertEq result 0.0
}

@test "cos of zero"
cosZero = {
  result = cos (radians 0.0)
  assertEq result 1.0
}

@test "tan of zero"
tanZero = {
  result = tan (radians 0.0)
  assertEq result 0.0
}

@test "asin of zero"
asinZero = {
  result = asin 0.0
  assertEq result.radians 0.0
}

@test "acos of one"
acosOne = {
  result = acos 1.0
  assertEq result.radians 0.0
}

@test "atan of zero"
atanZero = {
  result = atan 0.0
  assertEq result.radians 0.0
}

@test "atan2 basic"
atan2Basic = {
  result = atan2 1.0 1.0
  diff   = result.radians - (pi / 4.0)
  assert (abs diff < 0.0001)
}

// --- Hyperbolic functions ---

@test "sinh of zero"
sinhZero = {
  assertEq (sinh 0.0) 0.0
}

@test "cosh of zero"
coshZero = {
  assertEq (cosh 0.0) 1.0
}

@test "tanh of zero"
tanhZero = {
  assertEq (tanh 0.0) 0.0
}

// --- Power and root functions ---

@test "sqrt of 4"
sqrtFour = {
  assertEq (sqrt 4.0) 2.0
}

@test "sqrt of zero"
sqrtZero = {
  assertEq (sqrt 0.0) 0.0
}

@test "cbrt of 27"
cbrtTwentySeven = {
  assertEq (cbrt 27.0) 3.0
}

@test "cbrt of negative"
cbrtNeg = {
  assertEq (cbrt (-8.0)) (-2.0)
}

@test "pow base cases"
powBasic = {
  assertEq (pow 2.0 3.0) 8.0
  assertEq (pow 5.0 0.0) 1.0
  assertEq (pow 10.0 2.0) 100.0
}

@test "hypot"
hypotTest = {
  assertEq (hypot 3.0 4.0) 5.0
}

// --- Exp and log functions ---

@test "exp of zero"
expZero = {
  assertEq (exp 0.0) 1.0
}

@test "exp of one close to e"
expOne = {
  diff = (exp 1.0) - e
  assert (abs diff < 0.0001)
}

@test "exp2"
exp2Test = {
  assertEq (exp2 3.0) 8.0
}

@test "expm1 of zero"
expm1Zero = {
  assertEq (expm1 0.0) 0.0
}

@test "log of one"
logOne = {
  assertEq (log 1.0) 0.0
}

@test "log of e"
logE = {
  diff = (log e) - 1.0
  assert (abs diff < 0.0001)
}

@test "log2 of 8"
log2Eight = {
  assertEq (log2 8.0) 3.0
}

@test "log10 of 1000"
log10k = {
  assertEq (log10 1000.0) 3.0
}

@test "log1p of zero"
log1pZero = {
  assertEq (log1p 0.0) 0.0
}

// --- Rounding functions ---

@test "floor basic"
floorBasic = {
  assertEq (floor 3.7) 3.0
  assertEq (floor (-2.3)) (-3.0)
  assertEq (floor 5.0) 5.0
}

@test "ceil basic"
ceilBasic = {
  assertEq (ceil 3.2) 4.0
  assertEq (ceil (-2.7)) (-2.0)
  assertEq (ceil 5.0) 5.0
}

@test "trunc basic"
truncBasic = {
  assertEq (trunc 3.9) 3.0
  assertEq (trunc (-3.9)) (-3.0)
}

@test "round basic"
roundBasic = {
  assertEq (round 3.5) 4.0
  assertEq (round 2.5) 2.0
  assertEq (round 3.3) 3.0
  assertEq (round 3.7) 4.0
}

@test "fract basic"
fractBasic = {
  diff = (fract 3.75) - 0.75
  assert (abs diff < 0.0001)
}

@test "modf splits correctly"
modfTest = {
  result = modf 3.75
  assertEq result (3.0, 0.75)
}

// --- Abs, sign, copysign ---

@test "abs float"
absFloat = {
  assertEq (abs (-5.0)) 5.0
  assertEq (abs 5.0) 5.0
  assertEq (abs 0.0) 0.0
}

@test "abs int"
absInt = {
  assertEq (abs (-7)) 7
  assertEq (abs 7) 7
  assertEq (abs 0) 0
}

@test "sign positive"
signPos = {
  assertEq (sign 42.0) 1.0
}

@test "sign negative"
signNeg = {
  assertEq (sign (-42.0)) (-1.0)
}

@test "sign zero"
signZero = {
  assertEq (sign 0.0) 0.0
}

@test "copysign"
copysignTest = {
  assertEq (copysign 5.0 (-1.0)) (-5.0)
  assertEq (copysign (-5.0) 1.0) 5.0
}

// --- Min, max, clamp ---

@test "min"
minTest = {
  assertEq (min 3.0 5.0) 3.0
  assertEq (min 5.0 3.0) 3.0
}

@test "max"
maxTest = {
  assertEq (max 3.0 5.0) 5.0
  assertEq (max 5.0 3.0) 5.0
}

@test "clamp within bounds"
clampWithin = {
  assertEq (clamp 0.0 10.0 5.0) 5.0
}

@test "clamp below"
clampBelow = {
  assertEq (clamp 0.0 10.0 (-5.0)) 0.0
}

@test "clamp above"
clampAbove = {
  assertEq (clamp 0.0 10.0 15.0) 10.0
}

@test "minAll"
minAllTest = {
  assertEq (minAll [3.0, 1.0, 4.0, 1.0, 5.0]) (Some 1.0)
  assertEq (minAll []) None
}

@test "maxAll"
maxAllTest = {
  assertEq (maxAll [3.0, 1.0, 4.0, 1.0, 5.0]) (Some 5.0)
  assertEq (maxAll []) None
}

// --- Sum ---

@test "sum floats"
sumFloats = {
  assertEq (sum [1.0, 2.0, 3.0]) 6.0
  assertEq (sum []) 0.0
}

@test "sumInt"
sumIntTest = {
  assertEq (sumInt [1, 2, 3, 4]) 10
  assertEq (sumInt []) 0
}

// --- Integer math ---

@test "gcd"
gcdTest = {
  assertEq (gcd 12 8) 4
  assertEq (gcd 7 13) 1
  assertEq (gcd 0 5) 5
}

@test "lcm"
lcmTest = {
  assertEq (lcm 4 6) 12
  assertEq (lcm 3 5) 15
  assertEq (lcm 0 5) 0
}

@test "gcdAll"
gcdAllTest = {
  assertEq (gcdAll [12, 8, 4]) (Some 4)
  assertEq (gcdAll []) None
}

@test "lcmAll"
lcmAllTest = {
  assertEq (lcmAll [2, 3, 4]) (Some 12)
  assertEq (lcmAll []) None
}

@test "divmod positive"
divmodPos = {
  assertEq (divmod 7 3) (2, 1)
}

@test "divmod negative dividend"
divmodNeg = {
  result = divmod (-7) 3
  assertEq result (-3, 2)
}

@test "modPow"
modPowTest = {
  assertEq (modPow 2 10 1000) 24
  assertEq (modPow 3 0 5) 1
}

// --- Float classification ---

@test "isFinite"
isFiniteTest = {
  assertEq (isFinite 1.0) True
  assertEq (isFinite inf) False
  assertEq (isFinite negInf) False
}

@test "isInf"
isInfTest = {
  assertEq (isInf inf) True
  assertEq (isInf negInf) True
  assertEq (isInf 1.0) False
}

@test "isNaN"
isNaNTest = {
  assertEq (isNaN nan) True
  assertEq (isNaN 1.0) False
}

// --- Angle conversion ---

@test "degrees to radians"
degToRad = {
  angle = degrees 180.0
  diff  = angle.radians - pi
  assert (abs diff < 0.0001)
}

@test "radians to degrees"
radToDeg = {
  angle = radians pi
  diff  = (toDegrees angle) - 180.0
  assert (abs diff < 0.0001)
}

// --- frexp / ldexp ---

@test "frexp basic"
frexpTest = {
  result = frexp 8.0
  assertEq result (0.5, 4)
}

@test "ldexp basic"
ldexpTest = {
  assertEq (ldexp 0.5 4) 8.0
}

// --- fmod / remainder ---

@test "fmod"
fmodTest = {
  assertEq (fmod 7.0 3.0) 1.0
}

@test "remainder"
remainderTest = {
  diff = (remainder 7.0 3.0) - 1.0
  assert (abs diff < 0.0001)
}

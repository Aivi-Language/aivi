@no_prelude
module integrationTests.runtime.cryptoBuiltins

use aivi
use aivi.testing
use aivi.crypto
use aivi.text
use aivi.result

// --- SHA hashing ---

@test "sha256 produces 64-char hex"
sha256Len = {
  hash = sha256 "hello"
  assertEq (text.length hash) 64
}

@test "sha256 deterministic"
sha256Det = {
  assertEq (sha256 "test") (sha256 "test")
}

@test "sha256 different inputs differ"
sha256Diff = {
  assert (sha256 "a" != sha256 "b")
}

@test "sha384 produces 96-char hex"
sha384Len = {
  hash = sha384 "hello"
  assertEq (text.length hash) 96
}

@test "sha512 produces 128-char hex"
sha512Len = {
  hash = sha512 "hello"
  assertEq (text.length hash) 128
}

// --- randomUuid ---

@test "randomUuid produces 36-char string"
uuidLen = randomUuid
  |> text.length
  |> assertEq 36

@test "randomUuid unique"
uuidUnique = randomUuid
  |> id1 => randomUuid
    |> id2 => assert (id1 != id2)

// --- toHex / fromHex ---

@test "toHex and fromHex roundtrip"
hexRoundtrip = {
  original = crypto.fromHex "48656c6c6f"
  original match
    | Ok bytes => {
        hex = crypto.toHex bytes
        assertEq hex "48656c6c6f"
      }
    | Err _ => fail "fromHex failed"
}

@test "fromHex invalid"
fromHexInvalid = {
  result = crypto.fromHex "xyz"
  assertEq (isErr result) True
}

// --- secureEquals ---

@test "secureEquals same bytes"
secureEqSame = {
  result = crypto.fromHex "aabb"
  result match
    | Ok b  => assertEq (secureEquals b b) True
    | Err _ => fail "fromHex failed"
}

@test "secureEquals different bytes"
secureEqDiff = {
  r1 = crypto.fromHex "aabb"
  r2 = crypto.fromHex "ccdd"
  r1 match
    | Ok b1 => r2 match
      | Ok b2 => assertEq (secureEquals b1 b2) False
      | Err _ => fail "fromHex failed"
      | Err _ => fail "fromHex failed"
}

// --- randomBytes ---

@test "randomBytes produces correct length"
randomBytesLen = randomBytes 16
  |> toHex
  |> text.length
  |> assertEq 32

// --- hashPassword / verifyPassword ---

@test "hashPassword and verifyPassword"
passwordRoundtrip = hashPassword "mypassword"
  |> hash => verifyPassword "mypassword" hash
    |> assertEq True

@test "verifyPassword wrong password"
passwordWrong = hashPassword "correct"
  |> hash => verifyPassword "wrong" hash
    |> assertEq False

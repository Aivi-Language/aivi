@no_prelude
module integrationTests.runtime.craneliftInlinePaths

use aivi
use aivi.testing

// --- Simple functions that should be inlined (triggers inline_expr, substitute, freshen_ids) ---

double : Int -> Int
double = x => x * 2

triple : Int -> Int
triple = x => x * 3

inc : Int -> Int
inc = x => x + 1

dec : Int -> Int
dec = x => x - 1

@test "simple inlined functions"
simpleInlined = do Effect {
  assertEq (double 5) 10
  assertEq (triple 5) 15
  assertEq (inc 5) 6
  assertEq (dec 5) 4
}

// --- Chained inline calls (triggers inline_children recursion) ---

@test "chained inlined calls"
chainedInlines = do Effect {
  result = inc (double 5)
  assertEq result 11
  result2 = double (triple 2)
  assertEq result2 12
  result3 = inc (inc (inc 0))
  assertEq result3 3
}

// --- Inline function used multiple times (triggers freshen_ids for duplication) ---

@test "same function inlined multiple times"
multipleInlines = do Effect {
  a = double 3
  b = double 7
  c = double 10
  assertEq (a + b + c) 40
}

// --- Binary function inline (substitute multiple params) ---

add : Int -> Int -> Int
add = a b => a + b

mul : Int -> Int -> Int
mul = a b => a * b

@test "binary function inlined"
binaryInlined = do Effect {
  assertEq (add 3 4) 7
  assertEq (mul 6 7) 42
  assertEq (add (mul 2 3) (mul 4 5)) 26
}

// --- Polymorphic identity (triggers monomorphize_program, cg_type_suffix) ---

id : a -> a
id = x => x

@test "polymorphic identity monomorphized"
polyIdentity = do Effect {
  assertEq (id 42) 42
  assertEq (id "hello") "hello"
  assertEq (id True) True
  assertEq (id [1, 2]) [1, 2]
}

// --- Polymorphic const (triggers monomorphize with multiple type params) ---

const : a -> b -> a
const = x _ => x

@test "polymorphic const monomorphized"
polyConst = do Effect {
  assertEq (const 42 "ignored") 42
  assertEq (const "kept" 0) "kept"
}

// --- Recursive functions (not inlined, tests compile_definition_body depth guard) ---

factorial : Int -> Int
factorial = n => if n <= 1 then 1 else n * factorial (n - 1)

@test "recursive factorial"
recursiveFactorial = do Effect {
  assertEq (factorial 0) 1
  assertEq (factorial 1) 1
  assertEq (factorial 5) 120
  assertEq (factorial 10) 3628800
}

// --- Functions calling functions (triggers collect_called_globals) ---

square : Int -> Int
square = n => mul n n

sumOfSquares : Int -> Int -> Int
sumOfSquares = a b => add (square a) (square b)

@test "functions calling other functions"
funcCallingFunc = do Effect {
  assertEq (square 5) 25
  assertEq (sumOfSquares 3 4) 25
}

// --- Deeply nested expressions (tests inline depth limiting) ---

step1 : Int -> Int
step1 = x => x + 1

step2 : Int -> Int
step2 = x => step1 (step1 x)

step4 : Int -> Int
step4 = x => step2 (step2 x)

@test "deep expression nesting"
deepNesting = do Effect {
  assertEq (step4 0) 4
  assertEq (step4 10) 14
}

// --- Guard expressions (triggers emit_pattern_test with guards, lower_binary for comparisons) ---

classify : Int -> Text
classify =
  | n when n < 0    => "negative"
  | 0               => "zero"
  | n when n <= 10  => "small"
  | n when n <= 100 => "medium"
  | _               => "large"

@test "pattern guards with comparisons"
patternGuardsComparisons = do Effect {
  assertEq (classify (-5)) "negative"
  assertEq (classify 0) "zero"
  assertEq (classify 5) "small"
  assertEq (classify 10) "small"
  assertEq (classify 50) "medium"
  assertEq (classify 100) "medium"
  assertEq (classify 200) "large"
}

// --- Tuple in match arms (triggers lower_tuple, emit_pattern_test tuple) ---

swap = (a, b) => (b, a)

@test "tuple swap"
tupleSwap = do Effect {
  assertEq (swap (1, 2)) (2, 1)
  assertEq (swap ("a", "b")) ("b", "a")
}

// --- Record pattern matching (triggers emit_pattern_test record) ---

@test "record in match"
recordInMatch = do Effect {
  getName = person => person match
    | { name: n } => n
      assertEq (getName { name: "Alice", age: 30 }) "Alice"
}

// --- Returning closures and applying them (triggers rt_make_closure + rt_apply) ---

makeMultiplier = factor => x => x * factor

@test "closure factory"
closureFactory = do Effect {
  times3 = makeMultiplier 3
  times5 = makeMultiplier 5
  assertEq (times3 10) 30
  assertEq (times5 10) 50
  assertEq (times3 (times5 2)) 30
}

// --- Do-block with multiple effect binds (triggers rt_bind_effect chain) ---

@test "do block chain"
doBlockChain = do Effect {
  a <- pure 1
  b <- pure 2
  c <- pure 3
  d <- pure 4
  e <- pure 5
  assertEq (a + b + c + d + e) 15
}

// --- List of records (triggers multiple alloc paths) ---

@test "list of records"
listOfRecords = do Effect {
  people = [
    { name: "Alice", age: 30 }
    { name: "Bob",   age: 25 }
    { name: "Carol", age: 35 }
  ]
  first = people match
    | [p, ...] => p.name
    | []       => "none"
    assertEq first "Alice"
}

// --- ADT with many constructors (triggers multiple constructor paths) ---

Color = Red | Green | Blue | Yellow | Cyan | Magenta

colorToInt : Color -> Int
colorToInt =
  | Red     => 1
  | Green   => 2
  | Blue    => 3
  | Yellow  => 4
  | Cyan    => 5
  | Magenta => 6

@test "many constructors"
manyConstructors = do Effect {
  assertEq (colorToInt Red) 1
  assertEq (colorToInt Green) 2
  assertEq (colorToInt Blue) 3
  assertEq (colorToInt Yellow) 4
  assertEq (colorToInt Cyan) 5
  assertEq (colorToInt Magenta) 6
}

// --- Nested closures with multiple captures (triggers collect_free_locals, collect_inner_lambdas) ---

@test "nested closures multi capture"
nestedClosuresMultiCapture = do Effect {
  a = 1
  b = 2
  c = 3
  f = x => y => a + b + c + x + y
  g = f 4
  assertEq (g 5) 15
}

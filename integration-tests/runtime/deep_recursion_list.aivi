@no_prelude
module integrationTests.runtime.deepRecursionList

use aivi
use aivi.testing

// Verify that AIVI handles large collections without exhausting the call stack.
//
// Building strategy:
//   [0 .. N-1]  — the (..) range operator is evaluated iteratively in the
//                 runtime (Rust loop), so it does NOT increment the JIT call
//                 depth counter.
//
// Folding strategy:
//   List.foldl   — iterative Rust loop over the list elements; each step
//                 function call reaches at most depth 2 from the baseline.
//
// Note on the JIT call-depth guard: recursive AIVI functions go through
// rt_check_call_depth and are limited to 1000 nested frames. For large N,
// always prefer the (..) range + fold combination used here.

sumRangeRecursively = i => acc =>
  if i >= 500 then acc
  else sumRangeRecursively (i + 1) (acc + i)

buildRangeRecursively = i => acc =>
  if i >= 100 then acc
  else buildRangeRecursively (i + 1) [...acc, i]

@test "range of 50000 elements folds correctly"
rangeFold50k = {
  xs = [0..49999]
  // sum 0..49999 = 49999 * 50000 / 2 = 1249975000
  total = List.foldl (acc x => acc + x) 0 xs
  assertEq total 1249975000
}

@test "range length is correct for 50000 elements"
rangeLength50k = {
  xs = [0..49999]
  assertEq (List.length xs) 50000
}

@test "range fold with multiplication accumulator"
rangeFoldMul = {
  // product of 1..10 = 3628800 (10!)
  xs     = [1..10]
  result = List.foldl (acc x => acc * x) 1 xs
  assertEq result 3628800
}

@test "range of 10000 elements sums correctly"
rangeFold10k = {
  xs = [1..10000]
  // sum 1..10000 = 10000 * 10001 / 2 = 50005000
  total = List.foldl (acc x => acc + x) 0 xs
  assertEq total 50005000
}

@test "fold counts elements"
foldCount = {
  xs    = [0..9999]
  count = List.foldl (acc _ => acc + 1) 0 xs
  assertEq count 10000
}

@test "fold finds maximum in large range"
foldMax = {
  xs     = [0..999]
  maxVal = List.foldl (acc x => if x > acc then x else acc) 0 xs
  assertEq maxVal 999
}

@test "nested fold over moderate list"
nestedFold = {
  // sum 0..11 = 11 * 12 / 2 = 66
  xs    = [0..11]
  total = List.foldl (acc x => acc + x) 0 xs
  assertEq total 66
}

// --- Tail recursion within the safe depth limit (< 1000 frames) ---
//
// Tail-recursive helpers still go through the JIT call-depth guard. The tests
// below use a depth of 500 — comfortably within that limit — to verify that
// recursive accumulation itself works correctly.

@test "tail recursion across 500 iterations accumulates correctly"
tailRecursion500 = {
  total = sumRangeRecursively 0 0
  assertEq total 124750
}

@test "tail recursion builds list of 100 elements"
tailRecursionList100 = {
  xs    = buildRangeRecursively 0 []
  total = List.foldl (acc x => acc + x) 0 xs
  assertEq (List.length xs) 100
  assertEq total 4950
}

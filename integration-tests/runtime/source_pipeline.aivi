@no_prelude
module integrationTests.runtime.sourcePipeline

use aivi
use aivi.testing
use aivi.validation

countItems = items => List.length items

CsvUser = { id: Int, name: Text, active: Bool }

usersCountSource : Text -> Source File Int
usersCountSource = path =>
  source.transform countItems (file.json {
      path: path
      schema: source.schema.derive
  })

nonEmptyUsers : List A -> Validation (List DecodeError) (List A)
nonEmptyUsers = users =>
  if List.length users == 0 then
    Invalid [{
      path: []
      message: "expected at least one user"
    }]
  else
    Valid users

validatedUsersSource = path =>
  source.validate nonEmptyUsers (file.json {
      path: path
      schema: source.schema.derive
  })

fileDecodeErrors : SourceError File -> List DecodeError
fileDecodeErrors = err => source.decodeErrors err

envDecodeErrors : SourceError Env -> List DecodeError
envDecodeErrors = err => source.decodeErrors err

typedUsersCsvSource : Text -> Source File (List CsvUser)
typedUsersCsvSource = path =>
  file.csv {
    path: path
    schema: source.schema.derive
  }

@test "schema-first file source supports transform pipeline"
schema_first_file_source_supports_transform_pipeline = {
  path = "/tmp/aivi_source_pipeline_users.json"
  file.write_text path ~`[{"id":1,"name":"Ada"},{"id":2,"name":"Lin"}]`
  load (usersCountSource path)
   |> assertEq 2
}

@test "source validate returns structured decode errors"
source_validate_returns_structured_decode_errors = {
  path = "/tmp/aivi_source_pipeline_empty.json"
  file.write_text path "[]"
  attempt (load (validatedUsersSource path))
   |> assertErr
   |> err => {
        errs = fileDecodeErrors err
        assertEq (constructorName err) "DecodeError"
        assertEq (List.length errs) 1
        errs match
          | [onlyErr] => {
              assertEq onlyErr.path []
              assertEq onlyErr.message "expected at least one user"
            }
          | _ => fail "expected one decode error"
      }
}

@test "schema-first file csv source supports record form"
schema_first_file_csv_source_supports_record_form = {
  path = "/tmp/aivi_source_pipeline_users.csv"
  file.write_text path "id,name,active\n1,Ada,true\n2,Lin,false\n"
  load (typedUsersCsvSource path)
   |> rows => {
        assertEq (List.length rows) 2
        rows match
          | [first, second] => {
              assertEq first.id 1
              assertEq first.name "Ada"
              assertEq first.active True
              assertEq second.id 2
              assertEq second.name "Lin"
              assertEq second.active False
            }
          | _ => fail "expected two csv rows"
      }
}

@test "schema-first env decode supports config records"
schema_first_env_decode_supports_config_records = {
  env.set "AIVI_PHASE3_PORT" "8080"
  env.set "AIVI_PHASE3_DEBUG" "true"
  load (
    env.decode {
      prefix: "AIVI_PHASE3"
      schema: source.schema.derive
    }
  )
   |> cfg => {
        assertEq cfg.port 8080
        assertEq cfg.debug True
      }
}

@test "env decode missing prefix returns structured decode error"
env_decode_missing_prefix_returns_structured_decode_error = {
  attempt (
    load (
      env.decode {
        prefix: "AIVI_PHASE3_MISSING"
        schema: source.schema.derive
      }
    )
  )
   |> assertErr
   |> err => {
        assertEq (constructorName err) "DecodeError"
        assertEq (List.length (envDecodeErrors err)) 1
      }
}

@no_prelude
module integrationTests.runtime.tcoDeepRecursion

use aivi
use aivi.testing

// --- Deep iteration via collection primitives ---
//
// Large ranges and collection folds stay stack-safe in the runtime.
// These tests verify that the runtime can complete
// large numbers of iterations without error.

// ─── Tests ────────────────────────────────────────────────────────────────────

@test "countdown 10000 terminates and returns correct count"
tcoCountdown = {
  steps  = [1..10000]
  result = List.length steps
  assertEq result 10000
}

@test "sum to 10000 equals arithmetic formula"
tcoSumTo = {
  n        = 10000
  values   = [1.. n]
  result   = List.foldl (acc x => acc + x) 0 values
  expected = (n * (n + 1)) / 2
  assertEq result expected
}

@test "finds maximum in 1000-element range"
tcoMaxFold = {
  values = [1..1000]
  result = List.foldl (current n => if n > current then n else current) 0 values
  assertEq result 1000
}

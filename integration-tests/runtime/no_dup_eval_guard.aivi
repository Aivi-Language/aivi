@no_prelude
module integrationTests.runtime.noDupEvalGuard

use aivi
use aivi.testing

// Guard expressions are pure boolean conditions.  A correct implementation
// evaluates each guard at most once per arm check (the first arm whose
// pattern *and* guard both succeed is chosen; subsequent arms are not
// evaluated).

// --- Basic guard selection ---

@test "first matching guard wins"
firstGuardWins = do Effect {
  classify = n => n match
    | n when n < 0   => "negative"
    | 0              => "zero"
    | n when n < 10  => "small"
    | n when n < 100 => "medium"
    | _              => "large"

    assertEq (classify (-5)) "negative"
    assertEq (classify 0) "zero"
    assertEq (classify 7) "small"
    assertEq (classify 42) "medium"
    assertEq (classify 200) "large"
}

// --- Guard with complex pure expression ---
//
// The guard expression may involve multiple sub-expressions.  Even if the
// compiler could inline or duplicate a sub-expression, the visible result
// must be identical to evaluating the guard once.

@test "complex guard expression correct"
complexGuardExpression = do Effect {
  checkRange = lo => hi => n => n match
    | n when n >= lo && n <= hi => True
    | _                         => False

    assertEq (checkRange 1 10 5) True
    assertEq (checkRange 1 10 0) False
    assertEq (checkRange 1 10 11) False
    assertEq (checkRange 1 10 1) True
    assertEq (checkRange 1 10 10) True
}

// --- Guard skips remaining arms after first match ---
//
// Once a guard passes, subsequent arm guards must not be evaluated.
// We model this with a counter: advance it in the chosen arm and verify
// only that arm fired.

machine ArmCounter =
  {
             -> ArmNone  : reset {}
    ArmNone  -> ArmOne   : hitOne {}
    ArmNone  -> ArmTwo   : hitTwo {}
    ArmNone  -> ArmThree : hitThree {}
    ArmOne   -> ArmDone  : done {}
    ArmTwo   -> ArmDone  : done {}
    ArmThree -> ArmDone  : done {}
  }

@test "only the matching guard arm executes its body"
onlyMatchingArmBody = do Effect {
  { hitOne, hitTwo, hitThree, done, currentState } = ArmCounter

  n = 5 // falls in the "small" range

  // Dispatch to the correct arm body.
  _ <- n match
    | n when n < 0  => hitOne {}
    | n when n < 10 => hitTwo {}
    | _             => hitThree {}

  // Only arm-two's body ran.
  assertEq (constructorName (currentState Unit)) "ArmTwo"
}

// --- Guard evaluated per-arm, not globally ---
//
// When a guard fails, the runtime moves to the next arm.  Here the first
// arm's guard fails and the second arm should be tried exactly once.

@test "guard failure falls through to next arm"
guardFallThrough = do Effect {
  prioritise = n => n match
    | n when n > 100 => "big"
    | n when n > 10  => "medium"
    | _              => "small"

    assertEq (prioritise 200) "big"
    assertEq (prioritise 50) "medium"
    assertEq (prioritise 5) "small"
}

// --- Guard with binding pattern ---
//
// The pattern variable is in scope inside the guard.

SafeDiv A = Safe A | DivByZero

safeDiv : Int -> Int -> SafeDiv Int
safeDiv = a b => b match
  | b when b == 0 => DivByZero
  | b             => Safe (a / b)

@test "pattern variable visible in guard"
patternVarInGuard = do Effect {
  assertEq (safeDiv 10 2) (Safe 5)
  assertEq (safeDiv 10 0) DivByZero
}

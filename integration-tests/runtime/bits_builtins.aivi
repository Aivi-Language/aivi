@no_prelude
module integrationTests.runtime.bitsBuiltins

use aivi
use aivi.testing
use aivi.bits
use aivi.result

// --- fromInt / toInt ---

@test "fromInt and toInt roundtrip"
fromToInt = {
  b = fromInt 255
  assertEq (toInt b) 255
}

@test "fromInt zero"
fromIntZero = {
  b = fromInt 0
  assertEq (toInt b) 0
}

@test "fromInt large"
fromIntLarge = {
  b = fromInt 65535
  assertEq (toInt b) 65535
}

// --- fromBytes / toBytes ---

@test "fromBytes and toBytes roundtrip"
fromToBytes = {
  b     = fromInt 42
  bytes = toBytes b
  b2    = fromBytes bytes
  assertEq (toInt b2) 42
}

// --- zero / ones ---

@test "zero creates all-zero bits"
zeroTest = {
  b = zero 2
  assertEq (length b) 16
  assertEq (toInt b) 0
}

@test "ones creates all-one bits"
onesTest = {
  b = ones 1
  assertEq (toInt b) 255
}

// --- and ---

@test "and operation"
andTest = {
  a      = fromInt 240
  b      = fromInt 170
  result = and a b
  assertEq (toInt result) 160
}

// --- or ---

@test "or operation"
orTest = {
  a      = fromInt 240
  b      = fromInt 15
  result = or a b
  assertEq (toInt result) 255
}

// --- xor ---

@test "xor operation"
xorTest = {
  a      = fromInt 240
  b      = fromInt 170
  result = xor a b
  assertEq (toInt result) 90
}

// --- complement ---

@test "complement flips all bits"
complementTest = {
  b = fromInt 0
  c = complement b
  assertEq (toInt c) -1
}

// --- shiftLeft / shiftRight ---

@test "shiftLeft"
shiftLeftTest = {
  b      = fromInt 1
  result = shiftLeft 3 b
  assertEq (toInt result) 8
}

@test "shiftRight"
shiftRightTest = {
  b      = fromInt 8
  result = shiftRight 3 b
  assertEq (toInt result) 1
}

// --- get / set / clear / toggle ---

@test "get bit"
getBitTest = {
  b = fromInt 4
  assertEq (get 61 b) True
  assertEq (get 0 b) False
}

@test "set bit"
setBitTest = {
  b  = fromInt 0
  b2 = set 3 b
  assertEq (get 3 b2) True
}

@test "clear bit"
clearBitTest = {
  b  = fromInt 255
  b2 = clear 56 b
  assertEq (get 56 b2) False
  assertEq (get 57 b2) True
}

@test "toggle bit"
toggleBitTest = {
  b  = fromInt 0
  b2 = toggle 5 b
  assertEq (get 5 b2) True
  b3 = toggle 5 b2
  assertEq (get 5 b3) False
}

// --- length ---

@test "length of bits"
lengthTest = {
  b = fromInt 255
  assertEq (length b) 64
}

// --- slice ---

@test "slice bits"
sliceTest = {
  b = fromInt 65535
  s = slice 6 7 b
  assertEq (toInt s) 255
}

// --- popCount ---

@test "popCount"
popCountTest = {
  b = fromInt 170
  assertEq (popCount b) 4
}

@test "popCount all zeros"
popCountZero = {
  b = fromInt 0
  assertEq (popCount b) 0
}

@test "popCount all ones"
popCountOnes = {
  b = ones 1
  assertEq (popCount b) 8
}

// --- BitStream ---

@test "streamFromBits and streamRemaining"
streamBasic = {
  b = fromInt 65535
  s = streamFromBits b
  assertEq (streamRemaining s) 8
}

@test "streamRead success"
streamReadOk = {
  b      = fromInt 65535
  s      = streamFromBits b
  result = streamRead 1 s
  assertEq (isOk result) True
}

@test "streamRead past end"
streamReadPastEnd = {
  b      = fromInt 255
  s      = streamFromBits b
  result = streamRead 10 s
  assertEq (isErr result) True
}

@test "streamPeek does not advance"
streamPeekNoAdvance = {
  b = fromInt 65535
  s = streamFromBits b
  _ = streamPeek 1 s
  assertEq (streamRemaining s) 8
}

@test "streamPeek past end"
streamPeekPastEnd = {
  b      = fromInt 255
  s      = streamFromBits b
  result = streamPeek 10 s
  assertEq (isErr result) True
}

@test "streamSkip advances offset"
streamSkipOk = {
  b      = fromInt 65535
  s      = streamFromBits b
  result = streamSkip 1 s
  result match
    | Ok s2 => assertEq (streamRemaining s2) 7
    | Err _ => fail "skip failed"
}

@test "streamSkip past end"
streamSkipPastEnd = {
  b      = fromInt 255
  s      = streamFromBits b
  result = streamSkip 10 s
  assertEq (isErr result) True
}

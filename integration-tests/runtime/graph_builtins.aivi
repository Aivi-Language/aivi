@no_prelude
module integrationTests.runtime.graphBuiltins

use aivi
use aivi.testing
use aivi.graph

// --- empty ---

@test "empty graph has no nodes"
emptyGraph = {
  g = empty
  assertEq g.nodes []
  assertEq g.edges []
}

// --- addNode ---

@test "addNode to empty graph"
addNodeEmpty = {
  g = addNode empty 1
  assertEq g.nodes [1]
}

@test "addNode duplicate is idempotent"
addNodeDup = {
  g = addNode (addNode empty 1) 1
  assertEq g.nodes [1]
}

// --- addEdge ---

@test "addEdge creates edge"
addEdgeTest = {
  g = addEdge empty { from: 1, to: 2, weight: 1.0 }
  assertEq (List.length g.edges) 1
}

// --- fromEdges ---

@test "fromEdges builds graph"
fromEdgesTest = {
  g = fromEdges [(1, 2), (2, 3)]
  assertEq (List.length g.edges) 2
}

// --- fromWeightedEdges ---

@test "fromWeightedEdges builds graph"
fromWeightedEdgesTest = {
  g = fromWeightedEdges [(1, 2, 1.5), (2, 3, 2.0)]
  assertEq (List.length g.edges) 2
}

// --- removeEdge ---

@test "removeEdge removes matching edge"
removeEdgeTest = {
  edge = { from: 1, to: 2, weight: 1.0 }
  g    = addEdge empty edge
  g2   = removeEdge g edge
  assertEq g2.edges []
}

// --- removeNode ---

@test "removeNode removes node and its edges"
removeNodeTest = {
  g     = fromEdges [(1, 2), (2, 3), (1, 3)]
  g2    = removeNode g 2
  edges = g2.edges
  assertEq (List.length edges) 1
}

// --- normalize ---

@test "normalize adds edge endpoints to nodes"
normalizeTest = {
  g  = { nodes: [], edges: [{ from: 1, to: 2, weight: 1.0 }] }
  g2 = normalize g
  assertEq (List.length g2.nodes) 2
}

// --- isValid ---

@test "isValid on valid graph"
isValidOk = {
  g = normalize (fromEdges [(1, 2)])
  assertEq (isValid g) True
}

@test "isValid on invalid graph"
isValidBad = {
  g = { nodes: [1], edges: [{ from: 1, to: 99, weight: 1.0 }] }
  assertEq (isValid g) False
}

// --- dedupEdges ---

@test "dedupEdges removes duplicates"
dedupEdgesTest = {
  edge = { from: 1, to: 2, weight: 1.0 }
  g    = { nodes: [1, 2], edges: [edge, edge, edge] }
  g2   = dedupEdges g
  assertEq (List.length g2.edges) 1
}

// --- neighbors ---

@test "neighbors returns outgoing"
neighborsTest = {
  g  = normalize (fromEdges [(1, 2), (1, 3)])
  ns = neighbors g 1
  assertEq (List.length ns) 2
}

// --- inNeighbors ---

@test "inNeighbors returns incoming"
inNeighborsTest = {
  g  = normalize (fromEdges [(1, 3), (2, 3)])
  ns = inNeighbors g 3
  assertEq (List.length ns) 2
}

// --- edgesFrom / edgesTo ---

@test "edgesFrom returns outgoing edges"
edgesFromTest = {
  g  = normalize (fromEdges [(1, 2), (1, 3), (2, 3)])
  es = edgesFrom g 1
  assertEq (List.length es) 2
}

@test "edgesTo returns incoming edges"
edgesToTest = {
  g  = normalize (fromEdges [(1, 3), (2, 3)])
  es = edgesTo g 3
  assertEq (List.length es) 2
}

// --- degreeOut / degreeIn ---

@test "degreeOut"
degreeOutTest = {
  g = normalize (fromEdges [(1, 2), (1, 3)])
  assertEq (degreeOut g 1) 2
}

@test "degreeIn"
degreeInTest = {
  g = normalize (fromEdges [(1, 3), (2, 3)])
  assertEq (degreeIn g 3) 2
}

// --- bfs ---

@test "bfs finds path"
bfsTest = {
  g    = normalize (fromEdges [(1, 2), (2, 3), (3, 4)])
  path = bfs g { start: 1, end: 4 }
  assertEq (List.at 0 path) (Some 1)
}

@test "bfs start equals end"
bfsSame = {
  g    = normalize (fromEdges [(1, 2)])
  path = bfs g { start: 1, end: 1 }
  assertEq path [1]
}

@test "bfs no path"
bfsNoPath = {
  g    = normalize (fromEdges [(1, 2)])
  path = bfs g { start: 2, end: 1 }
  assertEq path []
}

// --- dfs ---

@test "dfs visits reachable"
dfsTest = {
  g       = normalize (fromEdges [(1, 2), (2, 3), (1, 4)])
  visited = dfs g 1
  assertEq (List.length visited) 4
}

// --- shortestPathUnweighted ---

@test "shortestPathUnweighted"
shortestUnweighted = {
  g    = normalize (fromEdges [(1, 2), (2, 3), (1, 3)])
  path = shortestPathUnweighted g 1 3
  assertEq (List.length path) 2
}

// --- topoSort ---

@test "topoSort dag"
topoSortDag = {
  g      = normalize (fromEdges [(1, 2), (1, 3), (2, 4), (3, 4)])
  sorted = topoSort g
  assertEq (List.length sorted) 4
}

@test "topoSort cycle returns empty"
topoSortCycle = {
  g      = normalize (fromEdges [(1, 2), (2, 3), (3, 1)])
  sorted = topoSort g
  assertEq sorted []
}

// --- hasCycle ---

@test "hasCycle true"
hasCycleTrue = {
  g = normalize (fromEdges [(1, 2), (2, 3), (3, 1)])
  assertEq (hasCycle g) True
}

@test "hasCycle false"
hasCycleFalse = {
  g = normalize (fromEdges [(1, 2), (2, 3)])
  assertEq (hasCycle g) False
}

// --- shortestPath (Dijkstra) ---

@test "shortestPath weighted"
shortestPathWeighted = {
  g    = normalize (fromWeightedEdges [(1, 2, 1.0), (2, 3, 1.0), (1, 3, 10.0)])
  path = shortestPath g 1 3
  assertEq (List.length path) 3
}

// --- relax ---

@test "relax updates distance"
relaxTest = {
  dists  = Map.insert 1 0.0 Map.empty
  edge   = { from: 1, to: 2, weight: 5.0 }
  result = relax dists 0.0 edge
  assertEq result.updated True
}

@test "relax no update when worse"
relaxNoUpdate = {
  dists  = Map.insert 2 1.0 (Map.insert 1 0.0 Map.empty)
  edge   = { from: 1, to: 2, weight: 10.0 }
  result = relax dists 0.0 edge
  assertEq result.updated False
}

// --- relaxEdges ---

@test "relaxEdges counts updates"
relaxEdgesTest = {
  dists  = Map.insert 1 0.0 Map.empty
  edges  = [{ from: 1, to: 2, weight: 3.0 }, { from: 1, to: 3, weight: 5.0 }]
  result = relaxEdges dists 0.0 edges
  assertEq result.count 2
}

// --- Graph domain (+) ---

@test "graph domain addition"
graphDomainAdd = {
  g1 = fromEdges [(1, 2)]
  g2 = fromEdges [(3, 4)]
  g3 = use graph in g1 + g2
  assertEq (List.length g3.edges) 2
}

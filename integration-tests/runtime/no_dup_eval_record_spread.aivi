@no_prelude
module integrationTests.runtime.noDupEvalRecordSpread

use aivi
use aivi.testing

// In a record spread expression `{ ...base, field: val }`, the `base`
// expression is evaluated exactly once, even when multiple fields are
// overridden.  The spread copies all fields from `base` and then applies
// the explicit overrides.

machine SpreadCounter =
  {
               -> SpreadZero  : reset {}
    SpreadZero -> SpreadOne   : tap {}
    SpreadOne  -> SpreadTwo   : tap {}
    SpreadTwo  -> SpreadThree : tap {}
  }

// --- Basic spread: all source fields are present ---

@test "spread copies all fields from base"
spreadCopiesAllFields = do Effect {
  base = { x: 1, y: 2, z: 3 }
  r    = { ...base, y: 99 }
  assertEq r.x 1
  assertEq r.y 99
  assertEq r.z 3
}

// --- Base expression evaluated once when binding is used ---
//
// We bind an effectful computation to a name first; then use that name
// in the spread.  The name lookup must not re-evaluate the original effect.

@test "bound base expression used once in spread"
boundBaseOnce = do Effect {
  { tap, currentState } = SpreadCounter

  // Advance the counter: "compute" the base record.
  _ <- tap {}
  assertEq (constructorName (currentState Unit)) "SpreadOne"

  base = { x: 10, y: 20 }

  // Spread from the already-computed record: no new effects.
  r = { ...base, y: 99 }
  assertEq r.x 10
  assertEq r.y 99

  // Counter unchanged: spread didn't re-run anything.
  assertEq (constructorName (currentState Unit)) "SpreadOne"
}

// --- Multiple field overrides: base evaluated once ---

@test "multiple overrides do not re-evaluate base"
multipleOverridesOnce = do Effect {
  { tap, currentState } = SpreadCounter

  _ <- tap {}
  assertEq (constructorName (currentState Unit)) "SpreadOne"

  base = { a: 1, b: 2, c: 3, d: 4 }

  // Override several fields at once.
  r = { ...base, b: 20, d: 40 }
  assertEq r.a 1
  assertEq r.b 20
  assertEq r.c 3
  assertEq r.d 40

  // Still SpreadOne: the spread of a bound record is free of extra effects.
  assertEq (constructorName (currentState Unit)) "SpreadOne"
}

// --- Patch operator `<|` shares the same single-evaluation guarantee ---

@test "patch operator evaluates base once"
patchOnce = do Effect {
  base    = { score: 0, name: "Alice", active: True }
  patched = base <| { score: _ + 10, active: False }
  assertEq patched.score 10
  assertEq patched.name "Alice"
  assertEq patched.active False
}

// --- Spread from a computed record (function result) ---

@test "spread from function result evaluated once"
spreadFromFunctionResult = do Effect {
  makeBase = n => { value: n, doubled: n * 2, label: "base" }

  r = { ...(makeBase 5), label: "overridden" }
  assertEq r.value 5
  assertEq r.doubled 10
  assertEq r.label "overridden"
}

@no_prelude
module integrationTests.runtime.collectionsBuiltins

use aivi
use aivi.testing

// --- Map.empty and basic operations ---

@test "map empty has size 0"
mapEmptySize = {
  m = Map.empty
  assertEq (Map.size m) 0
}

@test "map insert and get"
mapInsertGet = {
  m = Map.insert "a" 1 Map.empty
  assertEq (Map.get "a" m) (Some 1)
  assertEq (Map.get "b" m) None
}

@test "map size after inserts"
mapSizeInserts = {
  m = Map.insert "a" 1 (Map.insert "b" 2 Map.empty)
  assertEq (Map.size m) 2
}

@test "map has"
mapHas = {
  m = Map.insert "x" 42 Map.empty
  assertEq (Map.has "x" m) True
  assertEq (Map.has "y" m) False
}

@test "map remove"
mapRemove = {
  m  = Map.insert "a" 1 (Map.insert "b" 2 Map.empty)
  m2 = Map.remove "a" m
  assertEq (Map.get "a" m2) None
  assertEq (Map.get "b" m2) (Some 2)
}

@test "map update existing"
mapUpdate = {
  m  = Map.insert "a" 10 Map.empty
  m2 = Map.update "a" (v => v + 5) m
  assertEq (Map.get "a" m2) (Some 15)
}

@test "map update missing key unchanged"
mapUpdateMissing = {
  m  = Map.insert "a" 10 Map.empty
  m2 = Map.update "b" (v => v + 5) m
  assertEq (Map.size m2) 1
}

@test "map keys"
mapKeys = {
  m  = Map.insert "a" 1 Map.empty
  ks = Map.keys m
  assertEq ks ["a"]
}

@test "map values"
mapValues = {
  m  = Map.insert "a" 1 Map.empty
  vs = Map.values m
  assertEq vs [1]
}

@test "map fromList and toList"
mapFromList = {
  m = Map.fromList [("a", 1), ("b", 2)]
  assertEq (Map.get "a" m) (Some 1)
  assertEq (Map.get "b" m) (Some 2)
  assertEq (Map.size m) 2
}

@test "map union"
mapUnion = {
  m1 = Map.fromList [("a", 1)]
  m2 = Map.fromList [("b", 2)]
  m3 = Map.union m1 m2
  assertEq (Map.get "a" m3) (Some 1)
  assertEq (Map.get "b" m3) (Some 2)
}

@test "map union right overrides"
mapUnionOverride = {
  m1 = Map.fromList [("a", 1)]
  m2 = Map.fromList [("a", 2)]
  m3 = Map.union m1 m2
  assertEq (Map.get "a" m3) (Some 2)
}

@test "map getOrElse"
mapGetOrElse = {
  m = Map.fromList [("a", 1)]
  assertEq (Map.getOrElse "a" 0 m) 1
  assertEq (Map.getOrElse "b" 0 m) 0
}

@test "map map values"
mapMapValues = {
  m  = Map.fromList [("a", 1), ("b", 2)]
  m2 = Map.map (v => v * 10) m
  assertEq (Map.get "a" m2) (Some 10)
  assertEq (Map.get "b" m2) (Some 20)
}

// --- Set operations ---

@test "set empty has size 0"
setEmptySize = {
  s = Set.empty
  assertEq (Set.size s) 0
}

@test "set insert and contains"
setInsertContains = {
  s = Set.insert 1 (Set.insert 2 Set.empty)
  assertEq (Set.has 1 s) True
  assertEq (Set.has 3 s) False
}

@test "set remove"
setRemove = {
  s  = Set.insert 1 (Set.insert 2 Set.empty)
  s2 = Set.remove 1 s
  assertEq (Set.has 1 s2) False
  assertEq (Set.has 2 s2) True
}

@test "set union"
setUnion = {
  s1 = Set.fromList [1, 2, 3]
  s2 = Set.fromList [3, 4, 5]
  s3 = Set.union s1 s2
  assertEq (Set.size s3) 5
  assertEq (Set.has 1 s3) True
  assertEq (Set.has 5 s3) True
}

@test "set intersection"
setIntersection = {
  s1 = Set.fromList [1, 2, 3]
  s2 = Set.fromList [2, 3, 4]
  s3 = Set.intersection s1 s2
  assertEq (Set.size s3) 2
  assertEq (Set.has 2 s3) True
  assertEq (Set.has 3 s3) True
  assertEq (Set.has 1 s3) False
}

@test "set difference"
setDifference = {
  s1 = Set.fromList [1, 2, 3]
  s2 = Set.fromList [2, 3, 4]
  s3 = Set.difference s1 s2
  assertEq (Set.size s3) 1
  assertEq (Set.has 1 s3) True
  assertEq (Set.has 2 s3) False
}

@test "set fromList deduplicates"
setFromListDedup = {
  s = Set.fromList [1, 1, 2, 2, 3]
  assertEq (Set.size s) 3
}

@test "set toList"
setToList = {
  s  = Set.fromList [1]
  xs = Set.toList s
  assertEq xs [1]
}

// --- Queue operations ---

@test "queue basic"
queueBasic = {
  q = Queue.enqueue 1 (Queue.enqueue 2 Queue.empty)
  assertEq (Queue.peek q) (Some 2)
}

// --- Heap operations ---

@test "heap basic"
heapBasic = {
  h = Heap.push 3 (Heap.push 1 (Heap.push 2 Heap.empty))
  assertEq (Heap.peekMin h) (Some 1)
  assertEq (Heap.size h) 3
}

@test "heap fromList"
heapFromList = {
  h = Heap.fromList [5, 3, 1, 4, 2]
  assertEq (Heap.peekMin h) (Some 1)
  assertEq (Heap.size h) 5
}

@no_prelude
module integrationTests.runtime.noDupEvalMatchScrutinee

use aivi
use aivi.testing

// A step counter machine: the same transition name `step` works from each
// distinct source state, which lets us reuse it like a numeric counter.
machine StepCounter =
  {
           -> Count0 : reset {}
    Count0 -> Count1 : step {}
    Count1 -> Count2 : step {}
    Count2 -> Count3 : step {}
  }

// All scenarios are in one @test function so that the shared machine state
// does not leak between test entries.

@test "match scrutinee evaluated once in all scenarios"
matchScrutineeAllScenarios = do Effect {
  { step, currentState } = StepCounter

  // ── Scenario 1: effectful binding + match does not re-run the effect ────
  //
  // `step {}` runs once (counter → Count1); the match on the bound value
  // must not trigger another step.  We use `attempt` so the result is a
  // `Result` that can be matched with standard constructors.

  res1 <- attempt (step {})
  assertEq (constructorName (currentState Unit)) "Count1"

  res1 match
    | Ok _  => assertEq (constructorName (currentState Unit)) "Count1"
    | Err _ => fail "step should not fail from Count0"

  // ── Scenario 2: pure-expression scrutinee is consistent across arms ─────
  //
  // A pure scrutinee like `n * n` is evaluated once; every arm sees the
  // same computed value.

  n      = 6
  result = (n * n) match
    | 36 => "thirty-six"
    | _  => "wrong"
    assertEq result "thirty-six"

  // Counter still at Count1 — no extra effects.
  assertEq (constructorName (currentState Unit)) "Count1"

  // ── Scenario 3: multiple arms, scrutinee still evaluated once ───────────
  //
  // Regardless of how many arms the match has, the scrutinee is evaluated
  // once; the first matching arm is chosen and the rest are skipped.

  m = 42
  _ = m match
    | 1  => "one"
    | 42 => "forty-two"
    | _  => "other"

  // Counter still Count1: the match on a pure value didn't trigger step.
  assertEq (constructorName (currentState Unit)) "Count1"

  // ── Scenario 4: match result is used correctly ──────────────────────────

  label = m match
    | n when n > 40 => "large"
    | _             => "small"
    assertEq label "large"
}

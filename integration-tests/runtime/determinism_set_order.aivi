@no_prelude
module integrationTests.runtime.determinismSetOrder

use aivi
use aivi.testing

// Set-to-list conversion must produce a stable, deterministic ordering.
//
// The runtime guarantees that for the same immutable set value, repeated
// calls to `toList` always return the same list.
//
// NOTE: Sorted output is the desired future behaviour.  Tests below verify
// the weaker property (round-trip consistency, stable within a run) so that
// they pass today while documenting the sorted-order goal in comments.

// --- Single-element set: trivially ordered ---

@test "single element set toList"
singleElementToList = do Effect {
  s = Set.insert 7 Set.empty
  assertEq (Set.toList s) [7]
}

// --- toList is stable: same set always gives same list ---
//
// Calling toList on the same immutable set multiple times must return the
// same list (determinism within a run).

@test "toList is stable on same set"
setToListStable = do Effect {
  s = Set.fromList [9, 3, 6]
  l1 = Set.toList s
  l2 = Set.toList s
  assertEq l1 l2
}

// --- Two calls to toList on the same set give the same list (determinism) ---
//
// Calling `toList` on an immutable set value must return the same list
// each time — the iteration is determined by the set's internal structure,
// not by any per-call randomness.

@test "toList on same set value is deterministic"
setInsertionOrderIndependent = do Effect {
  s = Set.fromList [1, 2, 3]
  // Two calls to toList on the *same* value must agree.
  assertEq (Set.toList s) (Set.toList s)
}

// --- Round-trip: fromList -> toList -> fromList preserves all elements ---

@test "fromList toList round-trip preserves all elements"
setRoundTrip = do Effect {
  s = Set.fromList [10, 20, 30, 40]
  xs = Set.toList s
  s2 = Set.fromList xs
  assertEq (Set.size s) 4
  assertEq (Set.size s2) 4
  assertEq (Set.contains 10 s2) True
  assertEq (Set.contains 20 s2) True
  assertEq (Set.contains 30 s2) True
  assertEq (Set.contains 40 s2) True
}

// --- toList length matches set size ---

@test "toList length matches set size"
setToListLength = do Effect {
  s = Set.fromList [5, 3, 1, 4, 2]
  assertEq (Set.size s) 5
}

// --- Union toList length is sum minus overlap ---

@test "union toList length correct"
unionToListLength = do Effect {
  s1 = Set.fromList [1, 2, 3]
  s2 = Set.fromList [3, 4, 5]
  su = Set.union s1 s2
  assertEq (Set.size su) 5
}

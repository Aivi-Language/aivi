@no_prelude
module integrationTests.runtime.effectfulTupleLoopState

use aivi
use aivi.testing

advanceHandleState = state => state match
  | (n, currentHandle) =>
      if n >= 200 then pure n
      else advanceHandleState (n + 1, currentHandle)

advanceHandleMapState = state => state match
  | (n, currentHandles) =>
      if n >= 200 then pure n
      else advanceHandleMapState (n + 1, currentHandles)

@test "tuple loop carries effectful record state"
tupleLoopCarriesEffectfulRecordState = {
  handle = {
    cancel: pure Unit
    reusable: True
    signature: "tick"
  }
  advanceHandleState (0, handle)
  |> total => assertEq total 200
}

@test "tuple loop carries maps of effectful records"
tupleLoopCarriesEffectfulHandleMaps = {
  handle = {
    cancel: pure Unit
    reusable: True
    signature: "tick"
  }
  handles = Map.insert "tick" handle Map.empty
  advanceHandleMapState (0, handles)
  |> total => assertEq total 200
}

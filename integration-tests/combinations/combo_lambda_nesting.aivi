@no_prelude
module integrationTests.combinations.comboLambdaNesting

use aivi
use aivi.testing

transformBy = x => n => n + x

@test "lambda capture stays stable without do"
lambdaCaptureStaysStableWithoutDo = Unit
~|>_ => assertEq ((transformBy 10) 5) 15
~|>_ => assertEq ((transformBy 10) 32) 42

optionLambdaResult = factor => (Some 6) match
  | Some a => Some ((x => x * factor) a)
  | None   => None

@test "lambda in option-style helper captures outer"
lambdaInOptionStyleHelperCapturesOuter = assertEq (optionLambdaResult 7) (Some 42)

resultLambdaResult = offset => (Ok 10) match
  | Ok a  => Ok ((x => x + offset) a)
  | Err e => Err e

@test "lambda in result-style helper captures outer"
lambdaInResultStyleHelperCapturesOuter = assertEq (resultLambdaResult 100) (Ok 110)

mapWithScale = scale xs => xs match
  | []         => []
  | [x, ...rs] => [(n => n * scale) x, ...mapWithScale scale rs]

@test "lambda in list-style helper captures outer"
lambdaInListStyleHelperCapturesOuter = assertEq (mapWithScale 10 [1, 2, 3]) [10, 20, 30]

makeAdder = opt => opt match
  | Some n => x => x + n
  | None   => x => x

@test "lambda returned from match arm captures pattern var"
lambdaFromMatchArm = Unit
~|>_ => assertEq ((makeAdder (Some 10)) 5) 15
~|>_ => assertEq ((makeAdder None) 5) 5

@test "triple nested lambdas keep captured values"
tripleNesting = assertEq (((x => y => 10 + x + y) 20) 12) 42

makeAdderN : Int -> Int -> Int
makeAdderN = n => x => x + n

buildAdders : Int -> List (Int -> Int)
buildAdders = n => if n <= 0 then [] else [makeAdderN n, ...(buildAdders (n - 1))]

applyAll : List (Int -> Int) -> Int -> List Int
applyAll = fns arg => fns match
  | []           => []
  | [f, ...rest] => [f arg, ...(applyAll rest arg)]

@test "list of closures each captures creation-time value"
closureListCapture = assertEq (applyAll (buildAdders 3) 10) [13, 12, 11]

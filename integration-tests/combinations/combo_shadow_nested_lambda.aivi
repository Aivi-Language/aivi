@no_prelude
module integrationTests.combinations.comboShadowNestedLambda

use aivi
use aivi.testing

makeAdder = x => (Some 10) match
  | None   => z => z + x
  | Some x => z => z + x

@test "nested lambda uses pattern-bound x not outer param x"
nestedLambdaUsesPatternX = assertEq ((makeAdder 100) 5) 15

globalX = 1000

process = x => v => v match
  | Some x => z => globalX + x + z
  | None   => z => globalX + x + z

@test "three-level shadowing: lambda uses closest x"
threeLevelShadowing = Unit
~|>_ => assertEq ((process 200 (Some 30)) 0) 1030
~|>_ => assertEq ((process 200 None) 0) 1200

armScopedAdder = x => (Some 7) match
  | None   => z => z + x
  | Some x => z => z + x

@test "lambda in former do arm uses arm-scoped x"
lambdaInFormerDoArmUsesArmScopedX = assertEq ((armScopedAdder 50) 0) 7

pickValue : Int -> Option Int -> Int
pickValue = x => opt => opt match
  | Some x => x
  | None   => x

@test "pattern binding shadows outer param"
patternShadowsOuterParam = Unit
~|>_ => assertEq (pickValue 100 (Some 5)) 5
~|>_ => assertEq (pickValue 100 None) 100

nestedMatchResult = x => (Some 3) match
  | Some x => x
  | None   => 0

@test "shadow in nested match: innermost binding wins"
nestedMatchShadow = assertEq (nestedMatchResult 1) 3

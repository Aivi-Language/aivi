@no_prelude
module integrationTests.combinations.comboGeneratorNesting

use aivi
use aivi.testing

// List transforms replacing the older generator-shaped examples.
// Verifies captures and nesting still behave correctly in direct collection code.

// --- Conditional mapping over a list ---

classify = n => if n % 2 == 0 then n * 10 else n
scaleBy  = factor => n => n * factor

@test "list mapping uses function with conditional logic"
generatorWithMatch = assertEq (List.map classify [1, 2, 3, 4, 5]) [1, 20, 3, 40, 5]

// --- Plain collection filtering with outer capture ---

@test "list filtering captures outer scope"
generatorLambdaFilter =
  assertEq (
    [1, 2, 3, 4, 5]
       |> List.filter (n => n > 3)
       |> List.map (n => n * 2)
  ) [8, 10]

assertValuesWithBase = base => assertEq (List.map (n => n + base) [1, 2, 3]) [101, 102, 103]

@test "effect-bound values can feed later list shaping"
generatorInDoEffect = pure 100
   |> assertValuesWithBase

// --- Fan-out returned from function captures function arg ---

makeScaledGen = factor => List.map (scaleBy factor) [1, 2, 3, 4]

@test "mapped list returned from function captures arg"
generatorFromFunction = assertEq (makeScaledGen 5) [5, 10, 15, 20]

// --- Nested list expansion flattened after per-item expansion ---

pairWithOffsets = base => [base + 1, base + 2]

nestedValues = List.flatMap pairWithOffsets [10, 20]

@test "nested list expansion flattens per item"
nestedGenerators = assertEq nestedValues [11, 12, 21, 22]

// --- Pipe chain stays ordinary collection code ---

double = x => x * 2
inc    = x => x + 1

@test "list mapping can keep pipe chains in element logic"
generatorPipeChain = assertEq (List.map (n => n |> double |> inc) [1, 2, 3]) [3, 5, 7]

// --- Per-item expansion and guard-like filtering ---

matchingPairsFor = target => x =>
  [6, 7, 8, 9]
     |> List.filter (y => x + y == target)
     |> List.map (y => (x, y))

cartesianPairs = List.flatMap (matchingPairsFor 10) [1, 2, 3, 4]

@test "cartesian expansion can capture outer state"
generatorCartesianGuard = assertEq cartesianPairs [(1, 9), (2, 8), (3, 7), (4, 6)]

// --- Mapping can still capture outer state directly ---

scaledOuterValues = factor => List.map (scaleBy factor) [1, 2, 3, 4, 5]

@test "mapping captures outer scope"
generatorLoopCapturesOuter = assertEq (scaledOuterValues 2) [2, 4, 6, 8, 10]

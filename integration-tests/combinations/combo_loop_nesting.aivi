@no_prelude
module integrationTests.combinations.comboLoopNesting

use aivi
use aivi.testing
use aivi.logic

accumulateWithFactor = factor => i => acc =>
  if i > 5 then acc
  else accumulateWithFactor factor (i + 1) (acc + i * factor)

sumOptionalItems = remaining => acc => remaining match
  | []           => acc
  | [x, ...rest] => {
      value = x match
        | Some n => n
        | None   => 0
      sumOptionalItems rest (acc + value)
    }

buildAdderFnsDescending = i => fns =>
  if i > 3 then fns
  else {
    n = i
    f = x => x + n
    buildAdderFnsDescending (i + 1) [f, ...fns]
  }

sumScaledWithPure = base => i => acc =>
  if i > 3 then acc
  else sumScaledWithPure base (i + 1) (acc + i * base)

@test "recursive accumulation captures outer bindings"
recursiveCapturesOuter = {
  factor = 3
  result = accumulateWithFactor factor 1 0
  assertEq result 45
}

@test "recursive dispatch with match per step"
recursiveWithMatch = {
  items  = [Some 1, None, Some 3, None, Some 5]
  result = sumOptionalItems items 0
  assertEq result 9
}

@test "recursive builder creates closures capturing step state"
recursiveCreatesClosures = {
  fns = buildAdderFnsDescending 1 []
  fns match
    | [f3, f2, f1] => assertEq [f1 10, f2 10, f3 10] [11, 12, 13]
    | _            => fail "expected three closures"
}

@test "recursive helper with nested effect preserves outer"
recursiveNestedEffectPreservesOuter = {
  base   = 100
  result = sumScaledWithPure base 1 0
  assertEq result 600
}

@test "mapped list captures outer scope"
mappedListCapturesOuter = {
  multiplier = 10
  values     = map (n => n * multiplier) [1, 2, 3, 4]
  assertEq values [10, 20, 30, 40]
}

@no_prelude
module integrationTests.combinations.comboLoopNesting

use aivi
use aivi.testing
use aivi.generator

accumulateWithFactor = factor => i => acc =>
  if i > 5 then pure acc
  else accumulateWithFactor factor (i + 1) (acc + i * factor)

sumOptionalItems = remaining => acc => remaining match
  | []           => acc
  | [x, ...rest] => {
      value = x match
        | Some n => n
        | None   => 0
      sumOptionalItems rest (acc + value)
    }

buildAdderFnsDescending = i => fns =>
  if i > 3 then fns
  else {
    n = i
    f = x => x + n
    buildAdderFnsDescending (i + 1) [f, ...fns]
  }

sumScaledWithPure = base => i => acc =>
  if i > 3 then pure acc
  else sumScaledWithPure base (i + 1) (acc + i * base)

@test "loop in effect captures outer bindings"
loopCapturesOuter = pure 3
   |> factor => accumulateWithFactor factor 1 0#result
  ~|>_ => assertEq result 45

@test "loop with match dispatching per iteration"
loopWithMatch = {
  items  = [Some 1, None, Some 3, None, Some 5]
  result = sumOptionalItems items 0
  assertEq result 9
}

@test "loop creates closures capturing iteration state"
loopCreatesClosures = {
  fns = buildAdderFnsDescending 1 []
  fns match
    | [f3, f2, f1] => assertEq [f1 10, f2 10, f3 10] [11, 12, 13]
    | _            => fail "expected three closures"
}

@test "loop with nested effect preserves outer"
loopNestedEffectPreservesOuter = pure 100
   |> base => sumScaledWithPure base 1 0#result
  ~|>_ => assertEq result 600

@test "loop in generator captures outer scope"
loopInGeneratorCapturesOuter = {
  multiplier = 10
  g          = generate {
    loop n = 1 => {
      yield (n * multiplier)
      if n >= 4 then {}
      else recurse (n + 1)
    }
  }
  assertEq (toList g) [10, 20, 30, 40]
}

@no_prelude
module integrationTests.combinations.comboAdtLifecycle

use aivi
use aivi.testing

// ADTs through construction, matching, and closures end-to-end.
// Verifies ADT values flow correctly through nesting boundaries.

Tree  = Leaf Int | Branch Tree Tree
Shape = Circle Int | Rect Int Int | Point

shapeArea = s => s match
  | Circle r => r * r
  | Rect w h => w * h
  | Point    => 0

mapList : (A -> B) -> List A -> List B
mapList = f xs => xs match
  | []           => []
  | [x, ...rest] => [f x, ...(mapList f rest)]

@test "ADT constructed and matched by lambda-style helper"
adtConstructedAndMatchedByHelper = assertEq (shapeArea (Circle 5)) 25

@test "list of ADTs flows through downstream matcher"
adtListPipeline = assertEq (mapList shapeArea [Circle 3, Rect 4 5, Point]) [9, 20, 0]

sumTree = t => t match
  | Leaf n     => n
  | Branch l r => sumTree l + sumTree r

@test "recursive ADT tree traversal"
recursiveTreeTraversal = assertEq (sumTree (Branch (Branch (Leaf 1) (Leaf 2)) (Branch (Leaf 3) (Leaf 4)))) 10

transformShape = shape => shape match
  | Rect w h => n => n + w * h
  | _        => n => n

@test "ADT payload captured in closure used after match"
adtPayloadClosureCapture = Unit
~|>_ => assertEq ((transformShape (Rect 3 7)) 0) 21
~|>_ => assertEq ((transformShape (Rect 3 7)) 10) 31

Person = Student { name: Text, score: Int } | Teacher { name: Text, rating: Int }

personScore = p => p match
  | Student { name: _, score: s }  => s
  | Teacher { name: _, rating: r } => r * 10

@test "ADT with record payloads in nested match helpers"
adtRecordPayloads = peopleScores match
  | scores => assertEq scores [95, 50]

peopleScores = mapList personScore [Student { name: "Alice", score: 95 }, Teacher { name: "Bob", rating: 5 }]

mapTree = f t => t match
  | Leaf n     => Leaf (f n)
  | Branch l r => Branch (mapTree f l) (mapTree f r)

@test "map over tree with closure capturing outer"
mapTreeWithClosure = assertEq (sumTree (mapTree (n => n * 10) (Branch (Leaf 1) (Leaf 2)))) 30

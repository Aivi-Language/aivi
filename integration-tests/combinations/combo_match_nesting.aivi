@no_prelude
module integrationTests.combinations.comboMatchNesting

use aivi
use aivi.testing

Expr = Lit Int | Add Expr Expr | Neg Expr

eval = e => e match
  | Lit n     => n
  | Add l r   => eval l + eval r
  | Neg inner => 0 - eval inner

@test "nested match via recursive ADT evaluation"
nestedMatchEval = assertEq (eval (Add (Lit 10) (Neg (Lit 3)))) 7

matchEffectResult = value => value match
  | None   => pure 0
  | Some n => pure (n * 2)

@test "match arms can return effects"
matchArmsCanReturnEffects = Unit
   |> _ => matchEffectResult (Some 5)#result
  ~|>_ => assertEq result 10

Color = Red | Green | Blue

makeFn = color => color match
  | Red   => x => x + 1
  | Green => x => x + 2
  | Blue  => x => x + 3

@test "match returns different closures per arm"
matchReturnsClosure = Unit
~|>_ => assertEq (makeFn Red 10) 11
~|>_ => assertEq (makeFn Green 10) 12
~|>_ => assertEq (makeFn Blue 10) 13

classifyWithLimit = limit => n => n match
  | value when value < limit => "small"
  | _                        => "big"

@test "match guards with closures capturing outer"
matchGuardsClosure = Unit
~|>_ => assertEq ((classifyWithLimit 50) 10) "small"
~|>_ => assertEq ((classifyWithLimit 50) 100) "big"

matchResultEffect = value => value match
  | Err e => pure 0
  | Ok n  => pure (n * 2)

@test "match arms return effects using pattern vars"
matchArmsReturnEffectsUsingPatternVars = Unit
   |> _ => matchResultEffect (Ok 21)#result
  ~|>_ => assertEq result 42

recordScore = data => data match
  | Some r => r.score
  | None   => 0

@test "ADT match with field access"
adtMatchWithFieldAccess = assertEq (recordScore (Some { name: "Alice", score: 95 })) 95

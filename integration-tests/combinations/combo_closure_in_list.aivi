@no_prelude
module integrationTests.combinations.comboClosureInList

use aivi
use aivi.testing

makeAdder       = n => x => x + n
makeMultiplier  = n => x => x * n
makeShiftedBy   = base => n => x => base + n + x
subtractFrom    = n => x => n - x
makePairClosure = (a, b) => x => x + a + b

adderClosures      = List.map makeAdder [1, 2, 3]
multiplierClosures = List.map makeMultiplier [10, 20, 30]
shiftedClosures    = base => List.map (makeShiftedBy base) [1, 2, 3]
pairClosures       = List.map makePairClosure [(1, 10), (2, 20), (3, 30)]
subtractorClosures = List.map subtractFrom [10, 20, 30]

@test "each mapped closure captures its own item"
eachClosureCapturesOwnBinding = assertEq (List.map (f => f 0) adderClosures) [1, 2, 3]

@test "closures called after mapping return correct values"
closuresCalledAfterMapping =
  assertEq (List.map (f => f 2) multiplierClosures) [20, 40, 60]

@test "closure captures both outer scope and item"
closureCapturesOuterAndIter =
  assertEq (List.map (f => f 0) (shiftedClosures 100)) [101, 102, 103]

@test "mapped closures capture tuple pattern binding"
adtClosures = assertEq (List.map (f => f 0) pairClosures) [11, 22, 33]

@test "closures called out of order still hold their own captured value"
closuresCalledOutOfOrder = {
  assertEq (List.map (f => f 5) subtractorClosures) [5, 15, 25]
  assertEq (List.map (f => f 10) subtractorClosures) [0, 10, 20]
}

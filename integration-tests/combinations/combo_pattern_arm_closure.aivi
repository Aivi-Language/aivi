@no_prelude
module integrationTests.combinations.comboPatternArmClosure

use aivi
use aivi.testing

Val = Low Int | Mid Int | High Int

guardedClosure = value => value match
  | Low n when n < 10  => x => x + n
  | Mid n when n <= 50 => x => x * n
  | High n             => x => x - n

@test "closure in guarded arm captures pattern binding"
closureInGuardedArm = assertEq ((guardedClosure (Mid 21)) 2) 42

pickFn : Val -> (Int -> Int)
pickFn = v => v match
  | Low n  => x => n + x
  | Mid n  => x => n * x
  | High n => x => n - x

@test "only the matching arm's binding is captured"
onlyMatchingArmCaptured = Unit
~|>_ => assertEq ((pickFn (Low 3)) 10) 13
~|>_ => assertEq ((pickFn (High 7)) 10) (-3)

armClosure = n => (Some 5) match
  | None   => x => x + n
  | Some n => x => x + n

@test "arm closure ignores outer n, uses pattern-bound n"
armClosureUsesPatternN = assertEq ((armClosure 999) 10) 15

@test "two closures from different calls each capture their own binding"
twoClosuresDifferentBindings = Unit
~|>_ => assertEq ((pickFn (Low 4)) 6) 10
~|>_ => assertEq ((pickFn (Mid 3)) 6) 18

@no_prelude
module integrationTests.combinations.comboOperatorsInScopes

use aivi
use aivi.testing

double = x => x * 2
inc    = x => x + 1

@test "pipe chain stays valid without do"
pipeChainStaysValidWithoutDo = assertEq (5 |> double |> inc) 11

BaseRecord = { x: Int, y: Int, name: Text }

baseRecord : BaseRecord
baseRecord = { x: 1, y: 2, name: "test" }

updateY : BaseRecord -> Int -> BaseRecord
updateY = base => newY => base <| { y: newY }

@test "patch operator in closure-style helper capturing record"
patchInClosure = Unit
~|>_ => assertEq (updateY baseRecord 10).y 10
~|>_ => assertEq (updateY baseRecord 20).y 20
~|>_ => assertEq (updateY baseRecord 10).x 1
~|>_ => assertEq (updateY baseRecord 20).name "test"

applyValues = state values => values match
  | []           => state
  | [v, ...rest] => applyValues (state <| { total: state.total + v }) rest

@test "patch operator used in recursive accumulation"
patchInRecursiveAccumulation = assertEq (applyValues { total: 0 } [10, 20, 30]).total 60

classify = n => n match
  | value when value > 10 => "big"
  | _                     => "small"

@test "pipe into match expression"
pipeIntoMatch = Unit
~|>_ => assertEq (5 |> double |> classify) "small"
~|>_ => assertEq (6 |> double |> classify) "big"

@no_prelude
module integrationTests.combinations.comboPatternBindingNoLeak

use aivi
use aivi.testing

Status = Active Int | Inactive | Pending Int

armLabel = value => value match
  | 1 => "arm-one"
  | 2 => "arm-two"
  | _ => "arm-other"

statusLabel = status => status match
  | Inactive  => "off"
  | Active n  => if n > 0 then "active-positive" else "active-zero"
  | Pending n => if n > 0 then "pending-positive" else "pending-zero"

statusScore = status => status match
  | Inactive  => 0
  | Active n  => n * 2
  | Pending n => n * 3

reboundScore = status => status match
  | Inactive  => 0
  | Active n  => n * 10
  | Pending n => n

sumActive = inputs => inputs match
  | []                   => 0
  | [Active n, ...rest]  => n + sumActive rest
  | [Inactive, ...rest]  => sumActive rest
  | [Pending n, ...rest] => sumActive rest

@test "each arm's internal binding is independent"
armBindingsIndependent = assertEq (armLabel 2) "arm-two"

@test "pattern binding from non-matching arm does not pollute result"
patternBindingNotLeaking = assertEq (statusLabel (Active 99)) "active-positive"

@test "only matched arm's value exits the match"
onlyMatchedArmValueExits = assertEq (statusScore (Pending 7)) 21

@test "result must be explicitly rebound after match to be used"
explicitRebindAfterMatch = assertEq (reboundScore (Active 5)) 50

@test "multiple arms binding same name do not interfere"
multipleArmsBindSameName = assertEq (sumActive [Active 2, Inactive, Pending 5, Active 3]) 5

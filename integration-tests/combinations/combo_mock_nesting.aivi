@no_prelude
module integrationTests.combinations.comboMockNesting

use aivi
use aivi.testing

greeting = "Hello"

@test "mock active without do"
mockActiveWithoutDo = mock greeting = "Hi"
in assertEq greeting "Hi"

@test "mock scope does not leak into outer binding"
mockScopeDoesNotLeakIntoOuterBinding = Unit
~|>_ => assertEq (mock greeting = "Temp" in greeting) "Temp"
~|>_ => assertEq greeting "Hello"

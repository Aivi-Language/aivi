@no_prelude
module integrationTests.syntax.irDumpMinimal

use aivi
use aivi.testing

value = 1 + 2
pair  = (value, "ok")

mapList : (A -> B) -> List A -> List B
mapList = f xs => xs match
  | []           => []
  | [x, ...rest] => [f x, ...(mapList f rest)]

maybeInc : Option Int -> Int
maybeInc = opt => opt match
  | Some n => n + 1
  | None   => 0

result : List Int
result = mapList maybeInc [Some 1, None, Some 41]

expected = [2, 0, 42]

@test "basic IR pipeline end-to-end"
irDumpMinimalRuns = {
  assertEq value 3
  assertEq pair (3, "ok")
  assertEq (maybeInc (Some 1)) 2
  assertEq result expected
}

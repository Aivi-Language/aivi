@no_prelude
module integrationTests.syntax.effects.cleanupFailure

use aivi
use aivi.testing

successFlowWithFailingCleanup = Unit
  |> start => pure "acquired-value"@cleanup (acquiredValue => fail "cleanup-error")#value
  |> afterAcquire => pure value

failureFlowWithFailingCleanup = Unit
  |> start => pure "acquired-value"@cleanup (acquiredValue => fail "cleanup-error")#value
  |> afterAcquire => fail "primary-error"

@test "cleanup failure stays secondary on success"
cleanupFailureStaysSecondaryOnSuccess =
  attempt successFlowWithFailingCleanup
    |> attemptResult =>
         assertOk attemptResult
           |> value => assertEq value "acquired-value"

@test "primary failure stays visible alongside cleanup failure"
primaryFailureStaysVisibleAlongsideCleanupFailure =
  attempt failureFlowWithFailingCleanup
    |> attemptResult =>
         assertErr attemptResult
           |> err => assertEq err "primary-error"

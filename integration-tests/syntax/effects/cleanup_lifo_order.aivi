@no_prelude
module integrationTests.syntax.effects.cleanupLifoOrder

use aivi
use aivi.testing
use aivi.file

deleteIfExists = path =>
  path
   |> exists
  ||>True => delete path
  ||>False => pure (Ok Unit)

lifoFlow = logPath =>
  Unit
    |> start => pure logPath@cleanup (managedPath => writeText managedPath "A")#firstPath
    |> afterFirst => pure firstPath@cleanup (managedPath => writeText managedPath "B")#secondPath
    |> afterSecond => pure secondPath

@test "cleanup registrations unwind in reverse order"
cleanupRegistrationsUnwindInReverseOrder = "/tmp/aivi_lifo2_log.txt"
  |> pure@cleanup deleteIfExists#logPath
  |> currentPath => lifoFlow currentPath
  |> readText
  |> assertEq (Ok "A")

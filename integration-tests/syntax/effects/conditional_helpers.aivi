@no_prelude
module integrationTests.syntax.effects.conditionalHelpers

use aivi
use aivi.testing

runIf    = cond action => if cond then action else pure Unit
runIfNot = cond action => if cond then pure Unit else action

@test "conditional helper true branch produces failure"
conditionalHelperTrueBranchProducesFailure =
  attempt (runIf True (fail "triggered"))
    |> attemptResult =>
         assertErr attemptResult
           |> err => assertEq err "triggered"

@test "conditional helper false branch skips failure"
conditionalHelperFalseBranchSkipsFailure =
  attempt (runIf False (fail "triggered"))
    |> attemptResult =>
         assertOk attemptResult
           |> value => assertEq value Unit

@test "inverse helper true branch skips failure"
inverseHelperTrueBranchSkipsFailure =
  attempt (runIfNot True (fail "triggered"))
    |> attemptResult =>
         assertOk attemptResult
           |> value => assertEq value Unit

@test "inverse helper false branch produces failure"
inverseHelperFalseBranchProducesFailure =
  attempt (runIfNot False (fail "triggered"))
    |> attemptResult =>
         assertErr attemptResult
           |> err => assertEq err "triggered"

@no_prelude
module integrationTests.syntax.effects.givenOrBehavior

use aivi
use aivi.testing

// `given cond or failExpr` short-circuits the do-block with `failExpr` when
// `cond` is False. Execution continues normally when `cond` is True.

requireNonEmpty : List Int -> Effect Text (List Int)
requireNonEmpty = xs => do Effect {
  given (list.length xs > 0) or fail "list must not be empty"
  pure xs
}

requirePositive : Int -> Effect Text Int
requirePositive = n => do Effect {
  given n > 0 or fail "value must be positive"
  pure n
}

@test "given true continues block"
givenTrueContinuesBlock = do Effect {
  res <- attempt (requireNonEmpty [1, 2, 3])
  res match
    | Ok xs => assertEq xs [1, 2, 3]
    | Err _ => fail "unexpected error"
}

@test "given false short-circuits with fail expression"
givenFalseShortCircuits = do Effect {
  res <- attempt (requireNonEmpty [])
  res match
    | Err e => assertEq e "list must not be empty"
    | Ok _  => fail "should have short-circuited"
}

@test "given false does not execute subsequent statements"
givenFalseSkipsRemainder = do Effect {
  res <- attempt (do Effect {
      given False or fail "early exit"
      fail "should not reach here"
  })
  res match
    | Err e => assertEq e "early exit"
    | Ok _  => fail "should have exited early"
}

@test "multiple given guards all must pass"
multipleGivenGuards = do Effect {
  checkBoth = n => do Effect {
    given n > 0 or fail "must be positive"
    given n < 100 or fail "must be less than 100"
    pure n
  }
  ok <- attempt (checkBoth 50)
  ok match
    | Ok v  => assertEq v 50
    | Err _ => fail "unexpected error"
    tooSmall <- attempt (checkBoth (-1))
    tooSmall match
      | Err e => assertEq e "must be positive"
      | Ok _  => fail "should have failed"
    tooBig <- attempt (checkBoth 200)
    tooBig match
      | Err e => assertEq e "must be less than 100"
      | Ok _  => fail "should have failed"
}

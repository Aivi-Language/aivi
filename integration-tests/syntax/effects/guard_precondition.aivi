@no_prelude
module integrationTests.syntax.effects.guardPrecondition

use aivi
use aivi.testing

positiveOnly : Int -> Effect Text Int
positiveOnly = n =>
  n
  >|>_ > 0 or fail "must be positive"
   |> pure

@test "guard success continues"
guardSuccessContinues =
  attempt (positiveOnly 5)
    |> attemptResult =>
         assertOk attemptResult
           |> value => assertEq value 5

@test "guard failure returns the original error"
guardFailureReturnsTheOriginalError =
  attempt (positiveOnly (-1))
    |> attemptResult =>
         assertErr attemptResult
           |> err => assertEq err "must be positive"

@no_prelude
module integrationTests.syntax.effects.cleanupOnPatternFail

use aivi
use aivi.testing
use aivi.file

deleteIfExists = path =>
  path
   |> exists
  ||>True => delete path
  ||>False => pure (Ok Unit)

assertMissingPath = path =>
  path
|> exists
|> assertEq False

branchFailureFlow = path =>
  Unit
    |> start => writeText path "live"
    |> afterWrite => pure path@cleanup delete#managedPath
    |> afterAcquire => pure 99
   ||>1 => pure Unit
   ||>_ => fail "pattern-branch-failure"

guardFailureFlow = path =>
  Unit
    |> start => writeText path "alive"
    |> afterWrite => pure path@cleanup delete#managedPath
   >|>_ == "" or fail "guard-fired"

@test "cleanup runs after a branch failure"
cleanupRunsAfterABranchFailure = "/tmp/aivi_pattern_fail_cleanup.txt"
  |> pure@cleanup deleteIfExists#path
  |> currentPath =>
       attempt (branchFailureFlow currentPath)
         |> result =>
              assertMissingPath path
                |> checked =>
                     assertEq result (Err "pattern-branch-failure")

@test "cleanup runs after a guard failure"
cleanupRunsAfterAGuardFailure = "/tmp/aivi_guard_fail_cleanup.txt"
  |> pure@cleanup deleteIfExists#path
  |> currentPath =>
       attempt (guardFailureFlow currentPath)
         |> result =>
              assertMissingPath path
                |> checked =>
                     assertEq result (Err "guard-fired")

@no_prelude
module integrationTests.syntax.effects.resourceCleanupFailure

use aivi
use aivi.testing

// Resource whose cleanup always fails.
// Per spec §15.4: cleanup errors are suppressed; the primary result takes priority.
failingCleanupResource = resource {
  yield "acquired-value"
  fail "cleanup-error"
}

// (a) Primary computation succeeds; cleanup fails.
//     Expected: result is Ok with the primary value — cleanup error is suppressed.
@test "cleanup failure is suppressed when primary computation succeeds"
cleanupFailSuppressedOnSuccess = do Effect {
  result <- attempt (do Effect {
      val    <- failingCleanupResource
      pure val
  })

  result match
    | Ok val => assertEq val "acquired-value"
    | Err e  => fail "cleanup error leaked into result: {e}"
}

// (b) Primary computation fails; cleanup also fails.
//     Expected: result is Err with the primary error — cleanup error is still suppressed.
@test "primary error is preserved when both primary and cleanup fail"
primaryErrorPreservedWhenBothFail = do Effect {
  result <- attempt (do Effect {
      _      <- failingCleanupResource
      _      <- fail "primary-error"
      pure Unit
  })

  result match
    | Err e => assertEq e "primary-error"
    | Ok _  => fail "expected primary error to propagate, got Ok instead"
}

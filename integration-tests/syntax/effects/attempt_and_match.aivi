@no_prelude
module integrationTests.syntax.effects.attemptAndMatch

use aivi
use aivi.testing

@test "attempt exposes failure to branch matching"
attemptExposesFailureToBranchMatching = Unit
   |> _ => attempt (fail "nope")#attemptResult
   |> _ => assertErr attemptResult#err
  ~|>_ => assertEq err "nope"
   |> _ => pure Unit

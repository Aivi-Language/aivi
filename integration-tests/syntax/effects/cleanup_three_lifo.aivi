@no_prelude
module integrationTests.syntax.effects.cleanupThreeLifo

use aivi
use aivi.testing
use aivi.file

deleteIfExists = path =>
  path
   |> exists
  ||>True => delete path
  ||>False => pure (Ok Unit)

threeStepLifoFlow = logPath =>
  Unit
    |> start => pure logPath@cleanup (managedPath => writeText managedPath "A")#firstPath
    |> afterFirst => pure firstPath@cleanup (managedPath => writeText managedPath "B")#secondPath
    |> afterSecond => pure secondPath@cleanup (managedPath => writeText managedPath "C")#thirdPath
    |> afterThird => pure thirdPath

@test "three cleanup registrations unwind in reverse order"
threeCleanupRegistrationsUnwindInReverseOrder = "/tmp/aivi_three_lifo_log.txt"
  |> pure@cleanup deleteIfExists#logPath
  |> currentPath => threeStepLifoFlow currentPath
  |> readText
  |> assertEq (Ok "A")

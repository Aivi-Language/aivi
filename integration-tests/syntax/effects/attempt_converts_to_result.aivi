@no_prelude
module integrationTests.syntax.effects.attemptConvertsToResult

use aivi
use aivi.testing

recoverWithZero = result => result match
  | Ok value => value
  | Err _    => 0

nestedFailure = Unit
  |> _ => fail "inner error"
  |> _ => pure 99

@test "attempt wraps success in Ok"
attemptWrapsSuccessInOk = Unit
   |> _ => attempt (pure 42)#attemptResult
   |> _ => assertOk attemptResult#value
  ~|>_ => assertEq value 42
   |> _ => pure Unit

@test "attempt wraps failure in Err"
attemptWrapsFailureInErr = Unit
   |> _ => attempt (fail "something went wrong")#attemptResult
   |> _ => assertErr attemptResult#err
  ~|>_ => assertEq err "something went wrong"
   |> _ => pure Unit

@test "attempt allows recovery after failure"
attemptAllowsRecovery = Unit
   |> _ => attempt (fail "recoverable")#attemptResult
   |> _ => pure (recoverWithZero attemptResult)#value
  ~|>_ => assertEq value 0
   |> _ => pure Unit

@test "attempt on nested failure keeps the first error"
attemptNestedShortCircuit = Unit
   |> _ => attempt nestedFailure#attemptResult
   |> _ => assertErr attemptResult#err
  ~|>_ => assertEq err "inner error"
   |> _ => pure Unit

@no_prelude
module integrationTests.syntax.effects.sequentialFlow

use aivi
use aivi.testing

keepPositive : Int -> Effect Text Int
keepPositive = value =>
  value
  >|>_ > 0 or fail "not-positive"
   |> pure

recoverPositive : Int -> Effect Text Int
recoverPositive = value =>
  attempt (keepPositive value)
    |> result => result match
      | Ok current => pure (current + 1)
      | Err _      => pure 0

@test "flow bindings stay visible across steps"
flowBindingsStayVisibleAcrossSteps =
  pure 1
    |> x =>
         pure 2
           |> y => assertEq 3 (x + y)

@test "tap preserves the current subject"
tapPreservesTheCurrentSubject = pure 7
~|>value => assertEq value 7
~|>value => assertEq value 7

@test "guard preserves the current subject on success"
guardPreservesTheCurrentSubjectOnSuccess = keepPositive 5
~|>value => assertEq value 5

@test "recovery keeps the success path"
recoveryKeepsTheSuccessPath = recoverPositive 5
~|>value => assertEq value 6

@test "recovery can replace a failure"
recoveryCanReplaceAFailure = recoverPositive (-1)
~|>value => assertEq value 0

@no_prelude
module integrationTests.syntax.effects.optionFlow

use aivi
use aivi.testing

combineOption = left right => (left, right) match
  | (Some x, Some y) => Some (x + y)
  | (Some _, None)   => None
  | (None, _)        => None
  | _                => None

keepOption = option => option match
  | Some value => Some value
  | None       => None

dropOption = option => option match
  | Some _ => None
  | None   => None

@test "option chaining keeps the happy path"
optionChainingKeepsTheHappyPath = assertEq (combineOption (Some 1) (Some 2)) (Some 3)

@test "option chaining stops on None"
optionChainingStopsOnNone = assertEq (combineOption (Some 10) None) None

@test "option mapping keeps a present value"
optionMappingKeepsAPresentValue = assertEq (keepOption (Some 42)) (Some 42)

@test "option mapping can return one value"
optionMappingCanReturnOneValue = assertEq (keepOption (Some 123)) (Some 123)

@test "option chaining can end empty"
optionChainingCanEndEmpty = assertEq (dropOption (Some 1)) None

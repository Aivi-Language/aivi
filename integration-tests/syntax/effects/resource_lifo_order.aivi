@no_prelude
module integrationTests.syntax.effects.resourceLifoOrder

use aivi
use aivi.testing
use aivi.file

// Both resources write to the same log file.
// LIFO cleanup order (B before A) means A writes last → log ends up as "A".
// If order were reversed (A before B), B would write last → log would be "B".

resB = logPath => resource {
  yield Unit
  writeText logPath "B"
}

resA = logPath => resource {
  yield Unit
  writeText logPath "A"
}

@test "resources are released in LIFO order (B before A)"
resourceLifoOrder = do Effect {
  logPath = "/tmp/aivi_lifo2_log.txt"

  // Acquire A first, then B — LIFO means B writes "B" first, then A writes "A" (overwrites)
  _ <- do Effect {
    _ <- resA logPath
    _ <- resB logPath
    pure Unit
  }

  // Final content must be "A": proves A's cleanup ran last (after B's)
  logResult <- readText logPath
  _         <- logResult match
    | Ok txt => assertEq txt "A"
    | Err _  => fail "log file not written by cleanup"

  _ <- delete logPath
  pure Unit
}

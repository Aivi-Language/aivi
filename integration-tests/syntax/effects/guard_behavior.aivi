@no_prelude
module integrationTests.syntax.effects.guardBehavior

use aivi
use aivi.list
use aivi.testing

requireNonEmpty : List Int -> Effect Text (List Int)
requireNonEmpty = xs =>
  xs
  >|>length _ > 0 or fail "list must not be empty"
   |> pure

withinRange : Int -> Effect Text Int
withinRange = n =>
  n
  >|>_ > 0 or fail "must be positive"
  >|>_ < 100 or fail "must be less than 100"
   |> pure

abortBeforeTail : Effect Text Bool
abortBeforeTail = pure False
>|>_ or fail "early exit"
~|> current => fail "should not reach here"

@test "guard success keeps the current value"
guardSuccessKeepsTheCurrentValue =
  attempt (requireNonEmpty [1, 2, 3])
    |> attemptResult =>
         assertOk attemptResult
           |> value => assertEq value [1, 2, 3]

@test "guard failure returns the fallback error"
guardFailureReturnsTheFallbackError =
  attempt (requireNonEmpty [])
    |> attemptResult =>
         assertErr attemptResult
           |> err => assertEq err "list must not be empty"

@test "guard failure skips later steps"
guardFailureSkipsLaterSteps =
  attempt abortBeforeTail
    |> attemptResult =>
         assertErr attemptResult
           |> err => assertEq err "early exit"

@test "multiple guards can all pass"
multipleGuardsCanAllPass =
  attempt (withinRange 50)
    |> attemptResult =>
         assertOk attemptResult
           |> value => assertEq value 50

@test "the first guard can fail early"
firstGuardCanFailEarly =
  attempt (withinRange (-1))
    |> attemptResult =>
         assertErr attemptResult
           |> err => assertEq err "must be positive"

@test "the second guard can fail after the first passes"
secondGuardCanFailAfterTheFirstPasses =
  attempt (withinRange 200)
    |> attemptResult =>
         assertErr attemptResult
           |> err => assertEq err "must be less than 100"

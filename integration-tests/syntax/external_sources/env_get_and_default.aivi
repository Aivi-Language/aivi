@no_prelude
module integrationTests.syntax.externalSources.envGetAndDefault

use aivi
use aivi.testing

@test "env load with fallback"
envDefaultWorks = attempt (load (env.get "AIVI__MISSING_TEST_PORT__"))
  |> result => assertEq (result match
    | Ok port => port
    | Err _   => "3000"
  ) "3000"

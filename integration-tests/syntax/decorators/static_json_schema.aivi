@no_prelude
module integrationTests.syntax.decorators.staticJsonSchema

use aivi
use aivi (
  prelude (toText)
  text (contains)
)
use aivi.testing

ExtractionResult = {
  title: Text
  summary: Text
  tags: List Text
  score: Option Float
}

@static
extractionSchema = type.jsonSchema ExtractionResult

@test "type.jsonSchema produces record with json_schema wrapper"
jsonSchemaHasWrapper = do Effect {
  schemaText = toText extractionSchema
  assert (contains "json_schema" schemaText)
  assert (contains "ExtractionResult" schemaText)
  assert (contains "strict" schemaText)
}

@test "type.jsonSchema maps record fields"
jsonSchemaHasFields = do Effect {
  schemaText = toText extractionSchema
  assert (contains "title" schemaText)
  assert (contains "summary" schemaText)
  assert (contains "tags" schemaText)
  assert (contains "score" schemaText)
}

@test "type.jsonSchema maps primitive types"
jsonSchemaMapsPrimitives = do Effect {
  schemaText = toText extractionSchema
  assert (contains "string" schemaText)
  assert (contains "number" schemaText)
  assert (contains "array" schemaText)
}

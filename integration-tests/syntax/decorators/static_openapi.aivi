@no_prelude
module integrationTests.syntax.decorators.staticOpenapi

use aivi
use aivi.testing

@static
petStoreApi = openapi.fromFile "./petstore.json"

@test "openapi static produces a callable factory"
factoryCallable = do Effect {
  client = petStoreApi {}
  assert True
}

@test "openapi static client has endpoint functions"
clientEndpoints = do Effect {
  client = petStoreApi {}
  src = client.listPets { limit: Some 10 }
  assert True
}

@test "openapi static endpoints can be destructured"
destructureEndpoints = do Effect {
  client = petStoreApi {}
  { listPets, createPet, getPetById } = client
  assert True
}

@test "openapi static config with bearer token"
configBearerToken = do Effect {
  client = petStoreApi { bearerToken: Some "test-token" }
  src = client.listPets {}
  assert True
}

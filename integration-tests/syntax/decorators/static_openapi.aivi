@no_prelude
module integrationTests.syntax.decorators.staticOpenapi

use aivi
use aivi.testing

@static
petStoreApi = openapi.fromFile "./petstore.json"

@test "openapi static produces a callable factory"
factoryCallable = {
  client = petStoreApi { bearerToken: None, headers: None, timeoutMs: None, retryCount: None, strictStatus: None, baseUrl: None }
  assert True
}

@test "openapi static client has endpoint functions"
clientEndpoints = {
  client = petStoreApi { bearerToken: None, headers: None, timeoutMs: None, retryCount: None, strictStatus: None, baseUrl: None }
  _ = client.listPets { limit: Some 10 }
  assert True
}

@test "openapi static endpoints can be destructured"
destructureEndpoints = {
  client                              = petStoreApi { bearerToken: None, headers: None, timeoutMs: None, retryCount: None, strictStatus: None, baseUrl: None }
  { listPets, createPet, getPetById } = client
  assert True
}

@test "openapi static config with bearer token"
configBearerToken = {
  client = petStoreApi { bearerToken: Some "test-token", headers: None, timeoutMs: None, retryCount: None, strictStatus: None, baseUrl: None }
  _ = client.listPets { limit: None }
  assert True
}

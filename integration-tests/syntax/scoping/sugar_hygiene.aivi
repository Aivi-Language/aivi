@no_prelude
module integrationTests.syntax.scoping.sugarHygiene

use aivi
use aivi.testing

// Syntax sugar that desugars to internal bindings must not shadow user-defined
// variables that happen to share a name with the compiler's intermediate bindings.
//
// Tested constructs:
//   `when cond <- eff`   desugars to `_ <- if cond then eff else pure Unit`
//   `unless cond <- eff` desugars to `_ <- if cond then pure Unit else eff`

// --- `when` sugar: intermediate `_` does not shadow user bindings ---

@test "when sugar does not affect user bindings"
whenSugarNoShadow = {
  x = 42
  if True then pure Unit else pure Unit
  // `_` from desugar must not shadow or clobber `x`
  assertEq x 42
}

// --- `unless` sugar: same hygiene requirement ---

@test "unless sugar does not affect user bindings"
unlessSugarNoShadow = {
  count = 7
  if False then pure Unit else pure Unit
  assertEq count 7
}

// --- Multiple sugars in sequence: each desugar's internals stay isolated ---

@test "multiple when/unless in sequence do not interfere with each other"
multipleSugarsSequential = {
  value = 55
  flag1 = True
  flag2 = False
  if flag1 then pure Unit else pure Unit
  if flag2 then pure Unit else pure Unit
  if flag1 then pure Unit else pure Unit
  // After three sugar expansions, value is unchanged
  assertEq value 55
}

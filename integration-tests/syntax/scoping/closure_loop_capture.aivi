@no_prelude
module integrationTests.syntax.scoping.closureLoopCapture

use aivi
use aivi.testing
use aivi.logic

// Closures created by recursive builders, stored in a list, called after
// the recursion ends. Each closure must capture its own per-step value,
// not the last value seen.

buildMultiplierFns = i => fns =>
  if i > 4 then fns
  else {
    n = i
    f = x => x * n
    buildMultiplierFns (i + 1) [...fns, f]
  }

buildOffsetFns = i => fns =>
  if i >= 3 then fns
  else {
    offset = i * 100
    f      = x => x + offset
    buildOffsetFns (i + 1) [...fns, f]
  }

buildIncrementFns = i => fns =>
  if i > 3 then fns
  else {
    n = i
    f = x => x + n
    buildIncrementFns (i + 1) [...fns, f]
  }

@test "recursive closures each capture their own step value"
recursiveClosureCapture = {
  fns = buildMultiplierFns 1 []
  // fns = [f1, f2, f3, f4] where fi x = x * i
  results = map (f => f 10) fns
  assertEq results [10, 20, 30, 40]
}

@test "recursive closures capture distinct additive offsets"
recursiveClosureOffsets = {
  fns = buildOffsetFns 0 []
  // fns = [f0, f1, f2]: f0 adds 0, f1 adds 100, f2 adds 200
  results = map (f => f 5) fns
  assertEq results [5, 105, 205]
}

@test "recursive closures called multiple times keep the right captured value"
recursiveClosureMultiCall = {
  fns = buildIncrementFns 1 []
  fns match
    | [first, second, third] => {
        assertEq (first 0) 1
        assertEq (first 100) 101
        assertEq (second 0) 2
        assertEq (second 100) 102
        assertEq (third 0) 3
        assertEq (third 100) 103
      }
    | _ => fail "expected three closures"
}

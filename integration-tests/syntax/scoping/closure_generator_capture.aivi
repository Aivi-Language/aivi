@no_prelude
module integrationTests.syntax.scoping.closureGeneratorCapture

use aivi
use aivi.testing
use aivi.generator
use aivi.list (map)

// Closures created inside generate{} bind statements (x <- source),
// capturing x. Each closure must hold its own x from its iteration.

makeFns : Generator (Int -> Int)
makeFns = generate {
  x <- [10, 20, 30]
  yield (n => n + x)
}

@test "generator closures each capture their own bound iteration value"
generatorClosureCapture = do Effect {
  fns = toList makeFns
  results = map (f => f 5) fns
  // f10 5 = 15, f20 5 = 25, f30 5 = 35
  assertEq results [15, 25, 35]
}

@test "generator closures over two nested binds capture independently"
generatorNestedBindCapture = do Effect {
  fns = toList (generate {
      base <- [1, 2]
      mult <- [10, 100]
      yield (x => x * mult + base)
  })
  results = map (f => f 3) fns
  // (3*10+1)=31, (3*100+1)=301, (3*10+2)=32, (3*100+2)=302
  assertEq results [31, 301, 32, 302]
}

@test "generator closure captures correct x with guard filtering"
generatorClosureWithGuard = do Effect {
  fns = toList (generate {
      x <- [1, 2, 3, 4, 5]
      x -> x % 2 == 1
      yield (n => n + x)
  })
  // Only odd x: 1, 3, 5
  results = map (f => f 0) fns
  assertEq results [1, 3, 5]
}

@test "generator loop captures per-iteration value in yielded closure"
generatorLoopClosureCapture = do Effect {
  fns = toList (generate {
      loop n = 1 => {
        yield (x => x * n)
        if n >= 3 then {}
        else recurse (n + 1)
      }
  })
  results = map (f => f 4) fns
  // f1 4 = 4, f2 4 = 8, f3 4 = 12
  assertEq results [4, 8, 12]
}

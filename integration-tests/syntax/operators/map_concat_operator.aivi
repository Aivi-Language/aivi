@no_prelude
module integrationTests.syntax.operators.mapConcatOperator

use aivi
use aivi.collections (domain Collections)
use aivi.testing

m1 : Map Text Int
m1 = ~map{ "a" => 1, "b" => 2 }

m2 : Map Text Int
m2 = ~map{ "b" => 99, "c" => 3 }

merged = m1 ++ m2

emptyMap : Map Text Int
emptyMap = ~map{}

@test "map ++ merges entries, right side wins on collision"
mapConcatWorks = do Effect {
  assertEq (map.size merged) 3
  assertEq (map.get "a" merged) (Some 1)
  assertEq (map.get "b" merged) (Some 99)
  assertEq (map.get "c" merged) (Some 3)
}

@test "map ++ with empty right is identity"
mapConcatEmptyRight = do Effect {
  assertEq (m1 ++ emptyMap) m1
}

@test "map ++ with empty left is identity"
mapConcatEmptyLeft = do Effect {
  assertEq (emptyMap ++ m1) m1
}

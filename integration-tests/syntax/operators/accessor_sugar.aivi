@no_prelude
module integrationTests.syntax.operators.accessorSugar

use aivi
use aivi.testing

// .field  is accessor sugar: desugars to  x => x.field

getName : { name: Text, age: Int } -> Text
getName = .name

@test ".field as standalone accessor function"
dotFieldAccessor = {
  person = { name: "Alice", age: 30 }
  assertEq (getName person) "Alice"
}

// map .name is equivalent to map (x => x.name)
people : List { name: Text, age: Int }
people = [
  { name: "Alice", age: 30 }
  { name: "Bob",   age: 25 }
  { name: "Carol", age: 40 }
]

names1 = map.name people
names2 = map (x => x.name) people

@test "map .name equals map (x => x.name)"
mapDotName = {
  assertEq names1 ["Alice", "Bob", "Carol"]
  assertEq names1 names2
}

// .field works for Int fields too
ages1 = map.age people
ages2 = map (x => x.age) people

@test "map .age equals map (x => x.age)"
mapDotAge = {
  assertEq ages1 [30, 25, 40]
  assertEq ages1 ages2
}

// Predicate lifting: bare unbound field name in fn position becomes a field accessor
// filter active items  →  filter (__pred => __pred.active) items
items : List { label: Text, active: Bool }
items = [
  { label: "A", active: True }
  { label: "B", active: False }
  { label: "C", active: True }
]

activeItems     = filter active items
activeItemsExpl = filter (x => x.active) items

@test "predicate lifting: bare bool field used as filter predicate"
predicateLiftingBoolField = {
  assertEq (length activeItems) 2
  assertEq activeItems activeItemsExpl
}

// .field accessor in a pipeline
labels = items |> filter active |> map.label

@test "pipeline with filter+predicate and .field accessor"
pipelineAccessor = {
  assertEq labels ["A", "C"]
}

// `by prop` sugar: desugars to x => x.prop == prop (outer-scope capture)
records : List { id: Int, name: Text }
records = [
  { id: 1, name: "Alice" }
  { id: 2, name: "Bob" }
  { id: 3, name: "Carol" }
]

@test "by id: find by same-name equality"
byIdSugar = {
  id     = 2
  result = find (by id) records
  assertEq result (Some { id: 2, name: "Bob" })
}

@test "by (f1, f2): multi-field same-name equality"
byMultiField = {
  id     = 3
  name   = "Carol"
  result = find (by (id, name)) records
  assertEq result (Some { id: 3, name: "Carol" })
}

// Generalised lifting: bare name in any fn position, not just Bool
nums : List { value: Int }
nums = [{ value: 3 }, { value: 1 }, { value: 4 }, { value: 1 }, { value: 5 }]

sortedValues     = sortBy value nums |> map.value
explSortedValues = sortBy (x => x.value) nums |> map (x => x.value)

@test "generalised lifting: bare name in sortBy (non-Bool fn position)"
generalisedLifting = {
  assertEq sortedValues [1, 1, 3, 4, 5]
  assertEq sortedValues explSortedValues
}

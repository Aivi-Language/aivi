@no_prelude
module integrationTests.syntax.domains.multiDomainOperatorResolutionNonCollidingSuffixes

use aivi
use aivi.testing
use aivi.duration (domain Duration)
use aivi.color (domain Color)

span0 = { millis: 0 }
span1 = span0 + 1min

rgb0 = { r: 20, g: 20, b: 20 }
rgb1 = rgb0 + 10r

@test "operators resolve across domains; non-colliding suffixes work"
operatorsResolveAcrossDomains = do Effect {
  assertEq span1.millis 60000
  assertEq rgb1.r 30
  assertEq rgb1.g 20
  assertEq rgb1.b 20
}

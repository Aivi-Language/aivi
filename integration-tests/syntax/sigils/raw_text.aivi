@no_prelude
module integrationTests.syntax.sigils.rawText

use aivi
use aivi.testing

json = ~`{"id": 1, "name": "Alice"}`

multiline = ~`line one
line two
line three`

withBraces = ~`no {interpolation} here`

@test "raw text sigil produces Text"
rawTextSigil = do Effect {
  assertEq json "{\"id\": 1, \"name\": \"Alice\"}"
  assert (text.contains "line two" multiline)
  assertEq withBraces "no {interpolation} here"
}

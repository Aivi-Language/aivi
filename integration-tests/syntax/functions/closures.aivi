@no_prelude
module integrationTests.syntax.functions.closures

use aivi
use aivi.testing

// Closure over `factor` used inside a list transform
scaledRange : Int -> List Int
scaledRange = factor => List.map (n => n * factor) [1, 2, 3]

// Closure over two parameters used inside a list transform
filteredScaled : Int -> Int -> List Int
filteredScaled = offset factor => List.map (n => n * factor + offset) [1, 2, 3]

// Helper that captures `offset` and returns a closure
withAdder : Int -> (Int -> Int)
withAdder = offset => n => n + offset

@test "closure captures variable in list transform"
closureInListTransform = {
  result = scaledRange 3
  assertEq result [3, 6, 9]
}

@test "inner closure defined and composed in plain block"
innerClosureInPlainBlock = {
  base       = 100
  clampedAdd = limit n => if n + base > limit then limit else n + base
  assertEq (clampedAdd 120 10) 110
  assertEq (clampedAdd 120 25) 120
}

@test "closure passed to higher-order map"
closureInHigherOrder = {
  multiplier = 4
  assertEq (List.map (x => x * multiplier) [3, 4, 5]) [12, 16, 20]
}

@test "closure used inside Option logic"
closureInOptionLogic = {
  offset    = 5
  addOffset = x => Some (x + offset)
  result = Some 10 match
    | Some a => addOffset a
    | None   => None
  assertEq result (Some 15)
}

@test "closure used inside Result logic"
closureInResultLogic = {
  validate = max n => if n <= max then Ok (n * 2) else Err "out of range"
  result1 = validate 100 42
  result2 = validate 10 42
  assertEq result1 (Ok 84)
  assertEq result2 (Err "out of range")
}

@test "helper returns a closure"
closureHelperReturnsClosure = {
  adder = withAdder 7
  assertEq (adder 3) 10
  assertEq (adder 10) 17
}

@test "list transform with closure over two captured parameters"
listWithClosureFilterTransform = {
  result = filteredScaled 1 10
  assertEq result [11, 21, 31]
}

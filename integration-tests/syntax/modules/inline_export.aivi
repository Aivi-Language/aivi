@no_prelude
module integrationTests.syntax.modules.inlineExport

use aivi.testing

export greet = name => "Hello, { name }"

export double : Int -> Int
export double = x => x * 2

@test "inline exported bindings are accessible within the same module"
inlineExportWorks = do Effect {
  assertEq (greet "World") "Hello, World"
  assertEq (double 5) 10
}

@no_prelude
module integrationTests.complex.monadValidation

use aivi
use aivi.testing
use aivi.text (isEmpty, length)

// --- Typed validation errors ---

ValidationError =
  | EmptyField
  | TooShort Int
  | TooLong Int
  | OutOfRange Int Int Int

andThenValidation : Result ValidationError A -> (A -> Result ValidationError B) -> Result ValidationError B
andThenValidation = result next => result match
  | Ok value => next value
  | Err err  => Err err

andThenText : Result Text A -> (A -> Result Text B) -> Result Text B
andThenText = result next => result match
  | Ok value => next value
  | Err err  => Err err

// --- Result-based multi-field validator ---

validateUsername = name =>
  if isEmpty name then Err EmptyField
  else if length name < 3 then Err (TooShort (length name))
  else if length name > 20 then Err (TooLong (length name))
  else Ok name

validateAge = n => if n < 0 || n > 150 then Err (OutOfRange n 0 150) else Ok n

validateScore = n =>
  if n < 0 then Err (OutOfRange n 0 100)
  else if n > 100 then Err (OutOfRange n 0 100)
  else Ok n

// Compose: validate all three fields, fail at first error
validateUser = name age score =>
  andThenValidation (validateUsername name) (validName =>
    andThenValidation (validateAge age) (validAge =>
      andThenValidation (validateScore score) (validScore =>
        Ok { name: validName, age: validAge, score: validScore }
      )
    )
  )

// --- Option-based nested map lookups ---

ConfigMap = Map Text (Map Text Int)

lookupSetting = section key cfg =>
  Map.get section cfg match
    | Some foundSection => Map.get key foundSection
    | None              => None

// --- List pairing with guard-like filtering ---

pairsWithSum = target xs ys =>
  List.flatMap (x =>
    ys
      |> List.filter (y => x + y == target)
      |> List.map (y => (x, y))
  ) xs

validateScoreText = score => validateScore score match
  | Ok validScore => Ok validScore
  | Err _         => Err "invalid score"

// --- Tests ---

@test "validateUsername: happy path"
validateUsername_happy = {
  res = validateUsername "alice"
  assertEq res (Ok "alice")
}

@test "validateUsername: empty field"
validateUsername_empty = {
  res = validateUsername ""
  assertEq res (Err EmptyField)
}

@test "validateUsername: too short"
validateUsername_tooShort = {
  res = validateUsername "ab"
  assertEq res (Err (TooShort 2))
}

@test "validateUsername: too long"
validateUsername_tooLong = {
  res = validateUsername "abcdefghijklmnopqrstu"
  assertEq res (Err (TooLong 21))
}

@test "validateAge: out of range"
validateAge_outOfRange = {
  resNeg = validateAge (-1)
  assertEq resNeg (Err (OutOfRange (-1) 0 150))

  resTooBig = validateAge 200
  assertEq resTooBig (Err (OutOfRange 200 0 150))

  resOk = validateAge 25
  assertEq resOk (Ok 25)
}

@test "validateUser: full happy path"
validateUser_happy = {
  res = validateUser "alice" 30 95
  assertEq res (Ok { name: "alice", age: 30, score: 95 })
}

@test "validateUser: short-circuits at first error"
validateUser_shortCircuit = {
  // Name fails first; age and score are never checked
  res = validateUser "" (-1) 999
  assertEq res (Err EmptyField)

  // Name ok, age fails
  res2 = validateUser "alice" 200 50
  assertEq res2 (Err (OutOfRange 200 0 150))
}

@test "Option nested lookup succeeds"
optionNestedLookup = {
  inner1 = Map.insert "timeout" 30 Map.empty
  inner2 = Map.insert "retries" 5 Map.empty
  cfg    = Map.insert "network" inner1 (Map.insert "app" inner2 Map.empty)

  timeout = lookupSetting "network" "timeout" cfg
  retries = lookupSetting "app" "retries" cfg
  missing = lookupSetting "network" "missing" cfg
  absent  = lookupSetting "nosection" "key" cfg

  assertEq timeout (Some 30)
  assertEq retries (Some 5)
  assertEq missing None
  assertEq absent None
}

@test "Option short-circuits on missing key"
optionShortCircuit = {
  // Empty config: outer key missing, inner never evaluated
  emptyResult = lookupSetting "any" "key" Map.empty
  assertEq emptyResult None
}

@test "pairs summing to target"
pairsSum = {
  xs    = [1, 2, 3, 4]
  ys    = [6, 7, 8, 9]
  pairs = pairsWithSum 10 xs ys
  // 1+9=10, 2+8=10, 3+7=10, 4+6=10
  assertEq pairs [(1, 9), (2, 8), (3, 7), (4, 6)]
}

@test "Result and Option interop"
resultOptionInterop = {
  // Convert Option to Result for uniform error handling
  cfg = Map.insert "x" 42 Map.empty

  found = Map.get "x" cfg match
    | Some v => Ok v
    | None   => Err "missing key"

  notFound = Map.get "z" cfg match
    | Some v => Ok v
    | None   => Err "missing key"

  assertEq found (Ok 42)
  assertEq notFound (Err "missing key")

  // Compose validation on top of lookup
  combined = andThenText found validateScoreText
  assertEq combined (Ok 42)
}

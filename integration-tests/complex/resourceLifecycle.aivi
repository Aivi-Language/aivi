@no_prelude
module integrationTests.complex.resourceLifecycle

use aivi
use aivi.testing
use aivi.file

managedTempFile = path => content =>
  Unit
    |> start => writeText path content
    |> afterWrite => pure path@cleanup delete#managedPath
    |> afterAcquire => pure managedPath

readWhileManaged : Text -> Text -> Effect Text (Result Text Text)
readWhileManaged = path => content =>
  managedTempFile path content
    |> readText

failWhileManaged : Text -> Text -> Text -> Effect Text A
failWhileManaged = path => content => message =>
  managedTempFile path content
    |> managedPath => fail message

assertMissing : Text -> Effect Text Unit
assertMissing = path =>
  path
|> exists
|> assertEq False

readManagedPairs : List (Text, Text) -> List (Result Text Text) -> Effect Text (List (Result Text Text))
readManagedPairs = pairs => acc => pairs match
  | []                         => pure (reverseList acc)
  | [(path, content), ...rest] =>
      readWhileManaged path content
        |> readResult =>
             assertMissing path
               |> checked =>
                    readManagedPairs rest [readResult, ...acc]

@test "resource acquire and release cleans up file"
resourceAcquireRelease = {
  path = "/tmp/aivi_complex_resource_1.txt"

  readWhileManaged path "hello resource"
    |> readResult =>
         assertOk readResult
           |> txt =>
                assertEq txt "hello resource"
                  |> checked =>
                       assertMissing path
}

@test "resource cleanup runs even on failure"
resourceCleanupOnFailure = {
  path = "/tmp/aivi_complex_resource_2.txt"

  attempt (failWhileManaged path "ephemeral" "intentional error")
    |> res =>
         assertErr res
           |> err =>
                assertEq err "intentional error"
                  |> checked =>
                       assertMissing path
}

@test "sequential resource scopes are independent"
resourceSequential = {
  path1 = "/tmp/aivi_complex_resource_3a.txt"
  path2 = "/tmp/aivi_complex_resource_3b.txt"

  readWhileManaged path1 "first"
    |> r1 =>
         readWhileManaged path2 "second"
           |> r2 =>
                assertOk r1
                  |> txt1 =>
                       assertEq txt1 "first"
                         |> checked1 =>
                              assertOk r2
                                |> txt2 =>
                                     assertEq txt2 "second"
                                       |> checked2 =>
                                            assertMissing path1
                                              |> checked3 =>
                                                   assertMissing path2
}

@test "resource loop: acquire use release per iteration"
resourceLoop = {
  paths = [
    "/tmp/aivi_complex_resource_4a.txt"
    "/tmp/aivi_complex_resource_4b.txt"
    "/tmp/aivi_complex_resource_4c.txt"
  ]

  values = ["alpha", "beta", "gamma"]

  readManagedPairs (List.zip paths values) []
    |> results =>
         assertEq results [Ok "alpha", Ok "beta", Ok "gamma"]
           |> checked1 =>
                assertMissing "/tmp/aivi_complex_resource_4a.txt"
                  |> checked2 =>
                       assertMissing "/tmp/aivi_complex_resource_4b.txt"
                         |> checked3 =>
                              assertMissing "/tmp/aivi_complex_resource_4c.txt"
}

reverseList = xs => List.foldl (acc x => [x, ...acc]) [] xs

@no_prelude
module integrationTests.complex.resourceLifecycle

use aivi
use aivi.testing
use aivi.file

readManagedText : Text -> Text -> Effect Text (Result Text Text)
readManagedText = path => content =>
  writeText path content
|> _ => pure path@cleanup delete#managedPath
|> _ => readText managedPath

assertReadOk : Text -> Text -> Result Text Text -> Effect Text Unit
assertReadOk = message => expected => result => result match
  | Ok txt => assertEq txt expected
  | Err _  => fail message

assertMissing : Text -> Effect Text Unit
assertMissing = path =>
  exists path
|> afterExists => assertEq afterExists False

readManagedPairs : List (Text, Text) -> List (Result Text Text) -> Effect Text (List (Result Text Text))
readManagedPairs = pairs => acc => pairs match
  | []                         => pure (reverseList acc)
  | [(path, content), ...rest] =>
    readManagedText path content
|> txt => {
      assertMissing path
      readManagedPairs rest [txt, ...acc]
}

@test "resource acquire and release cleans up file"
resourceAcquireRelease = {
  path = "/tmp/aivi_complex_resource_1.txt"

  readManagedText path "hello resource"
  |> readResult => {
    assertMissing path
    assertReadOk "file read failed while resource was live" "hello resource" readResult
  }
}

@test "resource cleanup runs even on failure"
resourceCleanupOnFailure = {
  path = "/tmp/aivi_complex_resource_2.txt"

  attempt (
    writeText path "ephemeral"
    |> _ => pure path@cleanup delete#managedPath
    |> _ => fail "intentional error"
  )
  |> res => {
    assertMissing path
    res match
      | Err e => assertEq e "intentional error"
      | Ok _  => fail "expected failure"
  }
}

@test "sequential resource scopes are independent"
resourceSequential = {
  path1 = "/tmp/aivi_complex_resource_3a.txt"
  path2 = "/tmp/aivi_complex_resource_3b.txt"

  readManagedText path1 "first"
  |> r1 => {
    readManagedText path2 "second"
    |> r2 => {
      assertMissing path1
      assertMissing path2
      assertReadOk "first read failed" "first" r1
      assertReadOk "second read failed" "second" r2
    }
  }
}

@test "resource loop: acquire use release per iteration"
resourceLoop = {
  paths = [
    "/tmp/aivi_complex_resource_4a.txt"
    "/tmp/aivi_complex_resource_4b.txt"
    "/tmp/aivi_complex_resource_4c.txt"
  ]

  values = ["alpha", "beta", "gamma"]

  readManagedPairs (List.zip paths values) []
  |> results => assertEq results [Ok "alpha", Ok "beta", Ok "gamma"]
  |> _ => assertMissing "/tmp/aivi_complex_resource_4a.txt"
  |> _ => assertMissing "/tmp/aivi_complex_resource_4b.txt"
  |> _ => assertMissing "/tmp/aivi_complex_resource_4c.txt"
}

reverseList = xs => List.foldl (acc x => [x, ...acc]) [] xs

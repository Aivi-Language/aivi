// EXPECT-ERROR: column 'active' has no matching field
module integrationTests.compileFail.relationSchemaMissingRowField

use aivi
use aivi.database

Product = { id: Int, name: Text }

products : Relation Product
products = relation "products" [
  { name: "id",     type: IntType,    constraints: [NotNull], default: None }
  { name: "name",   type: Varchar 80, constraints: [NotNull], default: None }
  { name: "active", type: BoolType,   constraints: [NotNull], default: Some (DefaultBool True) }
] []

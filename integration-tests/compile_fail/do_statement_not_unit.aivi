// EXPECT-ERROR: type mismatch
@no_prelude
module integrationTests.compileFail.doStatementNotUnit

use aivi

// A bare non-Effect expression in statement position (not the final expression)
// is a compile error. The expression must be an Effect (its value is discarded
// via sequencing). A plain `Int` cannot be sequenced.
bad = do Effect {
  42
  pure Unit
}

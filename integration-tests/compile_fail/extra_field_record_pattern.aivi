// EXPECT-ERROR: E3000
@no_prelude
module integrationTests.compileFail.extraFieldRecordPattern

use aivi

// Point is a closed record with exactly x and y.
// Matching with an extra field 'z' that does not exist in Point is a type error.
Point = { x: Int, y: Int }

describe : Point -> Text
describe = p => p match
  | { x, y, z } => "three-dimensional"
  | _           => "unknown"

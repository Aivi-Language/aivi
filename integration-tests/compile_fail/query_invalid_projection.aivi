// EXPECT-ERROR: record has no field 'sku'
module integrationTests.compileFail.queryInvalidProjection

use aivi
use aivi.database

Product = { id: Int, name: Text }

productTable : Table Product
productTable = table "products" [
  { name: "id",   type: IntType,     constraints: [NotNull], default: None }
  { name: "name", type: Varchar 120, constraints: [NotNull], default: None }
]

bad : Query Text
bad = from productTable |> select (p => p.sku)

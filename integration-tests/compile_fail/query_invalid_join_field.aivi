// EXPECT-ERROR: record has no field 'sku'
module integrationTests.compileFail.queryInvalidJoinField

use aivi
use aivi.database

Product = { id: Int, name: Text }
Order   = { id: Int, productId: Int }

productTable : Table Product
productTable = table "products" [
  { name: "id",   type: IntType,     constraints: [NotNull], default: None }
  { name: "name", type: Varchar 120, constraints: [NotNull], default: None }
]

orderTable : Table Order
orderTable = table "orders" [
  { name: "id",        type: IntType, constraints: [NotNull], default: None }
  { name: "productId", type: IntType, constraints: [NotNull], default: None }
]

badJoin : Query Order
badJoin = do Query {
  order   <- from orderTable
  product <- from productTable
  guard (order.productId == product.sku)
  queryOf order
}

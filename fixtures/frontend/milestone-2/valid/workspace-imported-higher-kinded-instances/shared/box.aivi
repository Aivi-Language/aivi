type Box A = Box A

type (A -> B) -> Box A -> Box B
func mapBox = transform box => box
 ||> Box item -> Box (transform item)

instance Functor Box = {
    map = mapBox
}

type (B -> A -> B) -> B -> Box A -> B
func reduceBox = step seed box => box
 ||> Box item -> step seed item

instance Foldable Box = {
    reduce = reduceBox
}

value one : Box Int = Box 1

export (Box, one)

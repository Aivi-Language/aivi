class Eq A = {
    type (==) : A -> A -> Bool
}

type Blob = Blob Bytes

type Blob -> Blob -> Bool
func blobEquals = left right =>
    True

instance Eq Blob = {
    (==) = left right => blobEquals left right
}

type Blob -> Blob -> Bool
func sameBlob = left right =>
    left == right

class Compare A = {
    type same : A -> A -> Bool
}

type Label = Label Text

instance Compare Label = {
    same = left right => left == right
}

type HttpError =
  | Timeout

type User = { id: Int }

type DecodeMode =
  | Strict
  | Permissive

type Map K V =
  | EmptyMap
  | Entry K V (Map K V)

domain Duration over Int = {
    suffix sec
    type sec : Int
    sec = value => Duration value
}

domain Retry over Int = {
    suffix times
    type times : Int
    times = value => Retry value
}

@source http.get "/users" with {
    headers: Entry "Authorization" "Bearer demo" EmptyMap,
    decode: Strict,
    retry: 3times,
    timeout: 5sec
}
signal users : Signal (Result HttpError (List User))

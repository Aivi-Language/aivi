domain Duration over Int = {
    suffix sec
    type sec : Int
    sec = value => Duration value
}

domain Retry over Int = {
    suffix times
    type times : Int
    times = value => Retry value
}

func step = x =>
    x

@recur.timer 5sec
signal polled : Signal Int = 0
 @|> step
 <|@ step

@recur.backoff 3times
value retried : Task Int Int = 0
 @|> step
 <|@ step

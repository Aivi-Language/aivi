use aivi.api (
    ApiSource
    ApiError
)

use aivi.http (DecodeMode)

domain Duration over Int = {
    suffix sec
    type sec : Int
    sec = value => Duration value
}

domain Retry over Int = {
    suffix times
    type times : Int
    times = value => Retry value
}

type Pet = {
    id: Int,
    name: Text,
    status: Option Text
}

type NewPet = {
    name: Text,
    status: Option Text
}

value serverUrl : Text = "https://api.petstore.io/v2"
value apiToken : Text = "my-token"

@source api "./petstore.yaml" with {
    baseUrl: serverUrl,
    auth: BearerToken apiToken,
    timeout: 30sec
}
signal petstore : ApiSource

@source api "./petstore.yaml" with {
    baseUrl: serverUrl,
    timeout: 30sec
}
signal publicApi : ApiSource

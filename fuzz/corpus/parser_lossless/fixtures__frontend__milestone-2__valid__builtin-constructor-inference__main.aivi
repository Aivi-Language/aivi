type Screen =
  | Loading
  | Ready Text
  | Failed Text

type NamePair = NamePair Text Text

val first = Some "Ada"
val last = None

val maybePair:Option NamePair =
 &|> first
 &|> last
  |> NamePair

val okFirst = Ok "Ada"
val errLast = Err "missing"

val resultPair:Result Text NamePair =
 &|> okFirst
 &|> errLast
  |> NamePair

val current:Screen = Loading

val maybeLabel:Option Text =
    current
     ||> Loading => None
     ||> Ready title => Some title
     ||> Failed reason => Some reason

val resultLabel:Result Text Text =
    current
     ||> Loading => Ok "loading"
     ||> Ready title => Ok title
     ||> Failed reason => Err reason

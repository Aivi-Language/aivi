domain Duration over Int
    literal ms : Int -> Duration
    type Int -> Duration
    make
    type Duration -> Int
    value

domain Count over Int
    type Int -> Count
    make

domain NonEmpty A over List A
    type A -> NonEmpty A
    singleton
    type NonEmpty A -> A
    head

val delay : Duration = make 250
val delayMillis : Int = value delay
val literalMillis : Int = value 250ms
val first : Int = head (singleton 1)

export first

use aivi.path (
    Path
    PathError
    InvalidPath
    PathNotFound
)

use aivi.fs (
    FsError
    FsEvent
    NotFound
    PermissionDenied
    ReadFailed
    WriteFailed
    FsProtocolError
    Created
    Changed
    Deleted
)

value homePath:Path = "/home/user"
value badPath:PathError = InvalidPath "/not/valid/\000"
value missingPath:PathError = PathNotFound "/etc/missing"
value notFound:FsError = NotFound "/tmp/missing.txt"
value permDenied:FsError = PermissionDenied "/etc/shadow"
value readFail:FsError = ReadFailed "/dev/broken"
value writeFail:FsError = WriteFailed "/read-only/file.txt"
value protoErr:FsError = FsProtocolError "unexpected EOF"
value createdEvt:FsEvent = Created
value changedEvt:FsEvent = Changed
value deletedEvt:FsEvent = Deleted

type FileRef = {
    path: Path,
    label: Text
}

value configFile:FileRef = {
    path: "/etc/app.conf",
    label: "config"
}

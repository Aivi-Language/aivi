use aivi.bits (
    and
    or
    xor
    not
    shiftLeft
    shiftRight
    shiftRightUnsigned
)

/** Bitwise AND of two integers. */
type Int -> Int -> Int
func bitAnd = a b =>
    and a b

/** Bitwise OR of two integers. */
type Int -> Int -> Int
func bitOr = a b =>
    or a b

/** Bitwise XOR of two integers. */
type Int -> Int -> Int
func bitXor = a b =>
    xor a b

/** Bitwise NOT (complement) of an integer. */
type Int -> Int
func bitNot = a =>
    not a

/** Shift left: a << b */
type Int -> Int -> Int
func shiftLeftBy = a b =>
    shiftLeft a b

/** Arithmetic shift right: a >> b (sign-extending) */
type Int -> Int -> Int
func shiftRightBy = a b =>
    shiftRight a b

/** Logical shift right: a >>> b (zero-filling) */
type Int -> Int -> Int
func shiftRightUnsignedBy = a b =>
    shiftRightUnsigned a b

@test
value bits_and_basic : Task Text Bool = pure (bitAnd 0xFF 0x0F == 0x0F)

@test
value bits_and_zero : Task Text Bool = pure (bitAnd 0xAB 0 == 0)

@test
value bits_or_basic : Task Text Bool = pure (bitOr 0xF0 0x0F == 0xFF)

@test
value bits_xor_basic : Task Text Bool = pure (bitXor 0xFF 0x0F == 0xF0)

@test
value bits_not_zero : Task Text Bool = pure (bitNot 0 == -1)

@test
value bits_shift_left : Task Text Bool = pure (shiftLeftBy 1 8 == 256)

@test
value bits_shift_right : Task Text Bool = pure (shiftRightBy 256 8 == 1)

@test
value bits_shift_right_unsigned : Task Text Bool = pure (shiftRightUnsignedBy 0xFF00 8 == 0xFF)

@test
value bits_mask_byte : Task Text Bool = pure (bitAnd (shiftRightUnsignedBy 0x00FF0000 16) 0xFF == 0xFF)

export (
    and
    or
    xor
    not
    shiftLeft
    shiftRight
    shiftRightUnsigned
    bitAnd
    bitOr
    bitXor
    bitNot
    shiftLeftBy
    shiftRightBy
    shiftRightUnsignedBy
)

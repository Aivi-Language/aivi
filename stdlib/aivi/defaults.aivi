value defaultText : Text = ""
value defaultInt : Int = 0
value defaultBool : Bool = False

@test
value default_text_is_empty : Task Text Bool = pure (defaultText == "")

@test
value default_int_is_zero : Task Text Bool = pure (defaultInt == 0)

@test
value default_bool_is_false : Task Text Bool = pure (not defaultBool)

export (Option, defaultText, defaultInt, defaultBool)

type PathError =
  | InvalidPath Text
  | PathNotFound Text

domain Path over Text
    type Text -> Result PathError Path
    parse
    type Path -> Text
    unwrap
    type Path -> Text -> Path
    (/)
    type Path -> Option Path
    parent
    type Path -> Option Text
    filename
    type Path -> Option Text
    stem
    type Path -> Option Text
    ext

export (Path, PathError, InvalidPath, PathNotFound)

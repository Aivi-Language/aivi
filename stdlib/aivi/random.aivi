use aivi.random (randomBytes, randomInt)

type RandomError =
  | InsufficientEntropy

type RandomSource = Unit

type RandomTask = (Task RandomError Bytes)

type RandomIntTask = (Task Text Int)

type RandomBytesTask = (Task Text Bytes)

export (RandomError, InsufficientEntropy, RandomSource, RandomTask, RandomIntTask, RandomBytesTask, randomBytes, randomInt)

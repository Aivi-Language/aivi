main = gtkApp {
  id: "docs.hello",
  title: "Hello",
  size: (400, 240),
  model: { count: 0 },
  onStart: _ _ => pure Unit,
  subscriptions: noSubscriptions,
  view: model => ~<gtk>
    <GtkBox orientation="vertical" spacing="12">
      <GtkLabel label="Count: {toText model.count}" />
    </GtkBox>
  </gtk>,
  toMsg: auto,
  update: _ model => pure { model, commands: [] }
}

main = do Effect {
  dbConn <- db.connect { driver: Sqlite, url: "app.db" }
  _      <- db.runMigrationsOn dbConn [userTable]

  activeUsersQuery =
    db.from userTable
    |> db.where_ _.active

  activeUsers <- db.runQueryOn dbConn activeUsersQuery
  _           <- db.close dbConn
  pure activeUsers
}

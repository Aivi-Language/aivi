@test
module order_tests

@test "addition is commutative"
addCommutative = do Effect {
  assertEq (add 2 3) (add 3 2)
}

@test "empty list has length zero"
emptyLen = do Effect {
  assertEq (length []) 0
}

use aivi

@test "discount rounds down"
discountFloor = do Effect {
  assertEq (applyDiscount 100.0 0.15) 85.0
}

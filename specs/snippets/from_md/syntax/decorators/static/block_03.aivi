@static
petStoreApi = openapi.fromFile "./petstore.json"

petStoreClient = petStoreApi {
  bearerToken: Some "sk-..."
  baseUrl: None
  headers: None
  timeoutMs: None
  retryCount: None
  strictStatus: None
}

listSomePets = petStoreClient.listPets { limit: Some 10 }

{ listPets } = petStoreApi {
  bearerToken: None
  baseUrl: None
  headers: None
  timeoutMs: None
  retryCount: None
  strictStatus: None
}

listPetsWithDestructuring = listPets {}

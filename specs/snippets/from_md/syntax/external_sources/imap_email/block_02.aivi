InboxMessage = {
  uid: Option Int
  subject: Option Text
  from: Option Text
  to: Option Text
  date: Option Text
  body: Text
}

loadInbox =
  email.imap {
    host: "imap.gmail.com"
    user: "user@gmail.com"
    auth: OAuth2 myToken
    mailbox: Some "INBOX"
    filter: Some "UNSEEN"
    limit: Some 50
    port: None
    starttls: None
  }
     |> load

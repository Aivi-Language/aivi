use aivi.email

InboxMessage = {
  uid: Option Int
  subject: Option Text
  from: Option Text
  to: Option Text
  date: Option Text
  body: Text
}

fetchUnread : ImapConfig -> Effect Text (List InboxMessage)
fetchUnread = config =>
  config
   |> imapOpen#session
  ~|>imapSelect "INBOX" session
   |> imapSearch "UNSEEN"
   |> uids => imapFetch uids session

use aivi.email

InboxMessage = {
  uid: Option Int
  subject: Option Text
  from: Option Text
  to: Option Text
  date: Option Text
  body: Text
}

fetchUnread : ImapConfig -> Effect Text (List InboxMessage)
fetchUnread = config => do Effect {
  session <- imapOpen config
  _       <- imapSelect "INBOX" session
  uids    <- imapSearch "UNSEEN" session
  msgs    <- imapFetch uids session
  pure msgs
}

use aivi.bits

parseHeader : Bits -> Result Text { version: Int, flags: Bits, payload: Bits }
parseHeader = raw =>
  s0          = streamFromBits raw
  streamRead 1 s0 match
    | Ok (vb, s1) =>
        streamRead 2 s1 match
          | Ok (flags, s2) =>
              streamRead 4 s2 match
                | Ok (payload, _) => Ok { version: toInt vb, flags: flags, payload: payload }
                | Err err         => Err err
          | Err err => Err err
    | Err err => Err err

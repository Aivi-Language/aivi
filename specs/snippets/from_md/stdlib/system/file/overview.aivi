use aivi.file (readText, stat)

main =
  readText "config.json"
    |> contentRes =>
         print (contentRes or "missing config")
           |> logDone =>
                stat "large_video.mp4"
                  |> infoRes => infoRes match
                    | Ok info => print "File size: {info.size} bytes"
                    | Err _   => print "File not found"

use aivi.email

processUnread = session =>
  imapSearch "UNSEEN" session
|> uids => imapFetch uids session
|> processMsgs

watchInbox = session =>
  session
  ~|>imapSelect "INBOX"
   |> imapIdle 300
   |> result => result match
  | MailboxChanged =>
      processUnread session
      ~|>watchInbox session
  | TimedOut =>
      watchInbox session

use aivi.email

processInbox = token => {
  host: "imap.gmail.com"
  user: "user@gmail.com"
  auth: OAuth2 token
  port: None
  starttls: None
  mailbox: None
  filter: None
  limit: None
}
 |> imapOpen#session
~|>imapSelect "INBOX" session
 |> imapSearch "UNSEEN"
 |> uids =>
  imapFetch uids session
  ~|>imapAddFlags uids ["\Seen"] session

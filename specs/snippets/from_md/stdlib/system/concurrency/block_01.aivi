after : Int -> A -> Effect Text A
after = millis value => bind (sleep millis) (finished => pure value)

slow : Effect Text Text
slow = after 50 "left"

fast : Effect Text Text
fast = after 0 "right"

firstResult : Effect Text Text
firstResult = race slow fast

guardedValue : Effect Text Int
guardedValue = timeoutWith 100 "timeout" (pure 9)

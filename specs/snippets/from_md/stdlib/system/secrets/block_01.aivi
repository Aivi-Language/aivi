use aivi.secrets
use aivi.text (toBytes, Utf8)

loadStoredAlgorithm = do Effect {
  keyId  = "services/github/token"
  secret = blob keyId "aes-256-gcm" (toBytes Utf8 "ciphertext-from-kms")
  _      <- put keyId secret
  stored <- get keyId
  pure (
    stored match
      | Some saved => Some (blobAlgorithm saved)
      | None       => None
  )
}

use aivi.net.httpServer

startServer = resource {
  server <- listen { address: "127.0.0.1:8080" } (request =>
    pure (Http {
        status: 200
        headers: [{ name: "Content-Type", value: "text/plain" }]
        body: [72, 101, 108, 108, 111] // "Hello" encoded as UTF-8 bytes: H e l l o
    })
  )

  pure server
}

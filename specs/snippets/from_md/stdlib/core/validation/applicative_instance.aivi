// The built-in accumulating instance works with Validation (List E)
instance Apply (Validation (List E) A) = {
  ap: f v => (f, v) match
    | (Valid func, Valid a)    => Valid (func a)
    | (Invalid e1, Invalid e2) => Invalid (e1 ++ e2)
    | (Invalid e, _)           => Invalid e
    | (_, Invalid e)           => Invalid e
}

instance Applicative (Validation (List E) A) = {
  of: a => Valid a
}

use aivi.i18n
use aivi.system (localeTag)

defaultLocale : Locale
defaultLocale = { language: "en", region: Some "US", variants: [], tag: "en-US" }

systemLocale : Effect Text Locale
systemLocale = localeTag
  |> tagOpt => tagOpt match
    | Some tag => parseLocale tag or defaultLocale
    | None     => defaultLocale

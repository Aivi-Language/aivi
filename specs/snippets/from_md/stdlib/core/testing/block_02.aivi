use aivi.testing
use aivi.rest

User = { id: Int, name: Text }

fetchUsers = rest.get ~u(https://api.example.com/users)

@test "fetch users with a mocked request"
fetchUsersWithMock = mock
  rest.g - et = _ => pure [{ id: 1, name: "Ada" }]
in do Effect {
  users <- fetchUsers
  assertEq (length users) 1
  users match
    | [u, ..._] => assertEq u.name "Ada"
    | []        => fail "expected one mocked user"
}

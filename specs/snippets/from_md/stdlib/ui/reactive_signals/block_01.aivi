projectHeading = model =>
  if model.searchQuery == ""
    then "All Projects"
    else "Search · {model.searchQuery}"

projectHeadingDerived = derive (model =>
  if model.searchQuery == ""
    then "All Projects"
    else "Search · {model.searchQuery}"
)

visibleProjectNames = memo "projects.visibleNames" (model =>
  map (project => project.name) model.visibleProjects
)

nextEventSummary : Effect GtkError (Option Text)
nextEventSummary = signalPoll {}
  |> nextEvent => nextEvent match
    | None                                => None
    | Some (GtkClicked _ _)               => Some "button clicked"
    | Some (GtkInputChanged _ _ txt)      => Some txt
    | Some (GtkFocusOut _ _)              => Some "focus lost"
    | Some (GtkUnknownSignal _ _ sig _ _) => Some sig
    | Some _                              => Some "other event"

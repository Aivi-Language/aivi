Contact = {
  name: Text
  email: Text
}

MkContact : Text -> Text -> Contact
MkContact = name email => {
  name: name
  email: email
}

toContact : {
  name: Field Text
  email: Field Text
} -> Validation (List Text) Contact
toContact = model => do Applicative {
  name  <- validate (allOf [required, minLength 2]) model.name
  email <- validate (allOf [required, email]) model.email
  MkContact name email
}

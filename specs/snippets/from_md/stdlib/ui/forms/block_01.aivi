Contact = {
  name: Text
  email: Text
}

MkContact : Text -> Text -> Contact
MkContact = name email => {
  name: name
  email: email
}

toContact : {
  name: Field Text
  email: Field Text
} -> Validation (List Text) Contact
toContact = model =>
  model
     &|> validate (allOf [required, minLength 2]) model.name #name
     &|> validate (allOf [required, email]) model.email #email
      |> MkContact name email

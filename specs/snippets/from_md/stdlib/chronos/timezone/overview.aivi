use aivi.chronos.timezone

// Instantiation
paris = ~tz(Europe/Paris)
tokyo = ~tz(Asia/Tokyo)

// Creating a ZonedDateTime
meeting = ~zdt(2024-05-21T12:00:00[Europe/Paris])

isoText      = toText meeting
meetingLabel = meeting |> format "dd.MM.yyyy HH:mm XXX VV"
utcMoment    = toInstant meeting
tokyoView    = atZone meeting tokyo

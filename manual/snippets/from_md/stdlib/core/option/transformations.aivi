// map: transform the inner value
doubled = Some 5 |> map (_ * 2)    // Some 10

// flatMap: chain operations that may fail
findUser = id => users |> find (.id == id)
findEmail = user => user.email

email = findUser 42 |> flatMap findEmail

// filter: keep only if predicate holds
adult = Some 25 |> filter (_ >= 18)    // Some 25
minor = Some 12 |> filter (_ >= 18)    // None

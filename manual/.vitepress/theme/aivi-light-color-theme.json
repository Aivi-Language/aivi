{
  "$schema": "vscode://schemas/color-theme",
  "name": "AIVI Light",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#fdf6e3",
    "editor.foreground": "#657b83",
    "editorCursor.foreground": "#586e75",
    "editor.lineHighlightBackground": "#eee8d5",
    "editor.selectionBackground": "#d3cbb8",
    "editor.inactiveSelectionBackground": "#ddd6c4",
    "editor.wordHighlightBackground": "#ddd6c4",
    "editor.wordHighlightStrongBackground": "#d3cbb8",
    "editorLineNumber.foreground": "#b8b0a0",
    "editorLineNumber.activeForeground": "#93a1a1",
    "editorIndentGuide.background1": "#eee8d5",
    "editorIndentGuide.activeBackground1": "#d3cbb8",
    "editorWhitespace.foreground": "#eee8d5",
    "editorWidget.background": "#eee8d5",
    "editorWidget.border": "#d3cbb8",
    "editorSuggestWidget.background": "#eee8d5",
    "editorSuggestWidget.border": "#d3cbb8",
    "editorSuggestWidget.selectedBackground": "#d3cbb8",
    "editorHoverWidget.background": "#eee8d5",
    "editorHoverWidget.border": "#d3cbb8",
    "editorBracketMatch.background": "#d3cbb8",
    "editorBracketMatch.border": "#268bd2",
    "editorError.foreground": "#dc322f",
    "editorWarning.foreground": "#b58900",
    "editorInfo.foreground": "#268bd2",
    "focusBorder": "#268bd2"
  },
  "tokenColors": [

    { "name": "Comment line --",
      "scope": "comment.line.double-dash.aivi",
      "settings": { "foreground": "#93a1a1", "fontStyle": "italic" } },

    { "name": "Comment doc ---",
      "scope": "comment.block.documentation.aivi",
      "settings": { "foreground": "#93a1a1", "fontStyle": "italic" } },

    { "name": "Doc tag @param @returns",
      "scope": "keyword.other.documentation.aivi",
      "settings": { "foreground": "#6c71c4", "fontStyle": "italic" } },

    { "name": "Doc tag keyword (structured)",
      "scope": "keyword.other.documentation.tag.aivi",
      "settings": { "foreground": "#6c71c4", "fontStyle": "italic" } },

    { "name": "Doc tag param name",
      "scope": "variable.other.documentation.tag.name.aivi",
      "settings": { "foreground": "#cb4b16", "fontStyle": "italic" } },

    { "name": "String",
      "scope": "string.quoted.double.aivi",
      "settings": { "foreground": "#859900" } },

    { "name": "String punctuation",
      "scope": ["punctuation.definition.string.begin.aivi",
                "punctuation.definition.string.end.aivi"],
      "settings": { "foreground": "#859900" } },

    { "name": "String interpolation braces",
      "scope": ["punctuation.section.interpolation.begin.aivi",
                "punctuation.section.interpolation.end.aivi"],
      "settings": { "foreground": "#2aa198" } },

    { "name": "Escape sequence",
      "scope": "constant.character.escape.aivi",
      "settings": { "foreground": "#2aa198" } },

    { "name": "Number integer",
      "scope": ["constant.numeric.integer.aivi", "constant.numeric.float.aivi"],
      "settings": { "foreground": "#d33682" } },

    { "name": "Number unit suffix (5s, 250ms)",
      "scope": "keyword.other.unit.aivi",
      "settings": { "foreground": "#b58900" } },

    { "name": "Declaration keywords (type val fun sig class domain provider)",
      "scope": ["keyword.declaration.type.aivi",
                "keyword.declaration.val.aivi",
                "keyword.declaration.fun.aivi",
                "keyword.declaration.sig.aivi",
                "keyword.declaration.class.aivi",
                "keyword.declaration.instance.aivi",
                "keyword.declaration.domain.aivi",
                "keyword.declaration.provider.aivi"],
      "settings": { "foreground": "#268bd2" } },

    { "name": "use keyword",
      "scope": "keyword.control.import.aivi",
      "settings": { "foreground": "#268bd2" } },

    { "name": "export keyword",
      "scope": "keyword.control.export.aivi",
      "settings": { "foreground": "#6c71c4", "fontStyle": "bold" } },

    { "name": "Built-in type keywords (with as of key on pattern value match when if)",
      "scope": "keyword.other.aivi",
      "settings": { "foreground": "#268bd2", "fontStyle": "italic" } },

    { "name": "Type name / class name",
      "scope": ["entity.name.type.aivi", "entity.name.class.aivi"],
      "settings": { "foreground": "#b58900" } },

    { "name": "Type parameter (lowercase after type keyword)",
      "scope": "variable.parameter.type.aivi",
      "settings": { "foreground": "#657b83" } },

    { "name": "Function name (fun / sig)",
      "scope": ["entity.name.function.aivi", "entity.name.variable.signal.aivi"],
      "settings": { "foreground": "#657b83", "fontStyle": "bold" } },

    { "name": "Value name (val)",
      "scope": "entity.name.variable.aivi",
      "settings": { "foreground": "#657b83" } },

    { "name": "Domain / provider / namespace name",
      "scope": ["entity.name.namespace.aivi", "entity.name.module.aivi"],
      "settings": { "foreground": "#2aa198" } },

    { "name": "Constructor (uppercase identifier)",
      "scope": "entity.name.tag.constructor.aivi",
      "settings": { "foreground": "#b58900" } },

    { "name": "Built-in value constants (True False None Some Ok Err Valid Invalid)",
      "scope": "support.constant.builtin.aivi",
      "settings": { "foreground": "#b58900" } },

    { "name": "Built-in types (Int Bool Text List ...)",
      "scope": "support.type.builtin.aivi",
      "settings": { "foreground": "#268bd2" } },

    { "name": "Labeled parameter #name",
      "scope": "variable.parameter.labeled.aivi",
      "settings": { "foreground": "#2aa198" } },

    { "name": "Labeled parameter # sigil",
      "scope": "punctuation.definition.parameter.aivi",
      "settings": { "foreground": "#2aa198" } },

    { "name": "Import names",
      "scope": "variable.other.import.aivi",
      "settings": { "foreground": "#657b83" } },

    { "name": "Decorator @ sigil",
      "scope": "punctuation.definition.decorator.aivi",
      "settings": { "foreground": "#2aa198" } },

    { "name": "Decorator @source keyword",
      "scope": "keyword.decorator.source.aivi",
      "settings": { "foreground": "#2aa198", "fontStyle": "bold" } },

    { "name": "Decorator @recur keyword",
      "scope": "keyword.decorator.recur.aivi",
      "settings": { "foreground": "#dc322f", "fontStyle": "bold" } },

    { "name": "Decorator generic label (@myDecorator)",
      "scope": "entity.name.label.decorator.aivi",
      "settings": { "foreground": "#2aa198" } },

    { "name": "Decorator provider name (after @source)",
      "scope": "entity.name.label.provider.aivi",
      "settings": { "foreground": "#2aa198" } },

    { "name": "Decorator method name (.get .every ...)",
      "scope": "entity.name.label.method.aivi",
      "settings": { "foreground": "#2aa198" } },

    { "name": "Accessor dot in decorator",
      "scope": "punctuation.accessor.aivi",
      "settings": { "foreground": "#93a1a1" } },

    { "name": "Pipe — transform |>",
      "scope": "keyword.operator.pipe.transform.aivi",
      "settings": { "foreground": "#cb4b16" } },

    { "name": "Pipe — gate ?|>",
      "scope": "keyword.operator.pipe.gate.aivi",
      "settings": { "foreground": "#b58900" } },

    { "name": "Pipe — case ||>",
      "scope": "keyword.operator.pipe.case.aivi",
      "settings": { "foreground": "#6c71c4" } },

    { "name": "Pipe — map *|>",
      "scope": "keyword.operator.pipe.map.aivi",
      "settings": { "foreground": "#2aa198" } },

    { "name": "Pipe — apply &|>",
      "scope": "keyword.operator.pipe.apply.aivi",
      "settings": { "foreground": "#859900" } },

    { "name": "Pipe — recur start @|>",
      "scope": "keyword.operator.pipe.recur-start.aivi",
      "settings": { "foreground": "#dc322f" } },

    { "name": "Pipe — recur step <|@",
      "scope": "keyword.operator.pipe.recur-step.aivi",
      "settings": { "foreground": "#dc322f" } },

    { "name": "Pipe — fanin <|*",
      "scope": "keyword.operator.pipe.fanin.aivi",
      "settings": { "foreground": "#268bd2" } },

    { "name": "Pipe — truthy T|>",
      "scope": "keyword.operator.pipe.truthy.aivi",
      "settings": { "foreground": "#859900" } },

    { "name": "Pipe — falsy F|>",
      "scope": "keyword.operator.pipe.falsy.aivi",
      "settings": { "foreground": "#dc322f" } },

    { "name": "Pipe — tap |",
      "scope": "keyword.operator.pipe.tap.aivi",
      "settings": { "foreground": "#93a1a1" } },

    { "name": "Arrow => (match arm / lambda body)",
      "scope": "keyword.operator.arrow.fat.aivi",
      "settings": { "foreground": "#cb4b16" } },

    { "name": "Arrow -> (function type)",
      "scope": "keyword.operator.arrow.thin.aivi",
      "settings": { "foreground": "#cb4b16" } },

    { "name": "Equality == !=",
      "scope": "keyword.operator.comparison.aivi",
      "settings": { "foreground": "#657b83" } },

    { "name": "Assignment =",
      "scope": "keyword.operator.assignment.aivi",
      "settings": { "foreground": "#657b83" } },

    { "name": "Attribute = in markup",
      "scope": "keyword.operator.assign.aivi",
      "settings": { "foreground": "#b8b0a0" } },

    { "name": "Type annotation :",
      "scope": "keyword.operator.type-annotation.aivi",
      "settings": { "foreground": "#93a1a1" } },

    { "name": "Dot projection",
      "scope": "keyword.operator.projection.aivi",
      "settings": { "foreground": "#93a1a1" } },

    { "name": "Arithmetic + - * /",
      "scope": "keyword.operator.arithmetic.aivi",
      "settings": { "foreground": "#657b83" } },

    { "name": "Record / struct field key",
      "scope": "variable.other.property.aivi",
      "settings": { "foreground": "#2aa198" } },

    { "name": "Markup tag punctuation < > </ />",
      "scope": "punctuation.definition.tag.aivi",
      "settings": { "foreground": "#b8b0a0" } },

    { "name": "Markup control element tag (<show> <each> <match> ...)",
      "scope": "entity.name.tag.control.aivi",
      "settings": { "foreground": "#2aa198", "fontStyle": "bold" } },

    { "name": "Markup user component tag (<MyComponent>)",
      "scope": "entity.name.tag.component.aivi",
      "settings": { "foreground": "#b58900" } },

    { "name": "Markup HTML/GTK/XML tag (<div> <gtk:Box>)",
      "scope": "entity.name.tag.html.aivi",
      "settings": { "foreground": "#268bd2" } },

    { "name": "Markup attribute name",
      "scope": "entity.other.attribute-name.aivi",
      "settings": { "foreground": "#6c71c4" } }

  ],
  "semanticTokenColors": {
    "type":      { "foreground": "#b58900" },
    "class":     { "foreground": "#b58900" },
    "interface": { "foreground": "#2aa198" },
    "enum":      { "foreground": "#b58900" },
    "enumMember":{ "foreground": "#b58900" },
    "function":  { "foreground": "#657b83", "bold": true },
    "method":    { "foreground": "#657b83", "bold": true },
    "variable":  { "foreground": "#657b83" },
    "parameter": { "foreground": "#657b83" },
    "property":  { "foreground": "#2aa198" },
    "namespace": { "foreground": "#2aa198" },
    "keyword":   { "foreground": "#268bd2" },
    "number":    { "foreground": "#d33682" },
    "string":    { "foreground": "#859900" },
    "regexp":    { "foreground": "#2aa198" },
    "operator":  { "foreground": "#657b83" },
    "comment":   { "foreground": "#93a1a1", "italic": true },
    "macro":     { "foreground": "#dc322f" },
    "decorator": { "foreground": "#2aa198" }
  }
}
